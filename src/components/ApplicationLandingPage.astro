---
import BaseLayout from './BaseLayout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import Breadcrumbs from './Breadcrumbs.astro';
import CTA from './CTA.astro';
import { SITE_CONFIG } from '../utils/constants.js';
import { generateFAQSchema, generateBreadcrumbSchema } from '../utils/seo.js';

interface Card { title: string; description: string; }
interface GalleryItem { image: string; title: string; label: string; alt: string; }
interface FAQItem { question: string; answer: string; }
interface Props {
  title: string; accent: string; eyebrow: string; description: string; metaDescription: string;
  keyword: string; route: string; heroImage: string; heroAlt: string; benefits: Card[];
  gallery: GalleryItem[]; steps: Card[]; faqs: FAQItem[]; ctaTitle: string; waMessage: string;
  fit: string[]; notFit: string[]; priceFactors: string[]; qualityChecks: string[];
}

const { title, accent, eyebrow, description, metaDescription, keyword, route, heroImage, heroAlt, benefits, gallery, steps, faqs, ctaTitle, waMessage, fit, notFit, priceFactors, qualityChecks } = Astro.props;
const whatsapp = `https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent(waMessage)}`;
const breadcrumbs = [{ name: 'Beranda', url: '/' }, { name: title, url: route }];
---

<BaseLayout title={`${title} — Tepat Laser`} description={metaDescription} keywords={keyword} url={route} image={heroImage} jsonLd={[generateBreadcrumbSchema(breadcrumbs), generateFAQSchema(faqs)]}>
  <Header slot="header" />
  <main class="application-page overflow-hidden">
    <div class="pt-[4.8rem]"><Breadcrumbs crumbs={breadcrumbs} /></div>
    <section class="application-hero">
      <div class="container-custom application-hero-grid">
        <div class="application-copy">
          <span class="eyebrow">{eyebrow}</span>
          <h1 class="heading-xl mt-7"><span>{title}</span> <em>{accent}</em></h1>
          <p class="mt-7 max-w-xl text-lg leading-8">{description}</p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a href={whatsapp} target="_blank" rel="noopener noreferrer" class="btn-primary" data-wa-label={`${title} hero`}>Konsultasikan proyek <span>↗</span></a>
            <a href="#aplikasi" class="btn-secondary">Lihat aplikasinya <span>↓</span></a>
          </div>
        </div>
        <figure class="application-visual media-frame">
          <img src={heroImage} alt={heroAlt} width="1600" height="1000" fetchpriority="high" decoding="async" />
          <figcaption><span>Custom fabrication</span><span>Tangerang Selatan</span></figcaption>
        </figure>
      </div>
    </section>

    <section class="kinetic-line" aria-label={`Alur ${title}`}><div class="kinetic-track"><span>{title}</span><span>Review ukuran</span><span>Pilih material</span><span>Produksi</span><span>Finishing & QC</span><span>{title}</span><span>Review ukuran</span><span>Pilih material</span><span>Produksi</span><span>Finishing & QC</span></div></section>

    <section class="dark-section section-padding">
      <div class="container-custom">
        <div class="section-heading"><div><span class="eyebrow">Yang diperhatikan</span><h2 class="heading-lg mt-6">Tampilan menarik saja tidak cukup. Desainnya juga harus siap diproduksi.</h2></div><p>Ukuran bidang, kepadatan pola, struktur, material, sambungan, dan finishing dibaca sebagai satu sistem sebelum file masuk mesin.</p></div>
        <div class="benefit-grid accent-cycle">{benefits.map((item,index) => <article><span class="number-tag">0{index+1}</span><h3>{item.title}</h3><p>{item.description}</p></article>)}</div>
      </div>
    </section>

    <section class="section-padding" id="aplikasi">
      <div class="container-custom">
        <span class="eyebrow">Pilihan aplikasi</span>
        <h2 class="heading-lg mt-6 max-w-4xl">Lihat bagaimana skala, pola, dan material mengubah karakter bidang.</h2>
        <div class="application-gallery">{gallery.map((item,index) => <figure class:list={[index===0&&'gallery-wide']}><img src={item.image} alt={item.alt} width="1200" height="900" loading="lazy" decoding="async" /><figcaption><span>{item.label}</span><h3>{item.title}</h3></figcaption></figure>)}</div>
      </div>
    </section>

    <section class="application-fit section-padding">
      <div class="container-custom">
        <div class="section-heading"><div><span class="eyebrow text-amber-800">Keputusan fungsi</span><h2 class="heading-md mt-5 text-slate-950">Tidak semua bidang membutuhkan solusi yang sama.</h2></div><p>Gunakan dua kolom ini untuk menguji apakah kebutuhan sudah siap diarahkan ke desain produksi atau masih memerlukan data lapangan dan keputusan struktur.</p></div>
        <div class="application-fit-grid">
          <article><h3><span>✓</span> Cocok ketika</h3><ul>{fit.map((item) => <li>{item}</li>)}</ul></article>
          <article><h3><span>→</span> Perlu ditinjau ulang bila</h3><ul>{notFit.map((item) => <li>{item}</li>)}</ul></article>
        </div>
      </div>
    </section>

    <section class="warm-section section-padding">
      <div class="container-custom">
        <div class="section-heading"><div><span class="eyebrow">Alur kerja</span><h2 class="heading-lg mt-6">Setiap keputusan terlihat. Tidak ada produksi berdasarkan tebakan.</h2></div><p>Material, konstruksi, biaya, dan waktu dikunci bertahap supaya koreksi tidak menumpuk setelah proses berjalan.</p></div>
        <div class="step-grid">{steps.map((item,index) => <article><span>0{index+1}</span><h3>{item.title}</h3><p>{item.description}</p></article>)}</div>
      </div>
    </section>

    <section class="application-commercial section-padding">
      <div class="container-custom application-commercial-grid">
        <div>
          <span class="eyebrow text-amber-400">Logika penawaran</span>
          <h2 class="heading-md mt-5 text-white">Harga mengikuti keputusan desain, material, struktur, dan scope akhir.</h2>
          <p class="mt-5">Luas bidang saja tidak cukup untuk menghitung pekerjaan custom. Kepadatan pola, pembagian panel, rangka, finishing, akses pengiriman, dan pemasangan dapat mengubah kebutuhan secara signifikan.</p>
        </div>
        <ol>{priceFactors.map((item,index) => <li><span>0{index+1}</span><p>{item}</p></li>)}</ol>
      </div>
    </section>

    <section class="section-padding bg-white">
      <div class="container-custom application-quality">
        <div><span class="eyebrow text-amber-800">Sebelum serah terima</span><h2 class="heading-md mt-5 text-slate-950">Kualitas diperiksa pada hal yang memengaruhi pemasangan.</h2><p class="mt-5">Kriteria visual dan teknis dibicarakan sesuai fungsi bidang. Tujuannya bukan menjanjikan kesempurnaan abstrak, tetapi memastikan hasil siap melanjutkan ke tahap berikutnya.</p></div>
        <ul>{qualityChecks.map((item,index) => <li><span>{String(index+1).padStart(2,'0')}</span><p>{item}</p></li>)}</ul>
      </div>
    </section>

    <section class="section-padding">
      <div class="container-custom faq-layout">
        <div><span class="eyebrow">Pertanyaan umum</span><h2 class="heading-lg mt-6">Tanyakan sekarang, bukan setelah material terpotong.</h2></div>
        <div class="faq-list">{faqs.map((item,index) => <details open={index===0}><summary>{item.question}<span>＋</span></summary><p>{item.answer}</p></details>)}</div>
      </div>
    </section>
    <CTA title={ctaTitle} description="Kirim ukuran, foto bidang, dan referensi pola. Kami bantu mengubahnya menjadi keputusan material, struktur, dan proses yang bisa dipertanggungjawabkan." primaryText="Kirim brief via WhatsApp" primaryHref={whatsapp} secondaryText="Lihat semua layanan" secondaryLink="/services/" />
  </main>
  <Footer slot="footer" />
</BaseLayout>

<style>
  .application-hero{background:radial-gradient(circle at 78% 25%,rgba(54,114,172,.16),transparent 26rem),radial-gradient(circle at 14% 84%,rgba(234,49,79,.09),transparent 24rem),var(--surface)}
  .application-hero-grid{display:grid;min-height:calc(100svh - 4.8rem);align-items:stretch}
  .application-copy{display:flex;flex-direction:column;justify-content:center;padding-block:clamp(4.5rem,8vw,7rem)}
  .application-copy h1 span,.application-copy h1 em{display:block}
  .application-copy h1 em{color:transparent;background:var(--brand-spectrum);background-clip:text;-webkit-background-clip:text;-webkit-text-fill-color:transparent;font-style:normal}
  .application-visual{min-height:32rem}.application-visual img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}.application-visual figcaption{position:absolute;z-index:2;right:1.25rem;bottom:1.25rem;left:1.25rem;display:flex;justify-content:space-between;color:#fff;font-size:.75rem;font-weight:800;letter-spacing:.09em;text-transform:uppercase}
  .section-heading{display:grid;gap:2rem;align-items:end}.section-heading>p{max-width:34rem;font-size:1rem;line-height:1.8}
  .benefit-grid,.step-grid{display:grid;gap:1px;margin-top:3.5rem;background:rgba(255,255,255,.14)}.benefit-grid article{background:#09100d;padding:1.5rem}.benefit-grid h3,.step-grid h3{margin-top:2.5rem;font-size:1.5rem}.benefit-grid p,.step-grid p{margin-top:.8rem;font-size:.92rem;line-height:1.7}
  .application-gallery{display:grid;gap:1rem;margin-top:3rem}.application-gallery figure{position:relative;min-height:27rem;overflow:hidden;background:#050906}.application-gallery img{position:absolute;width:100%;height:100%;object-fit:cover;transition:transform .7s var(--ease-smooth)}.application-gallery figure:hover img{transform:scale(1.045)}.application-gallery figure::after{position:absolute;inset:0;content:'';background:linear-gradient(to top,rgba(5,9,6,.86),transparent 62%)}.application-gallery figcaption{position:absolute;z-index:1;right:1.25rem;bottom:1.25rem;left:1.25rem}.application-gallery figcaption span{color:var(--laser);font-size:.75rem;font-weight:800;letter-spacing:.11em;text-transform:uppercase}.application-gallery h3{margin-top:.45rem;color:#fff;font-size:1.7rem}
  .step-grid{border:1px solid var(--line);background:var(--line)}.step-grid article{background:var(--surface);padding:1.4rem}.step-grid>article>span{color:var(--laser-deep);font-size:.75rem;font-weight:800}.step-grid p{color:var(--muted)}
  .application-fit{background:#fffbeb;color:#0f172a}.application-fit .section-heading>p{color:#475569}
  .application-fit-grid{display:grid;gap:1rem;margin-top:3rem}.application-fit-grid article{border:1px solid #d6c8aa;background:#fff;padding:1.5rem}.application-fit-grid h3{display:flex;align-items:center;gap:.75rem;color:#0f172a;font-size:1.25rem}.application-fit-grid h3 span{display:grid;width:2rem;height:2rem;place-items:center;border-radius:50%;background:#0f172a;color:#fff}.application-fit-grid ul{display:grid;gap:.65rem;margin:1.5rem 0 0;padding:0;list-style:none}.application-fit-grid li{position:relative;padding-left:1rem;color:#334155;line-height:1.65}.application-fit-grid li::before{position:absolute;top:.7rem;left:0;width:.3rem;height:.3rem;border-radius:50%;background:#9a6c14;content:''}
  .application-commercial{background:#020617;color:#fff}.application-commercial-grid{display:grid;gap:3rem}.application-commercial-grid>div>p{max-width:38rem;color:#cbd5e1;line-height:1.8}.application-commercial ol{margin:0;padding:0;border-top:1px solid #334155;list-style:none}.application-commercial li{display:grid;grid-template-columns:3rem 1fr;gap:1rem;border-bottom:1px solid #334155;padding:1.15rem 0}.application-commercial li span{color:#edcf79;font-size:.75rem;font-weight:850}.application-commercial li p{color:#f8fafc;font-weight:700}
  .application-quality{display:grid;gap:3rem}.application-quality>div>p{max-width:38rem;color:#475569;line-height:1.8}.application-quality ul{margin:0;padding:0;border:1px solid #cbd5e1;list-style:none}.application-quality li{display:grid;grid-template-columns:3rem 1fr;gap:1rem;padding:1.15rem}.application-quality li+li{border-top:1px solid #cbd5e1}.application-quality li span{color:#76520e;font-size:.75rem;font-weight:850}.application-quality li p{color:#334155;font-weight:700;line-height:1.65}
  .faq-layout{display:grid;gap:3rem}.faq-list details{border-top:1px solid var(--line);padding:1.2rem 0}.faq-list details:last-child{border-bottom:1px solid var(--line)}.faq-list summary{display:flex;cursor:pointer;list-style:none;justify-content:space-between;gap:1rem;font-family:'Clash Display',sans-serif;font-size:1.15rem;font-weight:600}.faq-list summary::-webkit-details-marker{display:none}.faq-list summary span{color:var(--laser-deep);font-family:Arial,sans-serif}.faq-list p{max-width:44rem;margin-top:.9rem;line-height:1.75}
  @media(min-width:760px){.benefit-grid{grid-template-columns:repeat(3,minmax(0,1fr))}.step-grid{grid-template-columns:repeat(4,minmax(0,1fr))}.application-gallery{grid-template-columns:1.15fr .85fr}.gallery-wide{grid-row:span 2}.application-fit-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.application-commercial-grid,.application-quality{grid-template-columns:.8fr 1.2fr}.faq-layout{grid-template-columns:.8fr 1.2fr}}
  @media(min-width:1000px){.application-hero-grid{grid-template-columns:1fr .9fr;gap:3rem}.application-copy{padding-right:2rem}.application-visual{margin-block:2rem}.section-heading{grid-template-columns:1.1fr .9fr}}
  @media(max-width:640px){.application-hero-grid{min-height:auto}.application-copy{padding-block:3rem}.application-visual{min-height:27rem}.application-gallery figure{min-height:22rem}}
</style>
