---
import '../styles/global.css';

export interface Props {
  title?: string; description?: string; keywords?: string; image?: string; url?: string; type?: string;
  noindex?: boolean; jsonLd?: any[]; canonical?: string; metaTags?: any; publishedTime?: string; modifiedTime?: string; author?: string;
}

const props = Astro.props;
const siteUrl = new URL(Astro.site || 'https://tepatlaser.com');
const generated = props.metaTags || {};
const pageTitle = props.title || generated.title || 'Tepat Laser — Precision Fabrication';
const pageDescription = props.description || generated.description || 'Laser cutting, CNC router, fiber laser, CO2, dan galvo engraving untuk kebutuhan industri, arsitektur, interior, signage, dan custom.';
const pageKeywords = props.keywords || generated.keywords || 'jasa laser cutting, laser cutting Tangerang Selatan, CNC router, laser fiber, laser CO2';
const pageUrl = new URL(props.url || generated.url || Astro.url.pathname, siteUrl).href;
const canonicalUrl = new URL(props.canonical || generated.canonical || pageUrl, siteUrl).href;
const imageUrl = new URL(props.image || generated.openGraph?.image || '/images/logo.webp', siteUrl).href;
const ogTitle = generated.openGraph?.title || pageTitle;
const ogDescription = generated.openGraph?.description || pageDescription;
const jsonLd = props.jsonLd || [];
---

<!doctype html>
<html lang="id" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#080b0a" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content={pageKeywords} />
    <meta name="author" content={props.author || generated.author || 'Tim Teknis Tepat Laser'} />
    <meta name="robots" content={props.noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large'} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico?v=3" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />
    <meta property="og:type" content={generated.openGraph?.type || props.type || 'website'} />
    <meta property="og:title" content={ogTitle} /><meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={pageUrl} /><meta property="og:image" content={imageUrl} /><meta property="og:site_name" content="Tepat Laser" /><meta property="og:locale" content="id_ID" />
    <meta name="twitter:card" content="summary_large_image" /><meta name="twitter:title" content={ogTitle} /><meta name="twitter:description" content={ogDescription} /><meta name="twitter:image" content={imageUrl} />
    {props.publishedTime && <meta property="article:published_time" content={props.publishedTime} />}
    {props.modifiedTime && <meta property="article:modified_time" content={props.modifiedTime} />}
    {jsonLd.map((schema) => <script type="application/ld+json" set:html={JSON.stringify(schema)} />)}
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-LWLLCS1PG4"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){window.dataLayer.push(arguments)}
      gtag('js', new Date()); gtag('config', 'G-LWLLCS1PG4');
    </script>
  </head>
  <body class="antialiased">
    <a class="skip-link" href="#main-content">Lewati ke konten utama</a>
    <div class="pointer-events-none fixed inset-x-0 top-0 z-[80] h-px origin-left scale-x-0 bg-[var(--acid)]" id="scroll-progress"></div>
    <div class="cursor-dot" id="cursor-dot"></div><div class="cursor-ring" id="cursor-ring"></div>
    <slot name="header" />
    <main id="main-content" class="site-shell min-h-screen"><slot /></main>
    <slot name="footer" />
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const progress = document.querySelector('#scroll-progress');
        const updateProgress = () => { const max = document.documentElement.scrollHeight - window.innerHeight; if (progress) progress.style.transform = `scaleX(${max > 0 ? window.scrollY / max : 0})`; };
        window.addEventListener('scroll', updateProgress, { passive: true }); updateProgress();
        document.querySelectorAll('#main-content section').forEach((section) => { if (!section.closest('.home-page') && !section.hasAttribute('data-no-reveal')) section.classList.add('reveal'); });
        const reveal = new IntersectionObserver((entries) => entries.forEach((entry) => entry.isIntersecting && (entry.target.classList.add('is-visible'), reveal.unobserve(entry.target))), { threshold: .12 });
        document.querySelectorAll('.reveal, [data-reveal]').forEach((element) => reveal.observe(element));
        const dot = document.querySelector('#cursor-dot'); const ring = document.querySelector('#cursor-ring');
        if (window.matchMedia('(pointer:fine)').matches && dot && ring) {
          document.body.classList.add('has-pointer');
          window.addEventListener('pointermove', (event) => { dot.style.left = `${event.clientX}px`; dot.style.top = `${event.clientY}px`; ring.style.left = `${event.clientX}px`; ring.style.top = `${event.clientY}px`; }, { passive: true });
          document.querySelectorAll('a, button, input, select, textarea, summary').forEach((el) => { el.addEventListener('pointerenter', () => document.body.classList.add('cursor-hover')); el.addEventListener('pointerleave', () => document.body.classList.remove('cursor-hover')); });
        }
        document.querySelectorAll('a[href*="api.whatsapp.com"], a[href*="wa.me"]').forEach((link) => link.addEventListener('click', () => { if (typeof window.gtag === 'function') window.gtag('event', 'whatsapp_click', { event_category: 'engagement', event_label: link.dataset.waLabel || link.textContent?.trim() || 'WhatsApp Button', page_path: window.location.pathname }); }));
      });
    </script>
  </body>
</html>
