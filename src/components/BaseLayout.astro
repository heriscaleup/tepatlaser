---
import '../styles/global.css';

export interface Props {
  title?: string; description?: string; keywords?: string; image?: string; url?: string; type?: string;
  noindex?: boolean; jsonLd?: any[]; canonical?: string; metaTags?: any; publishedTime?: string; modifiedTime?: string; author?: string;
}

const props = Astro.props;
const siteUrl = new URL(Astro.site || 'https://tepatlaser.com');
const generated = props.metaTags || {};
const pageTitle = props.title || generated.title || 'Tepat Laser — Precision Fabrication';
const pageDescription = props.description || generated.description || 'Laser cutting, CNC router, fiber laser, CO2, dan galvo engraving untuk kebutuhan industri, arsitektur, interior, signage, dan custom. Workshop Tangerang Selatan.';
const pageKeywords = props.keywords || generated.keywords || 'jasa laser cutting, laser cutting Tangerang Selatan, CNC router, laser fiber, laser CO2';
const pageUrl = new URL(props.url || generated.url || Astro.url.pathname, siteUrl).href;
const canonicalUrl = new URL(props.canonical || generated.canonical || pageUrl, siteUrl).href;
const imageUrl = new URL(props.image || generated.openGraph?.image || '/gambar/pagar-laser-cutting-landing/hero-pagar-laser-cutting.webp', siteUrl).href;
const ogTitle = generated.openGraph?.title || pageTitle;
const ogDescription = generated.openGraph?.description || pageDescription;
const jsonLd = props.jsonLd || [];
const heroPreload = props.image || generated.openGraph?.image || (Astro.url.pathname === '/' ? '/images/v10/home-fiber-workshop-real.webp' : '');
---

<!doctype html>
<html lang="id" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0b0d0e" />
    <meta name="tepat-release" content="v10-2026-07-24" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content={pageKeywords} />
    <meta name="author" content={props.author || generated.author || 'Tim Teknis Tepat Laser'} />
    <meta name="robots" content={props.noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large'} />
    <meta name="googlebot" content={props.noindex ? 'noindex, nofollow' : 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1'} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico?v=7" />
    <link rel="manifest" href="/manifest.json" />
    {heroPreload && <link rel="preload" href={heroPreload} as="image" type="image/webp" fetchpriority="high" />}
    <link rel="dns-prefetch" href="//api.whatsapp.com" />
    <link rel="dns-prefetch" href="//www.googletagmanager.com" />
    <meta property="og:type" content={generated.openGraph?.type || props.type || 'website'} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Tepat Laser" />
    <meta property="og:locale" content="id_ID" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={imageUrl} />
    {props.publishedTime && <meta property="article:published_time" content={props.publishedTime} />}
    {props.modifiedTime && <meta property="article:modified_time" content={props.modifiedTime} />}
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'LocalBusiness',
      '@id': `${siteUrl.href}#business`,
      name: 'Tepat Laser',
      url: siteUrl.href,
      description: pageDescription,
      telephone: '+6282121292937',
      email: 'info@tepatlaser.com',
      image: imageUrl,
      priceRange: 'Rp',
      address: { '@type': 'PostalAddress', streetAddress: 'Jl. Bintaro BSD No. 1 D', addressLocality: 'Tangerang Selatan', addressRegion: 'Banten', addressCountry: 'ID' },
      geo: { '@type': 'GeoCoordinates', latitude: '-6.2765', longitude: '106.7196' },
      areaServed: ['Tangerang Selatan', 'Jakarta Selatan', 'Depok', 'Tangerang', 'Bogor', 'Bekasi', 'Jabodetabek'],
      openingHoursSpecification: [
        { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'], opens: '09:00', closes: '18:00' }
      ],
      sameAs: [
        'https://www.instagram.com/jasalasercutting.tangsel/',
        'https://www.facebook.com/profile.php?id=100054220779104',
        'https://www.youtube.com/@heriasari4189'
      ]
    })} />
    {jsonLd.map((schema) => <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />)}
    <!-- Marketing tags: antri di dataLayer, load JS SETELAH LCP atau interaksi user -->
    <script is:inline>
      (function(w,d){
        w.dataLayer = w.dataLayer || [];
        w.gtag = w.gtag || function(){ w.dataLayer.push(arguments); };
        w.gtag('js', new Date());
        w.gtag('config', 'AW-11545092315');

        var loaded = false;
        var loadMarketingTags = function(){
          if (loaded) return;
          loaded = true;

          var gtagScript = d.createElement('script');
          gtagScript.async = true;
          gtagScript.src = 'https://www.googletagmanager.com/gtag/js?id=AW-11545092315';
          d.head.appendChild(gtagScript);

          w.dataLayer.push({'gtm.start': new Date().getTime(), event: 'gtm.js'});
          var gtmScript = d.createElement('script');
          gtmScript.async = true;
          gtmScript.src = 'https://www.googletagmanager.com/gtm.js?id=GTM-PBR27KH7';
          d.head.appendChild(gtmScript);
        };

        ['pointerdown','keydown','touchstart','scroll'].forEach(function(eventName){
          w.addEventListener(eventName, loadMarketingTags, { once: true, passive: true });
        });

        try {
          var lcpObserver = new PerformanceObserver(function() {
            lcpObserver.disconnect();
            setTimeout(loadMarketingTags, 300);
          });
          lcpObserver.observe({ type: 'largest-contentful-paint', buffered: true });
        } catch(e) {}

        w.addEventListener('load', function(){ setTimeout(loadMarketingTags, 5000); }, { once: true });
      })(window,document);
    </script>
  </head>
  <body class="antialiased">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-PBR27KH7"
    title="Google Tag Manager" height="0" width="0" style="display:none;visibility:hidden" referrerpolicy="no-referrer-when-downgrade"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <a class="skip-link" href="#main-content">Lewati ke konten utama</a>

    <slot name="header" />
    <div id="main-content" class="site-shell min-h-screen"><slot /></div>
    <slot name="footer" />

    <script is:inline>
      const initBase = () => {
        const release = 'v10-2026-07-24';
        if (localStorage.getItem('tepat-release') !== release) {
          navigator.serviceWorker?.getRegistrations?.().then((items) => items.forEach((item) => item.unregister()));
          window.caches?.keys?.().then((keys) => Promise.all(keys.map((key) => window.caches.delete(key))));
          localStorage.setItem('tepat-release', release);
        }

        // WhatsApp tracking
        document.querySelectorAll('a[href*="api.whatsapp.com"], a[href*="wa.me"]').forEach((link) => link.addEventListener('click', () => {
          window.dispatchEvent(new CustomEvent('tepat:whatsapp-click', { detail: { label: link.dataset.waLabel || link.textContent?.trim() || 'WhatsApp Button', path: window.location.pathname } }));
        }));

        // Progressive reveal: compositor-only and disabled for reduced motion.
        const revealTargets = [...document.querySelectorAll('main > section, main > article > section, main > article + section')].slice(1);
        if ('IntersectionObserver' in window && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          const observer = new IntersectionObserver((entries) => entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-inview');
              entry.target.querySelectorAll('.text-reveal, .img-reveal').forEach((el) => el.classList.add('is-inview'));
              observer.unobserve(entry.target);
            }
          }), { rootMargin: '0px 0px -5% 0px', threshold: .04 });
          revealTargets.forEach((section) => {
            section.classList.add('motion-section');
            observer.observe(section);
          });
        } else {
          revealTargets.forEach((section) => {
            section.classList.add('is-inview');
            section.querySelectorAll('.text-reveal, .img-reveal').forEach((el) => el.classList.add('is-inview'));
          });
        }
      };
      document.readyState === 'loading' ? document.addEventListener('DOMContentLoaded', initBase, { once: true }) : initBase();
    </script>
    <!-- WA Tracker: GCLID attribution untuk semua tombol WhatsApp -->
    <script is:inline src="/wa-tracker.js" defer></script>
  </body>
</html>
