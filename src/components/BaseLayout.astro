---
// BaseLayout.astro - Layout utama untuk semua halaman (FIXED & LENGKAP)
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

export interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  image?: string;
  url?: string;
  type?: string;
  noindex?: boolean;
  jsonLd?: any;
}

const {
  title,
  description = "Solusi laser cutting profesional dengan teknologi terdepan. 7 tahun pengalaman, 1000+ proyek selesai, garansi kualitas premium. Melayani CNC Router, Laser Fiber, Laser CO2, dan Galvo Engraving.",
  keywords = "jasa laser cutting, laser cutting jakarta, laser cutting tangerang, laser cutting stainless, cnc router, laser fiber, bintaro, tangerang selatan, serpong",
  image = "logo.webp",
  url,
  type = "website",
  noindex = false,
  jsonLd
} = Astro.props;

// KRITICAL: Menggunakan Astro.site dan memastikan nilainya ada
if (!Astro.site) {
  throw new Error('SITE_URL environment variable is not set. Please update your astro.config.mjs');
}
const siteUrl = Astro.site; 
const siteName = "Tepat Laser";

const defaultTitle = "Jasa Laser Cutting Jakarta & Tangerang Terpercaya | Tepat Laser";
const fullTitle = title ? `${title} | ${siteName}` : defaultTitle;
// Cara paling benar membuat URL, anti error path ganda
const fullUrl = new URL(url || Astro.url.pathname, siteUrl);
const fullImage = new URL(image, siteUrl);
---

<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE-edge" />
  
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content={keywords} />
  <meta name="author" content="Tepat Laser Team" />
  <link rel="canonical" href={fullUrl.href} />
  
  {noindex ? (
    <meta name="robots" content="noindex, nofollow" />
  ) : (
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
  )}
  
  <meta property="og:type" content={type} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={fullUrl.href} />
  <meta property="og:image" content={fullImage.href} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:locale" content="id_ID" />
  
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={fullImage.href} />
  
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" href="/images/logo.webp" />
  
  <link rel="preload" href="/images/logo.webp" as="image" type="image/webp" />
  <link rel="preload" href="https://fonts.gstatic.com/s/inter/v12/UcCO3FwrK3iLTeHuS_fvQtMwCp50KnMw2boKoduKmMEVuLyfAZ9hiA.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="https://fonts.gstatic.com/s/inter/v12/UcCO3FwrK3iLTeHuS_fvQtMwCp50KnMw2boKoduKmMEVuGKYAZ9hiA.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="https://fonts.gstatic.com/s/inter/v12/UcCO3FwrK3iLTeHuS_fvQtMwCp50KnMw2boKoduKmMEVuFuYAZ9hiA.woff2" as="font" type="font/woff2" crossorigin />
  
  <link rel="dns-prefetch" href="//fonts.gstatic.com" />
  <link rel="dns-prefetch" href="//api.whatsapp.com" />

  <!-- Google Tag Manager -->
<script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-PBR27KH7');</script>
<!-- End Google Tag Manager -->

  {jsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  )}
  
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Tepat Laser",
    "url": siteUrl.href,
    "logo": new URL('logo-company.webp', siteUrl).href,
    "description": "Jasa laser cutting profesional — stainless steel, plat besi, aluminium, akrilik — di Bintaro, Tangerang Selatan. Toleransi ±0.02mm, express 4 jam.",
    "telephone": "+62 821-2129-2937",
    "email": "info@tepatlaser.com",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Jl. Bintaro BSD No 1D",
      "addressLocality": "Tangerang Selatan",
      "addressRegion": "Banten",
      "postalCode": "15413",
      "addressCountry": "ID"
    },
    "openingHours": "Mo-Sa 08:00-17:00",
    "areaServed": [ "Jakarta", "Tangerang", "Tangerang Selatan", "Depok", "Bekasi", "Bogor", "Serpong", "Bintaro" ],
    "serviceType": [ "Laser Cutting Stainless Steel", "Laser Cutting Metal", "CNC Router", "Laser Fiber", "Laser CO2", "Galvo Engraving" ]
  })} />
  
  <meta name="theme-color" content="#0066FF" />

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=AW-11545092315"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'AW-11545092315');
    gtag('config', 'G-1B48ZVLKET');

    // Memicu pageview ulang saat navigasi SPA (ClientRouter) Astro
    document.addEventListener('astro:page-load', () => {
      gtag('event', 'page_view', {
        page_path: window.location.pathname,
        page_location: window.location.href,
        send_to: ['AW-11545092315', 'G-1B48ZVLKET']
      });
    });
  </script>

  <ClientRouter />
</head>

<body class="antialiased bg-white text-gray-900">
  <!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-PBR27KH7"
title="Google Tag Manager" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-blue-600 text-white px-4 py-2 rounded-md z-50">
    Skip to main content
  </a>
  
  <slot name="header" />
  
  <main id="main-content" class="min-h-screen">
    <slot />
  </main>
  
  <slot name="footer" />

  <script>
    import { initializeEnhancedConversionTracking } from '../utils/tracking.js';
    initializeEnhancedConversionTracking();
  </script>

  <!-- WA Tracker: GCLID attribution untuk semua tombol WhatsApp -->
  <script is:inline src="/wa-tracker.js" defer></script>

  <div class="fixed bottom-6 right-6 z-50">
    <a 
      href="https://api.whatsapp.com/send?phone=6282121292937&text=Halo,%20saya%20tertarik%20dengan%20jasa%20laser%20cutting.%20Bisa%20konsultasi?"
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center justify-center w-14 h-14 bg-green-500 hover:bg-green-600 text-white rounded-full shadow-lg hover:shadow-xl transition-all duration-300 transform hover:scale-110"
      aria-label="Chat via WhatsApp"
      data-gtm-id="whatsapp-click"
    >
      <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/></svg>
    </a>
  </div>
</body>
</html>