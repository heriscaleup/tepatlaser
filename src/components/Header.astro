---
import { SITE_CONFIG, SERVICES, MATERIALS } from '../utils/constants.js';

const path = Astro.url.pathname;
const isActive = (href: string) => href === '/' ? path === '/' : path.startsWith(href);
const wa = `https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent('Halo Tepat Laser, saya ingin konsultasi proyek dan mengirimkan brief.')}`;
---

<header class="fixed inset-x-0 top-0 z-50 glass-header" id="main-header">
  <div class="container-custom flex h-[4.8rem] items-center justify-between gap-5">
    <a href="/" class="brand-lockup" aria-label="Tepat Laser, kembali ke beranda">
      <img class="brand-logo" src="/images/logo-transparent.webp" alt="Tepat Laser — Laser Cutting" width="1200" height="594" decoding="async" />
    </a>

    <nav class="desktop-nav hidden items-center gap-7 lg:flex" aria-label="Navigasi utama">
      <a href="/" class:list={["nav-link", isActive('/') && "is-active"]}>Beranda</a>
      <a href="/about/" class:list={["nav-link", isActive('/about/') && "is-active"]}>Tentang</a>
      <details class="nav-mega" data-nav-dropdown>
        <summary class:list={["nav-link cursor-pointer list-none", (isActive('/jasa-') || isActive('/laser-')) && "is-active"]}>
          Layanan <span aria-hidden="true">⌄</span>
        </summary>
        <div class="mega-panel">
          <div>
            <p class="mega-label">Proses produksi</p>
            <div class="mega-service-list">
              {SERVICES.map((item) => <a href={`/${item.slug}/`}><span>{item.name}</span><small>{item.applications.slice(0,2).join(' · ')}</small></a>)}
            </div>
          </div>
          <div>
            <p class="mega-label">Material populer</p>
            <div class="mega-material-list">
              {MATERIALS.map((item) => <a href={`/${item.slug}/`}><span>{item.name}</span><small>{item.thickness}</small></a>)}
            </div>
          </div>
          <a href="/services/" class="mega-all">Lihat semua kapabilitas <span>↗</span></a>
        </div>
      </details>
      <a href="/portfolio/" class:list={["nav-link", isActive('/portfolio/') && "is-active"]}>Portofolio</a>
      <a href="/blog/" class:list={["nav-link", isActive('/blog/') && "is-active"]}>Wawasan</a>
    </nav>

    <div class="desktop-cta hidden lg:block">
      <a href={wa} target="_blank" rel="noopener noreferrer" class="btn-primary min-h-10 px-5 py-2 text-sm" data-wa-label="Header WhatsApp">Kirim brief <span>↗</span></a>
    </div>

    <button id="mobile-menu-button" class="mobile-toggle lg:hidden" aria-expanded="false" aria-controls="mobile-menu" aria-label="Buka menu navigasi">
      <span></span><span></span>
    </button>
  </div>

  <div id="mobile-menu" class="mobile-panel lg:hidden" aria-hidden="true">
    <nav class="container-custom py-5" aria-label="Navigasi mobile">
      <a href="/">Beranda</a>
      <a href="/about/">Tentang</a>
      <details>
        <summary>Layanan <span>＋</span></summary>
        <div class="mobile-subgrid">
          <a href="/services/">Semua layanan</a>
          {SERVICES.map((item) => <a href={`/${item.slug}/`}>{item.name}</a>)}
          {MATERIALS.map((item) => <a href={`/${item.slug}/`}>{item.name}</a>)}
        </div>
      </details>
      <a href="/portfolio/">Portofolio</a>
      <a href="/blog/">Wawasan</a>
      <a href="/contact/">Kontak</a>
      <a href={wa} target="_blank" rel="noopener noreferrer" class="btn-primary mt-5" data-wa-label="Mobile WhatsApp">Kirim brief via WhatsApp <span>↗</span></a>
    </nav>
  </div>
</header>

<script is:inline>
  const initHeader = () => {
    const header = document.querySelector('#main-header');
    const menuButton = document.querySelector('#mobile-menu-button');
    const menu = document.querySelector('#mobile-menu');
    const dropdowns = [...document.querySelectorAll('[data-nav-dropdown]')];

    const setMobile = (open) => {
      menuButton?.setAttribute('aria-expanded', String(open));
      menu?.setAttribute('aria-hidden', String(!open));
      menu?.classList.toggle('is-open', open);
      menuButton?.classList.toggle('is-open', open);
      document.body.style.overflow = open ? 'hidden' : '';
    };
    menuButton?.addEventListener('click', () => setMobile(menuButton.getAttribute('aria-expanded') !== 'true'));
    menu?.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => setMobile(false)));
    dropdowns.forEach((dropdown) => dropdown.addEventListener('toggle', () => {
      if (dropdown.open) dropdowns.forEach((other) => { if (other !== dropdown) other.open = false; });
    }));
    document.addEventListener('click', (event) => {
      if (!event.target.closest('[data-nav-dropdown]')) dropdowns.forEach((item) => item.open = false);
    });
    window.addEventListener('keydown', (event) => { if (event.key === 'Escape') { setMobile(false); dropdowns.forEach((item) => item.open = false); } });

    // Add a restrained shadow after the header leaves the top edge.
    let ticking = false;
    const onScroll = () => {
      header?.classList.toggle('glass-header-scrolled', window.scrollY > 10);
      ticking = false;
    };
    window.addEventListener('scroll', () => { if (!ticking) { ticking = true; requestAnimationFrame(onScroll); } }, { passive: true });
    onScroll();
  };
  document.readyState === 'loading' ? document.addEventListener('DOMContentLoaded', initHeader, { once: true }) : initHeader();
</script>

<style>
  .nav-link{position:relative;display:inline-flex;align-items:center;gap:.35rem;padding:.7rem 0;color:var(--header-muted);font-size:.9rem;font-weight:700;line-height:1;transition:color .2s ease;animation:nav-arrive .7s var(--ease-smooth) both}
  .desktop-nav>.nav-link:nth-child(2),.desktop-nav>details:nth-child(2){animation-delay:.06s}.desktop-nav>.nav-link:nth-child(3),.desktop-nav>details:nth-child(3){animation-delay:.12s}.desktop-nav>.nav-link:nth-child(4){animation-delay:.18s}.desktop-nav>.nav-link:nth-child(5){animation-delay:.24s}
  .nav-link:hover,.nav-link.is-active{color:var(--header-ink)}
  .nav-link.is-active::after{position:absolute;right:0;bottom:.15rem;left:0;height:2px;content:'';background:var(--brand-spectrum)}
  .nav-mega{position:relative}
  .nav-mega summary::-webkit-details-marker{display:none}
  .mega-panel{position:absolute;top:calc(100% + .7rem);left:50%;display:grid;width:min(60rem,calc(100vw - 3rem));grid-template-columns:.8fr 1.45fr;gap:1.5rem;border:1px solid #343837;background:#090c0b;padding:1.5rem;box-shadow:0 1.5rem 5rem rgba(0,0,0,.38);transform:translateX(-50%)}
  .mega-label{margin:0;color:#edcf79!important;font-size:.75rem;font-weight:800;letter-spacing:.11em;text-transform:uppercase}.mega-panel>div:nth-child(2) .mega-label{color:#78b7ef!important}
  .mega-service-list{display:grid;gap:.35rem;margin-top:1rem}
  .mega-material-list{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:.35rem;margin-top:1rem}
  .mega-panel a{display:flex;min-width:0;align-items:flex-start;justify-content:space-between;gap:.8rem;border:1px solid transparent;border-radius:.4rem;padding:.7rem .75rem;color:#f5f7f4!important;transition:background .2s ease,border-color .2s ease}
  .mega-panel a:hover,.mega-panel a:focus-visible{border-color:#39413d;background:#151a17}
  .mega-panel a span{min-width:0;color:#f5f7f4!important;font-size:.88rem;font-weight:750;line-height:1.35}
  .mega-panel a small{flex:none;color:#bdc7c1!important;font-size:.72rem;line-height:1.4;text-align:right;white-space:normal}
  .mega-panel .mega-all{grid-column:1/-1;align-items:center;border:1px solid #edcf79;background:#edcf79;color:#09100d!important;padding:.8rem 1rem;box-shadow:none}
  .mega-panel .mega-all span{color:#09100d!important}
  .mega-panel .mega-all:hover{background:#fff}
  .mobile-toggle{position:relative;width:2.75rem;height:2.75rem;border:1px solid var(--header-line);border-radius:50%;background:var(--paper);color:var(--header-ink)}
  .mobile-toggle span{position:absolute;right:.75rem;left:.75rem;height:1px;background:var(--header-ink);transition:transform .2s ease}
  .mobile-toggle span:first-child{top:1.1rem}.mobile-toggle span:last-child{bottom:1.1rem}
  .mobile-toggle.is-open span:first-child{top:1.35rem;transform:rotate(45deg)}.mobile-toggle.is-open span:last-child{bottom:1.35rem;transform:rotate(-45deg)}
  .mobile-panel{visibility:hidden;position:absolute;z-index:2;top:100%;right:0;left:0;height:calc(100dvh - 4.8rem);overflow:auto;border-top:3px solid transparent;border-image:var(--brand-spectrum) 1;background:var(--canvas);opacity:0;transform:translateY(-.5rem);transition:opacity .2s ease,transform .2s ease,visibility .2s}
  .mobile-panel.is-open{visibility:visible;opacity:1;transform:none}
  .mobile-panel nav>a,.mobile-panel summary{display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--line);padding:1rem 0;font-family:'Clash Display',sans-serif;font-size:1.55rem;font-weight:600;letter-spacing:-.03em}
  .mobile-panel summary{cursor:pointer;list-style:none}.mobile-panel summary::-webkit-details-marker{display:none}
  .mobile-subgrid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:.35rem;padding:.7rem 0 1rem}
  .mobile-subgrid a{border:1px solid var(--line);background:var(--surface);padding:.8rem;font-size:.85rem;font-weight:700}
  .mobile-panel summary span,.mobile-panel .btn-primary span{font-family:Arial,sans-serif;font-weight:400;letter-spacing:0}
  .mobile-panel nav>.btn-primary{justify-content:center;border:0;color:#09100d;font-family:Inter,ui-sans-serif,sans-serif;font-size:.9rem;font-weight:800;letter-spacing:0}
  .brand-logo{width:8.6rem;height:3.45rem;object-fit:contain;object-position:left center}
  @media(max-width:640px){.brand-logo{width:7.6rem;height:3rem}}
  @keyframes nav-arrive{from{opacity:0;transform:translateY(-.7rem)}to{opacity:1;transform:none}}
</style>
