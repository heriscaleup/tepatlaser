---
import { NAVIGATION, SITE_CONFIG } from '../utils/constants.js';

const currentPath = new URL(Astro.request.url).pathname.replace(/\/$/, '') || '/';
const navigation = NAVIGATION.map((item) => ({ ...item, active: item.href === '/' ? currentPath === '/' : item.href.startsWith('#') ? false : currentPath.startsWith(item.href.replace(/\/$/, '')) }));
const whatsapp = `https://api.whatsapp.com/send?phone=${SITE_CONFIG.whatsapp}&text=${encodeURIComponent('Halo Tepat Laser, saya ingin konsultasi project.')}`;
---

<header class="fixed inset-x-0 top-0 z-50 glass-header" id="main-header">
  <div class="container-custom">
    <div class="flex h-[4.75rem] items-center justify-between gap-6 md:h-20" id="header-inner">
      <a href="/" class="group flex min-w-0 items-center gap-3" aria-label="Tepat Laser — beranda">
        <img src="/images/logo.webp" alt="Logo Tepat Laser" class="h-11 w-11 shrink-0 object-contain transition-transform duration-300 group-hover:scale-105" width="48" height="48" />
        <span class="hidden min-w-0 sm:block"><span class="block truncate font-heading text-base font-bold tracking-[-.04em] text-[var(--paper)]">Tepat Laser</span><span class="block font-mono text-[.57rem] uppercase tracking-[.18em] text-[var(--muted)]">Precision fabrication</span></span>
      </a>
      <nav class="hidden items-center gap-7 lg:flex" aria-label="Navigasi utama">
        {navigation.map((item) => item.submenu ? (
          <div class="group/nav relative"><button class="flex items-center gap-1 py-3 text-xs font-bold uppercase tracking-[.12em] text-[var(--muted)] transition-colors hover:text-[var(--acid)]" aria-haspopup="true">{item.name}<svg class="h-3.5 w-3.5 transition-transform group-hover/nav:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6" /></svg></button><div class="invisible absolute left-1/2 top-full w-64 -translate-x-1/2 translate-y-2 border border-[var(--line)] bg-[rgba(15,21,18,.96)] p-2 opacity-0 shadow-2xl backdrop-blur-xl transition-all duration-300 group-hover/nav:visible group-hover/nav:translate-y-0 group-hover/nav:opacity-100">{item.submenu.map((subitem) => <a href={subitem.href} class="block border border-transparent px-4 py-3 text-sm font-semibold text-[var(--muted)] transition-colors hover:border-[var(--line)] hover:bg-[var(--panel-2)] hover:text-[var(--acid)]">{subitem.name}</a>)}</div></div>
        ) : (<a href={item.href} class:list={["relative py-3 text-xs font-bold uppercase tracking-[.12em] text-[var(--muted)] transition-colors hover:text-[var(--acid)]", item.active && "text-[var(--acid)]"]}>{item.name}{item.active && <span class="absolute -bottom-0.5 left-0 h-px w-full bg-[var(--acid)]"></span>}</a>))}
      </nav>
      <div class="hidden items-center gap-3 lg:flex"><span class="mr-2 hidden items-center gap-2 font-mono text-[.62rem] uppercase tracking-[.12em] text-[var(--muted)] xl:flex"><span class="h-1.5 w-1.5 animate-pulse rounded-full bg-[var(--acid)]"></span>Online untuk project baru</span><a href={whatsapp} target="_blank" rel="noopener noreferrer" class="btn-primary min-h-10 px-5 py-2 text-xs" data-wa-label="Header consultation">Mulai konsultasi <span aria-hidden="true">↗</span></a></div>
      <button id="mobile-menu-button" class="grid h-11 w-11 place-items-center border border-[var(--line)] bg-[var(--panel)] text-[var(--paper)] lg:hidden" aria-label="Buka menu" aria-expanded="false"><span class="relative block h-4 w-5"><span id="bar1" class="absolute left-0 top-0 h-px w-full bg-current transition-transform"></span><span id="bar2" class="absolute left-0 top-2 h-px w-3/4 bg-current transition-opacity"></span><span id="bar3" class="absolute bottom-0 left-0 h-px w-full bg-current transition-transform"></span></span></button>
    </div>
  </div>
  <div id="mobile-menu" class="invisible fixed inset-0 top-[4.75rem] z-40 translate-x-full overflow-y-auto bg-[rgba(8,11,10,.98)] px-6 pb-10 pt-8 opacity-0 transition-all duration-500 lg:hidden" aria-hidden="true">
    <nav class="flex flex-col" aria-label="Navigasi mobile">
      {navigation.map((item, index) => item.submenu ? (<div class="border-b border-[var(--line)] py-2"><button class="flex w-full items-center justify-between py-4 text-left font-heading text-2xl font-bold text-[var(--paper)]" data-submenu-index={index} aria-expanded="false">{item.name}<span id={`submenu-icon-${index}`} class="text-[var(--acid)] transition-transform">＋</span></button><div id={`submenu-${index}`} class="hidden grid grid-cols-2 gap-2 pb-3">{item.submenu.map((subitem) => <a href={subitem.href} class="border border-[var(--line)] px-3 py-3 text-sm text-[var(--muted)] hover:text-[var(--acid)]">{subitem.name}</a>)}</div></div>) : (<a href={item.href} class:list={["border-b border-[var(--line)] py-5 font-heading text-3xl font-bold text-[var(--paper)]", item.active && "text-[var(--acid)]"]}>{item.name}</a>))}
    </nav>
    <div class="mt-8 grid gap-3 sm:grid-cols-2"><a href={whatsapp} target="_blank" rel="noopener noreferrer" class="btn-primary py-4" data-wa-label="Mobile consultation">Kirim detail project <span aria-hidden="true">↗</span></a><a href={`tel:${SITE_CONFIG.phone}`} class="btn-secondary py-4">{SITE_CONFIG.phone}</a></div>
  </div>
</header>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const header = document.querySelector('#main-header'); const inner = document.querySelector('#header-inner'); const button = document.querySelector('#mobile-menu-button'); const menu = document.querySelector('#mobile-menu'); const bars = [document.querySelector('#bar1'), document.querySelector('#bar2'), document.querySelector('#bar3')]; let open = false;
    const close = () => { open = false; menu?.classList.add('invisible','translate-x-full','opacity-0'); menu?.setAttribute('aria-hidden','true'); button?.setAttribute('aria-expanded','false'); document.body.style.overflow = ''; bars[0]?.classList.remove('translate-y-2','rotate-45'); bars[1]?.classList.remove('opacity-0'); bars[2]?.classList.remove('-translate-y-2','-rotate-45'); };
    button?.addEventListener('click', () => { open ? close() : (open = true, menu?.classList.remove('invisible','translate-x-full','opacity-0'), menu?.setAttribute('aria-hidden','false'), button?.setAttribute('aria-expanded','true'), document.body.style.overflow = 'hidden', bars[0]?.classList.add('translate-y-2','rotate-45'), bars[1]?.classList.add('opacity-0'), bars[2]?.classList.add('-translate-y-2','-rotate-45')); });
    menu?.querySelectorAll('a').forEach((link) => link.addEventListener('click', close));
    menu?.querySelectorAll('[data-submenu-index]').forEach((toggle) => toggle.addEventListener('click', () => { const index = toggle.getAttribute('data-submenu-index'); document.querySelector(`#submenu-${index}`)?.classList.toggle('hidden'); document.querySelector(`#submenu-icon-${index}`)?.classList.toggle('rotate-45'); }));
    window.addEventListener('scroll', () => { const scrolled = window.scrollY > 24; header?.classList.toggle('glass-header-scrolled', scrolled); inner?.classList.toggle('md:h-16', scrolled); inner?.classList.toggle('md:h-20', !scrolled); }, { passive: true });
  });
</script>
