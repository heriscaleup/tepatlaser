---
import { SITE_CONFIG } from '../utils/constants.js';
export interface Props {
  title?: string;
  description?: string;
  primaryText?: string;
  primaryHref?: string;
  secondaryText?: string;
  secondaryLink?: string;
}
const {
  title = 'Siap mulai project berikutnya?',
  description = 'Kirimkan brief, file, atau referensi. Tim teknis kami akan membaca dan memberikan rekomendasi proses serta estimasi biaya.',
  primaryText = 'Konsultasi via WhatsApp',
  primaryHref = `https://api.whatsapp.com/send?phone=${SITE_CONFIG.whatsapp}&text=${encodeURIComponent('Halo Tepat Laser, saya ingin konsultasi proyek.')}`,
  secondaryText = 'Lihat layanan kami',
  secondaryLink = '/services/'
} = Astro.props;
---

<section class="cta-section">
  <div class="container-custom">
    <div class="cta-grid">
      <div class="cta-content">
        <h2 class="heading-md">{title}</h2>
        <p class="cta-desc">{description}</p>
        <div class="cta-actions">
          <a href={primaryHref} target="_blank" rel="noopener noreferrer" class="btn-primary" data-wa-label="CTA WhatsApp" data-magnetic>
            <span class="cta-whatsapp-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2a9.9 9.9 0 0 0-8.3 15.3L2.5 22l4.82-1.25A9.94 9.94 0 1 0 12.04 2Zm0 18.1a8.13 8.13 0 0 1-4.15-1.14l-.3-.18-2.86.75.76-2.78-.2-.29a8.1 8.1 0 1 1 6.75 3.64Zm4.46-6.05c-.24-.12-1.42-.7-1.64-.77-.22-.08-.38-.12-.54.12-.16.24-.62.77-.76.93-.14.16-.28.18-.52.06-.24-.12-1.01-.37-1.92-1.18-.71-.63-1.18-1.4-1.32-1.64-.14-.24-.01-.37.1-.49.1-.1.23-.25.34-.38.11-.13.14-.23.22-.38.07-.16.04-.29-.02-.41-.06-.12-.54-1.3-.74-1.78-.2-.47-.4-.4-.54-.41h-.46c-.16 0-.41.06-.63.29-.22.24-.83.81-.83 1.97s.85 2.28.96 2.44c.12.16 1.67 2.54 4.04 3.56.56.24 1 .38 1.34.49.56.18 1.08.15 1.48.09.45-.07 1.42-.58 1.62-1.14.2-.55.2-1.02.14-1.12-.06-.1-.21-.16-.44-.28Z" /></svg>
            </span>
            {primaryText} <span aria-hidden="true">↗</span>
          </a>
          <a href={secondaryLink} class="btn-secondary" data-magnetic>{secondaryText} <span aria-hidden="true">→</span></a>
        </div>
      </div>
      <div class="cta-proof">
        <div class="proof-item">
          <strong>4</strong>
          <span>Teknologi produksi</span>
        </div>
        <div class="proof-item">
          <strong>122 × 244</strong>
          <span>cm area kerja maksimum</span>
        </div>
        <div class="proof-item">
          <strong>Sen–Sab</strong>
          <span>09.00–18.00 WIB</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section { position: relative; border-top: 1px solid var(--line); background: linear-gradient(180deg, var(--surface) 0%, var(--canvas) 100%); padding-block: clamp(4rem, 8vw, 6rem); overflow: hidden; }
  .cta-section::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 70% 50%, rgba(211,177,93,.06), transparent 60%); pointer-events: none; }
  .cta-grid { display: grid; gap: 3rem; position: relative; z-index: 1; }
  .cta-content { max-width: 52rem; }
  .cta-content h2 { color: var(--ink); }
  .cta-desc { margin-top: 1.25rem; max-width: 42rem; font-size: 1.05rem; line-height: 1.75; color: var(--muted); }
  .cta-actions { margin-top: 2rem; display: flex; flex-wrap: wrap; gap: .75rem; }
  .cta-whatsapp-icon { display: grid; width: 1.8rem; height: 1.8rem; flex: none; place-items: center; border-radius: 50%; background: #07120b; color: #25d366; }
  .cta-whatsapp-icon svg { width: 1.1rem; height: 1.1rem; }
  .cta-proof { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; border-top: 1px solid var(--line); padding-top: 2rem; }
  .proof-item { text-align: center; }
  .proof-item strong { display: block; font-family: 'Clash Display', sans-serif; font-size: 2rem; font-weight: 600; color: var(--brand-gold-soft); letter-spacing: -.03em; }
  .proof-item span { display: block; margin-top: .35rem; font-size: .75rem; font-weight: 650; color: var(--muted); letter-spacing: .07em; text-transform: uppercase; }

  @media (min-width: 900px) {
    .cta-grid { grid-template-columns: 1fr auto; align-items: center; gap: 4rem; }
    .cta-proof { border-top: none; border-left: 1px solid var(--line); padding-top: 0; padding-left: 3rem; }
  }
  @media (max-width: 640px) {
    .cta-proof { grid-template-columns: 1fr; gap: 1rem; }
    .proof-item { display: flex; align-items: center; justify-content: space-between; text-align: left; }
    .proof-item strong { font-size: 1.5rem; }
  }
</style>
