---
import { SITE_CONFIG, WHATSAPP_MESSAGES } from '../utils/constants.js';
export interface Props { title?: string; description?: string; primaryText?: string; primaryLink?: string; secondaryText?: string; secondaryLink?: string; variant?: string; size?: string; }
const { title='Siap wujudkan gagasan desain Anda?', description='Kirim detail material, ukuran, jumlah, dan file desain. Tim teknis Tepat Laser bantu memilih jalur produksi paling efisien.', primaryText='Konsultasi teknis gratis', primaryLink=`https://api.whatsapp.com/send?phone=${SITE_CONFIG.whatsapp}&text=${encodeURIComponent(WHATSAPP_MESSAGES.default)}`, secondaryText='Lihat portfolio', secondaryLink='/portfolio/', variant='default', size='default' } = Astro.props;
---
<section class="relative overflow-hidden border-y border-[var(--line)] bg-[var(--ink-soft)] py-24" data-variant={variant} data-size={size}>
  <div class="pointer-events-none absolute inset-0 opacity-10" style="background-image:radial-gradient(circle at 1.5px 1.5px, #b8ff3d 1.5px, transparent 0);background-size:32px 32px"></div>
  <div class="container-custom relative z-10 max-w-4xl text-center"><span class="eyebrow">Kolaborasi & fabrikasi berkelas</span><h2 class="heading-lg mt-6">{title}</h2><p class="mx-auto mt-6 max-w-2xl text-base leading-8 md:text-lg">{description}</p><div class="mt-9 flex flex-col items-center justify-center gap-4 sm:flex-row"><a href={primaryLink} target="_blank" rel="noopener noreferrer" class="btn-primary w-full sm:w-auto" data-wa-label="CTA consultation">{primaryText} <span aria-hidden="true">↗</span></a><a href={secondaryLink} class="btn-secondary w-full sm:w-auto">{secondaryText} <span aria-hidden="true">↓</span></a></div><div class="mt-10 flex flex-col items-center justify-center gap-4 font-mono text-[.65rem] uppercase tracking-[.12em] text-[var(--muted)] sm:flex-row sm:gap-8"><span>Respon penawaran cepat</span><span>Analisis file awal gratis</span><span>QC sebelum kirim</span></div></div>
</section>
