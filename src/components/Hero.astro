---
import { SITE_CONFIG, WHATSAPP_MESSAGES } from '../utils/constants.js';
export interface Props { title?: string; subtitle?: string; description?: string; primaryCTA?: string; primaryCTALink?: string; secondaryCTA?: string; secondaryCTALink?: string; backgroundImage?: string; showTrustSignals?: boolean; whatsappMessage?: string; }
const { title='Presisi yang terlihat. Hasil yang terasa.', subtitle='Laser cutting untuk project yang tidak boleh meleset.', description='Kami memproses material metal dan non-metal dengan jalur produksi yang jelas, finishing rapi, dan kontrol teknis dari file sampai barang siap dipasang.', primaryCTA='Konsultasi Gratis', primaryCTALink=`https://api.whatsapp.com/send?phone=${SITE_CONFIG.whatsapp}&text=${encodeURIComponent(WHATSAPP_MESSAGES.default)}`, secondaryCTA='Lihat Portfolio', secondaryCTALink='/portfolio/', backgroundImage='/images/metal.webp', whatsappMessage=WHATSAPP_MESSAGES.default } = Astro.props;
---
<section class="service-hero relative isolate overflow-hidden border-b border-[var(--line)] pt-28" data-whatsapp-message={whatsappMessage} data-no-reveal>
  <img src={backgroundImage} alt="" aria-hidden="true" class="absolute inset-0 -z-20 h-full w-full object-cover object-center" width="1920" height="1080" fetchpriority="high" />
  <div class="absolute inset-0 -z-10 bg-[linear-gradient(90deg,rgba(8,11,10,.98)_0%,rgba(8,11,10,.88)_42%,rgba(8,11,10,.45)_75%,rgba(8,11,10,.72)_100%)]"></div>
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_75%_38%,rgba(110,168,221,.18),transparent_26rem)]"></div>
  <div class="absolute inset-0 -z-10 opacity-20 [background-image:linear-gradient(rgba(255,255,255,.08)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,.08)_1px,transparent_1px)] [background-size:5rem_5rem] [mask-image:linear-gradient(to_bottom,black,transparent)]"></div>

  <!-- Floating particles/dust effect -->
  <div class="absolute inset-0 -z-10 pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="particle particle-1"></div>
    <div class="particle particle-2"></div>
    <div class="particle particle-3"></div>
    <div class="particle particle-4"></div>
    <div class="particle particle-5"></div>
  </div>

  <div class="container-custom grid min-h-[min(780px,calc(100svh-5rem))] items-end gap-12 pb-12 md:pb-16 lg:grid-cols-[minmax(0,1fr)_minmax(18rem,.46fr)] lg:gap-20">
    <div class="max-w-4xl">
      <div class="mb-7 inline-flex items-center gap-3 border border-[var(--acid)]/35 bg-[rgba(211,177,93,.10)] px-4 py-2 font-mono text-[.62rem] font-bold uppercase tracking-[.16em] text-[var(--acid)]">
        <span class="h-2 w-2 animate-pulse rounded-full bg-[var(--acid)]"></span>
        TL / Production capability
      </div>

      <div class="text-reveal">
        <h1 class="heading-xl max-w-4xl text-[var(--paper)]">{title}</h1>
      </div>

      <div class="text-reveal mt-7">
        <p class="max-w-3xl font-heading text-xl font-bold leading-tight text-[var(--acid)] md:text-3xl">{subtitle}</p>
      </div>

      <div class="text-reveal mt-6">
        <p class="max-w-2xl text-base leading-8 text-[rgba(237,240,232,.72)] md:text-lg">{description}</p>
      </div>

      <div class="mt-9 flex flex-col gap-3 sm:flex-row">
        <a href={primaryCTALink} target="_blank" rel="noopener noreferrer" class="btn-primary" data-wa-label="Service hero consultation" data-magnetic>
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.16-.17.2-.35.22-.64.08-.3-.15-1.26-.46-2.4-1.48-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.03-.52-.07-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48s1.06 2.88 1.21 3.07c.15.2 2.1 3.2 5.08 4.49.71.31 1.26.49 1.69.63.71.23 1.36.2 1.87.12.57-.09 1.76-.72 2.01-1.41.25-.69.25-1.29.17-1.41-.07-.12-.27-.2-.57-.35M12.05 0C5.5 0 .16 5.34.16 11.89c0 2.1.55 4.14 1.59 5.95L.06 24l6.3-1.65a11.88 11.88 0 0 0 5.68 1.45h.01c6.55 0 11.89-5.34 11.89-11.89A11.82 11.82 0 0 0 12.05 0"/></svg>
          {primaryCTA} <span aria-hidden="true">↗</span>
        </a>
        <a href={secondaryCTALink} class="btn-secondary" data-magnetic>{secondaryCTA} <span aria-hidden="true">↓</span></a>
      </div>
    </div>

    <div class="hidden lg:block">
      <div class="scanline border border-white/15 bg-[rgba(8,11,10,.64)] p-5 backdrop-blur-md">
        <div class="flex items-center justify-between border-b border-white/10 pb-4 font-mono text-[.6rem] uppercase tracking-[.14em] text-[rgba(237,240,232,.55)]">
          <span>Machine status</span>
          <span class="text-[var(--acid)]">READY</span>
        </div>
        <div class="space-y-5 pt-5">
          <div>
            <span class="font-mono text-[.6rem] uppercase tracking-[.14em] text-[rgba(237,240,232,.55)]">Process route</span>
            <strong class="mt-2 block font-heading text-2xl text-[var(--paper)]">File → Nest → Cut</strong>
          </div>
          <div class="grid grid-cols-2 gap-4 border-t border-white/10 pt-4">
            <div>
              <strong class="block font-heading text-3xl text-[var(--acid)]">±0.1</strong>
              <span class="font-mono text-[.58rem] uppercase tracking-[.1em] text-[rgba(237,240,232,.55)]">mm tolerance</span>
            </div>
            <div>
              <strong class="block font-heading text-3xl text-[var(--acid)]">QC</strong>
              <span class="font-mono text-[.58rem] uppercase tracking-[.1em] text-[rgba(237,240,232,.55)]">before delivery</span>
            </div>
          </div>
        </div>
      </div>
      <p class="mt-4 font-mono text-[.6rem] uppercase tracking-[.12em] text-[rgba(237,240,232,.55)]">Workshop Tangerang Selatan / Banten & Jabodetabek</p>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 hidden lg:flex flex-col items-center gap-2" aria-hidden="true">
    <span class="font-mono text-[.5rem] uppercase tracking-[.2em] text-[rgba(237,240,232,.35)]">Scroll</span>
    <div class="w-px h-8 bg-gradient-to-b from-[rgba(237,240,232,.35)] to-transparent animate-pulse"></div>
  </div>
</section>

<style>
  .service-hero { position: relative; }
  .scanline { position: relative; }
  .scanline::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,.03) 2px,
      rgba(0,0,0,.03) 4px
    );
    pointer-events: none;
    border-radius: inherit;
  }

  /* Floating particles */
  .particle {
    position: absolute;
    width: 2px;
    height: 2px;
    background: var(--brand-gold-soft);
    border-radius: 50%;
    opacity: 0;
    animation: float-particle 8s ease-in-out infinite;
  }
  .particle-1 { left: 10%; top: 20%; animation-delay: 0s; animation-duration: 10s; }
  .particle-2 { left: 25%; top: 60%; animation-delay: 2s; animation-duration: 12s; width: 3px; height: 3px; background: var(--brand-red-soft); }
  .particle-3 { left: 70%; top: 30%; animation-delay: 4s; animation-duration: 9s; background: var(--brand-blue-soft); }
  .particle-4 { left: 85%; top: 70%; animation-delay: 1s; animation-duration: 11s; width: 1px; height: 1px; }
  .particle-5 { left: 50%; top: 80%; animation-delay: 3s; animation-duration: 13s; background: var(--brand-green-soft); }

  @keyframes float-particle {
    0%, 100% { opacity: 0; transform: translateY(0) scale(0); }
    20% { opacity: 0.6; transform: translateY(-20px) scale(1); }
    80% { opacity: 0.3; transform: translateY(-60px) scale(0.5); }
  }

  @media (prefers-reduced-motion: reduce) {
    .particle { animation: none; opacity: 0; }
  }
</style>
