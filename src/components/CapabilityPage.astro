---
import BaseLayout from './BaseLayout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import CTA from './CTA.astro';
import Breadcrumbs from './Breadcrumbs.astro';
import { SITE_CONFIG, SERVICES, MATERIALS } from '../utils/constants.js';
import { getCapabilityContent } from '../utils/capabilityContent.js';
import { generateBreadcrumbSchema, generateFAQSchema } from '../utils/seo.js';

export interface Item {
  id?: string;
  name: string;
  slug?: string;
  description: string;
  image: string;
  features?: string[];
  applications?: string[];
  thickness?: string;
  keywords?: string;
}

export interface Props {
  item: Item;
  kind?: 'service' | 'material' | 'solution';
  title?: string;
  description?: string;
  url?: string;
}

interface DeepDecision { title: string; description: string; }
interface DeepImage { src: string; alt: string; label: string; caption: string; }
interface DeepContent {
  lead: string;
  decisions: DeepDecision[];
  fit: string[];
  notFit: string[];
  gallery: DeepImage[];
  priceFactors: string[];
  qualityChecks: string[];
}

const { item, kind = 'service', title = item.name, description = item.description, url = `/${item.slug || ''}/` } = Astro.props;
const label = kind === 'material' ? 'Kapabilitas Material' : kind === 'solution' ? 'Solusi Proyek Custom' : 'Kapabilitas Mesin Produksi';
const deepContent = getCapabilityContent(item.slug || '', item.image || '/images/v10/home-fiber-workshop-real.webp', title) as DeepContent;

const features = item.features?.length
  ? item.features
  : [
      item.thickness ? `Ketebalan material umum: ${item.thickness}` : 'Spesifikasi & toleransi disesuaikan kebutuhan proyek',
      'File vektor AI, DXF, DWG, CDR, atau SVG ditinjau sebelum produksi',
      'Parameter mesin ditetapkan sesuai jenis material dan target hasil',
      'Kondisi tepi serta dimensi acuan diperiksa sebelum serah terima',
      'Finishing, packing, dan pengiriman dikonfirmasi sebagai lingkup terpisah'
    ];

const applications = item.applications?.length
  ? item.applications
  : ['Ornamen & Panel Arsitektur', 'Elemen Interior & Partisi', 'Huruf Timbul & Signage', 'Komponen Mesin & Mold Custom'];

const related = (kind === 'service' ? SERVICES : MATERIALS).filter((entry) => entry.name !== item.name).slice(0, 3);
const crumbsInput = [{ name: 'Beranda', url: '/' }, { name: kind === 'material' ? 'Material' : 'Layanan', url: '/services/' }, { name: title, url }];
const breadcrumbSchema = generateBreadcrumbSchema(crumbsInput);
const wa = `https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent(`Halo Tepat Laser, saya ingin konsultasi ${title}.`)}`;
const intakeItems = [
  ['Material', 'Jenis atau grade material bila sudah ditentukan'],
  ['Dimensi', 'Panjang × lebar, ketebalan, dan ukuran komponen'],
  ['Jumlah', 'Jumlah desain, jumlah per desain, dan total kebutuhan'],
  ['File', 'DXF, DWG, AI, CDR, SVG, PDF vektor, atau sketsa'],
  ['Hasil akhir', 'Cutting saja, engraving, bending, finishing, atau siap pasang'],
  ['Target waktu', 'Tanggal material atau komponen perlu diterima']
];
const processSteps = [
  ['Review brief', 'Tim membaca fungsi, file, ukuran, material, jumlah, dan risiko geometri.'],
  ['Kunci spesifikasi', 'Rute mesin, scope pekerjaan, toleransi relevan, harga, serta estimasi waktu disepakati.'],
  ['Produksi terkontrol', 'File final digunakan untuk setup, nesting, proses mesin, dan pekerjaan tambahan yang disetujui.'],
  ['QC & serah terima', 'Output diperiksa terhadap brief, lalu disiapkan untuk pickup atau pengiriman.']
];
const faqs = [
  { question: `Berapa harga ${title}?`, answer: `Harga ${title} dihitung dari material, ketebalan, panjang jalur atau waktu proses, kompleksitas file, jumlah, finishing, dan target waktu. Kirim data tersebut agar estimasi tidak menyesatkan.` },
  { question: 'Apakah bisa mulai dari foto atau sketsa?', answer: 'Bisa untuk konsultasi awal. Produksi tetap memerlukan ukuran dan file kerja yang layak; tim akan menjelaskan data yang masih perlu dilengkapi.' },
  { question: 'Berapa lama pengerjaannya?', answer: 'Lead time ditentukan setelah file, material, jumlah, finishing, dan antrean produksi dikonfirmasi. Tanggal selesai dicantumkan saat scope pekerjaan sudah jelas.' },
  { question: 'Apakah material bisa disediakan pelanggan?', answer: 'Bisa ditinjau. Jenis, kondisi, ukuran, dan jumlah cadangan material perlu diperiksa karena karakter setiap bahan memengaruhi hasil proses.' }
];
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: title,
  description,
  url: new URL(url, SITE_CONFIG.url).href,
  provider: { '@type': 'LocalBusiness', '@id': `${SITE_CONFIG.url}/#business`, name: SITE_CONFIG.name },
  areaServed: ['Tangerang Selatan', 'Jakarta', 'Depok', 'Tangerang', 'Bogor', 'Bekasi']
};
const meta = {
  title: `${title} Tangerang Selatan | Tepat Laser`,
  description,
  keywords: item.keywords || `${title}, Tepat Laser, laser cutting Tangerang Selatan, fabrikasi presisi`,
  url,
  image: item.image || '/images/v10/home-fiber-workshop-real.webp',
  jsonLd: [breadcrumbSchema, generateFAQSchema(faqs), serviceSchema]
};
---

<BaseLayout {...meta}>
  <Header slot="header" />
  <main class="capability-page overflow-hidden bg-slate-50 text-slate-900">
    <!-- Hero Banner Section -->
    <section class="capability-hero bg-slate-50 border-b border-slate-200/80 pt-24 pb-16">
      <div class="container-custom">
        <Breadcrumbs crumbs={crumbsInput} />
        <div class="mt-6 grid items-center gap-8 lg:grid-cols-12 lg:gap-12">
          <!-- Left Copy -->
          <div class="lg:col-span-7">
            <div class="inline-flex items-center gap-2 rounded-full border border-slate-300 bg-white px-3.5 py-1 text-xs font-bold text-slate-800 shadow-sm">
              <span class="h-2 w-2 rounded-full bg-emerald-500"></span>
              {label}
            </div>
            <h1 class="mt-5 text-3xl font-black tracking-tight text-slate-950 sm:text-4xl lg:text-5xl lg:leading-[1.15]">
              {title}
            </h1>
            <p class="mt-5 text-base sm:text-lg leading-relaxed text-slate-700 font-medium max-w-2xl">
              {description}
            </p>
            <div class="mt-8 flex flex-col gap-3.5 sm:flex-row sm:items-center">
              <a href={wa} target="_blank" rel="noopener noreferrer" class="btn-primary shadow-lg shadow-amber-500/15" data-wa-label={`Capability ${title}`}>
                Konsultasikan Brief Proyek <span>↗</span>
              </a>
              <a href="#spesifikasi" class="btn-secondary">
                Spesifikasi & Detail <span>↓</span>
              </a>
            </div>
          </div>

          <!-- Right Visual (Properly Fitted, No Zoom Distortion) -->
          <div class="lg:col-span-5">
            <div class="relative overflow-hidden rounded-2xl border border-slate-300 bg-slate-900 shadow-xl">
              <img
                src={item.image || '/images/v10/home-fiber-workshop-real.webp'}
                alt={`${title} — Tepat Laser`}
                width="1200"
                height="800"
                class="w-full h-[20rem] sm:h-[25rem] lg:h-[28rem] object-cover object-center"
                fetchpriority="high"
                decoding="async"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-slate-950/85 via-slate-950/20 to-transparent"></div>
              <div class="absolute bottom-0 inset-x-0 p-4 flex items-center justify-between text-white text-xs font-bold tracking-wider">
                <span class="flex items-center gap-2">
                  <span class="h-2 w-2 rounded-full bg-amber-400"></span>
                  {title}
                </span>
                <span class="text-slate-300 font-medium">Tepat Laser Tangsel</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Kinetic Ticker -->
    <section class="kinetic-line" aria-label={`Alur produksi ${title}`}>
      <div class="kinetic-track">
        <span>{title}</span><span>Review Vector File</span><span>Pengujian Sample</span><span>Kalibrasi Laser</span><span>Pemeriksaan Mutu QC</span>
        <span>{title}</span><span>Review Vector File</span><span>Pengujian Sample</span><span>Kalibrasi Laser</span><span>Pemeriksaan Mutu QC</span>
      </div>
    </section>

    <section class="section-padding bg-white">
      <div class="container-custom">
        <div class="decision-intro">
          <div>
            <span class="eyebrow text-amber-800">Sebelum memilih proses</span>
            <h2 class="heading-md mt-4 text-slate-950">Tiga keputusan yang lebih penting daripada sekadar bertanya “bisa dipotong atau tidak”.</h2>
          </div>
          <p>{deepContent.lead}</p>
        </div>
        <div class="decision-grid">
          {deepContent.decisions.map((entry, index) => (
            <article>
              <span>0{index + 1}</span>
              <h3>{entry.title}</h3>
              <p>{entry.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Specifications Grid -->
    <section id="spesifikasi" class="section-padding bg-slate-50">
      <div class="container-custom">
        <div class="grid gap-10 lg:grid-cols-12 lg:items-start">
          <div class="lg:col-span-5">
            <span class="eyebrow text-amber-800">Parameter Teknis</span>
            <h2 class="heading-lg mt-4 text-slate-950">Detail Produksi Yang Kami Kunci Sebelum Mesin Bergerak.</h2>
            <p class="mt-4 text-slate-700 font-medium leading-relaxed">
              Material, ketebalan, geometri potongan, jumlah order, dan target visual akhir saling memengaruhi. Kami membacanya sebagai satu kesatuan keputusan teknik yang terukur.
            </p>
          </div>
          <div class="lg:col-span-7">
            <div class="grid gap-4 sm:grid-cols-2">
              {features.map((feature, index) => (
                <div class="rounded-xl border border-slate-200 bg-slate-50 p-5 shadow-sm transition-transform hover:-translate-y-0.5">
                  <span class="inline-block rounded-md bg-amber-500/10 px-2.5 py-0.5 font-mono text-xs font-bold text-amber-800 border border-amber-500/20">
                    POS 0{index + 1}
                  </span>
                  <p class="mt-3 text-sm font-bold text-slate-900 leading-snug">{feature}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-padding bg-white">
      <div class="container-custom">
        <div class="grid gap-6 lg:grid-cols-[.8fr_1.2fr] lg:items-end">
          <div>
            <span class="eyebrow text-amber-800">Material, proses, dan hasil</span>
            <h2 class="heading-md mt-4 text-slate-950">Visual yang benar-benar berkaitan dengan {title}.</h2>
          </div>
          <p class="max-w-2xl text-slate-600 leading-7">Gambar mesin menjelaskan proses, gambar material menjelaskan karakter bahan, dan gambar aplikasi membantu Anda menilai hasil dalam konteks penggunaan—bukan dekorasi acak yang sekadar memenuhi ruang.</p>
        </div>
        <div class="capability-gallery">
          {deepContent.gallery.map((entry, index) => (
            <figure class:list={[index === 0 && 'capability-gallery-wide']}>
              <img src={entry.src} alt={entry.alt} width="1200" height="900" loading="lazy" decoding="async" />
              <figcaption><span>{entry.label}</span><h3>{entry.caption}</h3></figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- Quote readiness -->
    <section class="section-padding bg-slate-950 text-white">
      <div class="container-custom">
        <div class="grid gap-10 lg:grid-cols-[.8fr_1.2fr] lg:items-end">
          <div>
            <span class="eyebrow text-amber-400">Data untuk estimasi</span>
            <h2 class="heading-md mt-4 text-white">Enam data yang membuat penawaran lebih cepat dan lebih akurat.</h2>
            <p class="mt-5 max-w-xl text-slate-300">Belum lengkap tidak masalah. Tandai yang belum diketahui; tim akan membantu memisahkan keputusan wajib dari detail yang bisa menyusul.</p>
          </div>
          <div class="intake-grid">
            {intakeItems.map(([name, detail], index) => (
              <div>
                <span>0{index + 1}</span>
                <h3>{name}</h3>
                <p>{detail}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section-padding bg-amber-50">
      <div class="container-custom">
        <div class="max-w-3xl">
          <span class="eyebrow text-amber-800">Cocok atau perlu rute lain?</span>
          <h2 class="heading-md mt-4 text-slate-950">Keputusan yang baik juga menjelaskan kapan {title} bukan pilihan paling efisien.</h2>
          <p class="mt-5 text-slate-700 leading-7">Jika brief Anda masuk kolom kanan, tim akan mengarahkan ke teknologi, material, atau tahapan lain sebelum biaya terlanjur keluar.</p>
        </div>
        <div class="fit-grid">
          <article>
            <div class="fit-heading"><span>✓</span><h3>Umumnya cocok untuk</h3></div>
            <ul>{deepContent.fit.map((entry) => <li>{entry}</li>)}</ul>
          </article>
          <article>
            <div class="fit-heading"><span>→</span><h3>Perlu ditinjau atau dialihkan bila</h3></div>
            <ul>{deepContent.notFit.map((entry) => <li>{entry}</li>)}</ul>
          </article>
        </div>
      </div>
    </section>

    <!-- Applications Grid -->
    <section class="dark-section py-16 md:py-20">
      <div class="container-custom">
        <div class="max-w-2xl">
          <span class="eyebrow text-amber-400">Pilihan Aplikasi</span>
          <h2 class="heading-md mt-4 text-white">Bukan Sekadar Bisa Dipotong. Harus Siap Dipasang Di Lapangan.</h2>
        </div>
        <div class="mt-10 grid grid-cols-2 gap-4 sm:grid-cols-4">
          {applications.map((application, index) => (
            <div class="rounded-xl border border-slate-800 bg-slate-950 p-6 shadow-md border-t-2 border-t-amber-400">
              <span class="font-mono text-xs font-bold text-amber-400">0{index + 1}</span>
              <p class="mt-4 text-base font-bold text-white">{application}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Production flow -->
    <section class="section-padding bg-white">
      <div class="container-custom">
        <div class="max-w-3xl">
          <span class="eyebrow text-amber-800">Alur yang transparan</span>
          <h2 class="heading-md mt-4 text-slate-950">Dari brief sampai barang diterima, setiap keputusan punya titik konfirmasi.</h2>
        </div>
        <ol class="production-flow">
          {processSteps.map(([name, detail], index) => (
            <li>
              <span>0{index + 1}</span>
              <div><h3>{name}</h3><p>{detail}</p></div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="section-padding bg-slate-950 text-white">
      <div class="container-custom grid gap-10 lg:grid-cols-[.7fr_1.3fr] lg:items-start">
        <div>
          <span class="eyebrow text-amber-400">Logika harga</span>
          <h2 class="heading-md mt-4 text-white">Penawaran yang dapat dibandingkan harus menjelaskan apa yang membentuk angkanya.</h2>
          <p class="mt-5 text-slate-300 leading-7">File, material, jumlah, dan scope pekerjaan dibaca bersama agar angka awal tidak berubah karena asumsi tersembunyi.</p>
        </div>
        <ol class="factor-list">
          {deepContent.priceFactors.map((entry, index) => (
            <li><span>0{index + 1}</span><p>{entry}</p></li>
          ))}
        </ol>
      </div>
    </section>

    <section class="section-padding bg-white">
      <div class="container-custom">
        <div class="grid gap-8 lg:grid-cols-[.9fr_1.1fr]">
          <div>
            <span class="eyebrow text-amber-800">Kriteria penerimaan</span>
            <h2 class="heading-md mt-4 text-slate-950">“Rapi” harus diterjemahkan menjadi hal yang bisa diperiksa.</h2>
            <p class="mt-5 text-slate-700 leading-7">Dimensi kritis, sisi kosmetik, kondisi tepi, jumlah, dan kesiapan untuk proses berikutnya disepakati sesuai fungsi komponen.</p>
          </div>
          <ul class="quality-list">
            {deepContent.qualityChecks.map((entry, index) => (
              <li><span>{String(index + 1).padStart(2, '0')}</span><p>{entry}</p></li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section-padding bg-slate-50">
      <div class="container-custom grid gap-10 lg:grid-cols-[.7fr_1.3fr]">
        <div>
          <span class="eyebrow text-amber-800">Pertanyaan sebelum order</span>
          <h2 class="heading-md mt-4 text-slate-950">Jawaban singkat tanpa janji teknis yang dibuat sebelum melihat file.</h2>
        </div>
        <div class="capability-faq">
          {faqs.map((faq, index) => (
            <details open={index === 0}>
              <summary>{faq.question}<span aria-hidden="true">＋</span></summary>
              <p>{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Related Capabilities -->
    <section class="section-padding bg-slate-50">
      <div class="container-custom">
        <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div>
            <span class="eyebrow text-amber-800">Kapabilitas Lainnya</span>
            <h2 class="heading-md mt-3 text-slate-950">Jelajahi Pilihan Material & Teknologi Tambahan.</h2>
          </div>
          <a href="/services/" class="text-sm font-bold text-amber-800 hover:text-amber-900">Lihat Semua Kapabilitas ↗</a>
        </div>
        <div class="mt-8 grid gap-6 sm:grid-cols-3">
          {related.map((entry, index) => (
            <a href={`/${entry.slug}/`} class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition-all hover:-translate-y-1 hover:shadow-md hover:border-amber-400">
              <span class="font-mono text-xs font-bold text-slate-600 group-hover:text-amber-800">0{index + 1}</span>
              <h3 class="mt-3 text-xl font-bold text-slate-900 group-hover:text-amber-600">{entry.name}</h3>
              <p class="mt-2 text-xs leading-relaxed text-slate-600 font-medium">{entry.description}</p>
              <span class="mt-4 inline-block text-xs font-extrabold text-amber-800">Lihat Detail ↗</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <CTA
      title="Punya Brief Proyek Yang Perlu Ditinjau Tim Engineer?"
      description="Kirim berkas CAD, DXF, PDF, atau sketsa kasar Anda. Tim teknis Tepat Laser siap membantu membaca material, toleransi, dan estimasi biaya tanpa biaya konsultasi."
      primaryText="Konsultasikan via WhatsApp"
      secondaryText="Lihat Alur Produksi"
      secondaryLink="/proses-produksi-lead-time/"
    />
  </main>
  <Footer slot="footer" />
</BaseLayout>

<style>
  .decision-intro{display:grid;gap:2rem;align-items:end}
  .decision-intro>p{max-width:44rem;color:#475569;font-size:1rem;line-height:1.8}
  .decision-grid{display:grid;gap:1rem;margin-top:3rem}
  .decision-grid article{border:1px solid #cbd5e1;background:#f8fafc;padding:1.5rem}
  .decision-grid article>span{color:#76520e;font-size:.75rem;font-weight:850;letter-spacing:.12em}
  .decision-grid h3{margin-top:2rem;color:#0f172a;font-size:1.35rem}
  .decision-grid p{margin-top:.75rem;color:#475569;font-size:.94rem;line-height:1.75}
  .capability-gallery{display:grid;gap:1rem;margin-top:3rem}
  .capability-gallery figure{position:relative;min-height:25rem;overflow:hidden;border-radius:.7rem;background:#050706}
  .capability-gallery img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
  .capability-gallery figure::after{position:absolute;inset:0;content:'';background:linear-gradient(to top,rgba(5,7,6,.9),transparent 62%)}
  .capability-gallery figcaption{position:absolute;z-index:1;right:1.3rem;bottom:1.3rem;left:1.3rem}
  .capability-gallery figcaption span{color:#edcf79;font-size:.72rem;font-weight:850;letter-spacing:.12em;text-transform:uppercase}
  .capability-gallery figcaption h3{max-width:30rem;margin-top:.5rem;color:#fff;font-size:1.35rem;line-height:1.15}
  .fit-grid{display:grid;gap:1rem;margin-top:3rem}
  .fit-grid article{border:1px solid #d6c8aa;background:#fff;padding:1.5rem}
  .fit-heading{display:flex;align-items:center;gap:.8rem}
  .fit-heading>span{display:grid;width:2rem;height:2rem;place-items:center;border-radius:50%;background:#0f172a;color:#fff;font-weight:800}
  .fit-heading h3{color:#0f172a;font-size:1.25rem}
  .fit-grid ul{display:grid;gap:.7rem;margin:1.5rem 0 0;padding:0;list-style:none}
  .fit-grid li{position:relative;padding-left:1.1rem;color:#334155;line-height:1.65}
  .fit-grid li::before{position:absolute;top:.72rem;left:0;width:.35rem;height:.35rem;border-radius:50%;background:#9a6c14;content:''}
  .factor-list{display:grid;margin:0;padding:0;border-top:1px solid #334155;list-style:none}
  .factor-list li{display:grid;grid-template-columns:3rem 1fr;gap:1rem;border-bottom:1px solid #334155;padding:1.15rem 0}
  .factor-list span{color:#edcf79;font-size:.75rem;font-weight:850}
  .factor-list p{color:#f8fafc;font-weight:700}
  .quality-list{display:grid;margin:0;padding:0;border:1px solid #cbd5e1;list-style:none}
  .quality-list li{display:grid;grid-template-columns:3rem 1fr;gap:1rem;padding:1.2rem}
  .quality-list li+li{border-top:1px solid #cbd5e1}
  .quality-list span{color:#76520e;font-size:.75rem;font-weight:850}
  .quality-list p{color:#334155;font-weight:650;line-height:1.65}
  .intake-grid{display:grid;gap:1px;border:1px solid #334155;background:#334155}
  .intake-grid>div{background:#0f172a;padding:1.25rem}
  .intake-grid span,.production-flow>li>span{font-size:.75rem;font-weight:800;letter-spacing:.1em}
  .intake-grid span{color:#f4c95d}
  .production-flow>li>span{color:#76520e}
  .intake-grid h3{margin-top:1.4rem;color:#fff;font-size:1.15rem}
  .intake-grid p{margin-top:.45rem;color:#cbd5e1;font-size:.9rem;line-height:1.65}
  .production-flow{display:grid;margin:2.5rem 0 0;padding:0;border-top:1px solid #cbd5e1;list-style:none}
  .production-flow li{display:grid;grid-template-columns:2.5rem 1fr;gap:1rem;border-bottom:1px solid #cbd5e1;padding:1.4rem 0}
