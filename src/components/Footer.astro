---
import { SITE_CONFIG, SERVICES, MATERIALS } from '../utils/constants.js';
const wa = `https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent('Halo Tepat Laser, saya ingin konsultasi proyek dan mengirimkan file.')}`;
---

<footer class="site-footer">
  <div class="container-custom py-16 md:py-20">
    <div class="footer-top">
      <div>
        <a href="/" class="brand-lockup footer-brand" aria-label="Tepat Laser, beranda">
          <span class="footer-logo-shell"><img class="footer-logo" src="/images/logo-light-transparent.webp" alt="Tepat Laser — Laser Cutting" width="1200" height="594" loading="lazy" decoding="async" /></span>
        </a>
        <p class="mt-6 max-w-md text-sm leading-7">Bukan sekadar tempat potong. Kami membantu mengunci material, proses, detail, dan pemeriksaan agar hasil siap melanjutkan proyek Anda.</p>
        <a href={wa} target="_blank" rel="noopener noreferrer" class="footer-action mt-7" data-wa-label="Footer WhatsApp">Kirim kebutuhan Anda <span>↗</span></a>

        <div class="footer-social mt-6">
          <a href={SITE_CONFIG.socialMedia.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram Tepat Laser">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href={SITE_CONFIG.socialMedia.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook Tepat Laser">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href={SITE_CONFIG.socialMedia.youtube} target="_blank" rel="noopener noreferrer" aria-label="YouTube Tepat Laser">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/></svg>
          </a>
        </div>
      </div>
      <div class="footer-links">
        <div><h2>Layanan</h2><ul>{SERVICES.map((item) => <li><a href={`/${item.slug}/`}>{item.name}</a></li>)}</ul></div>
        <div><h2>Material</h2><ul>{MATERIALS.map((item) => <li><a href={`/${item.slug}/`}>{item.name}</a></li>)}</ul></div>
        <div><h2>Informasi</h2><ul><li><a href="/about/">Tentang kami</a></li><li><a href="/proses-produksi-lead-time/">Proses kerja</a></li><li><a href="/faq/">Pertanyaan umum</a></li><li><a href="/blog/">Wawasan teknis</a></li><li><a href="/contact/">Kontak</a></li></ul></div>
      </div>
    </div>
    <div class="footer-workshop">
      <div><span>Workshop</span><p>{SITE_CONFIG.address}</p></div>
      <div><span>Jam kerja</span><p>{SITE_CONFIG.businessHours}</p></div>
      <div><span>Kontak</span><p><a href={`tel:${SITE_CONFIG.phone}`}>{SITE_CONFIG.phone}</a><br /><a href={`mailto:${SITE_CONFIG.email}`}>{SITE_CONFIG.email}</a></p></div>
    </div>
    <div class="footer-bottom"><span>© {new Date().getFullYear()} Tepat Laser</span><span>Tangerang Selatan · Indonesia</span><span class="footer-release">V10</span></div>
  </div>

  <a href={wa} target="_blank" rel="noopener noreferrer" class="whatsapp-float" aria-label="Konsultasi Tepat Laser melalui WhatsApp" data-wa-label="Floating WhatsApp">
    <span class="whatsapp-icon" aria-hidden="true"><svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2a9.9 9.9 0 0 0-8.3 15.3L2.5 22l4.82-1.25A9.94 9.94 0 1 0 12.04 2Zm0 18.1a8.13 8.13 0 0 1-4.15-1.14l-.3-.18-2.86.75.76-2.78-.2-.29a8.1 8.1 0 1 1 6.75 3.64Zm4.46-6.05c-.24-.12-1.42-.7-1.64-.77-.22-.08-.38-.12-.54.12-.16.24-.62.77-.76.93-.14.16-.28.18-.52.06-.24-.12-1.01-.37-1.92-1.18-.71-.63-1.18-1.4-1.32-1.64-.14-.24-.01-.37.1-.49.1-.1.23-.25.34-.38.11-.13.14-.23.22-.38.07-.16.04-.29-.02-.41-.06-.12-.54-1.3-.74-1.78-.2-.47-.4-.4-.54-.41h-.46c-.16 0-.41.06-.63.29-.22.24-.83.81-.83 1.97s.85 2.28.96 2.44c.12.16 1.67 2.54 4.04 3.56.56.24 1 .38 1.34.49.56.18 1.08.15 1.48.09.45-.07 1.42-.58 1.62-1.14.2-.55.2-1.02.14-1.12-.06-.1-.21-.16-.44-.28Z" /></svg></span>
    <span>Konsultasi</span>
  </a>
</footer>

<style>
  .site-footer{position:relative;border-top:0;background:#050706;color:#fff}.site-footer::before{position:absolute;top:0;right:0;left:0;height:3px;content:'';background:var(--brand-spectrum)}
  .site-footer p{color:rgba(255,255,255,.62)}
  .footer-logo-shell{display:inline-flex;align-items:center}.footer-logo{width:12rem;height:5.8rem;object-fit:contain;object-position:left center}
  .footer-action{display:inline-flex;align-items:center;gap:.65rem;color:var(--brand-gold-soft);font-size:.9rem;font-weight:750}.footer-action:hover{color:var(--brand-blue-soft)}
  .footer-social{display:flex;gap:.75rem;margin-top:1rem}
  .footer-social a{display:grid;width:2.2rem;height:2.2rem;place-items:center;border:1px solid rgba(255,255,255,.15);border-radius:50%;color:rgba(255,255,255,.6);transition:all .25s var(--ease-smooth)}
  .footer-social a:hover{border-color:var(--brand-gold-soft);color:var(--brand-gold-soft);transform:translateY(-2px)}
  .footer-top{display:grid;gap:3.5rem}
  .footer-links{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:2rem}
  .footer-links h2{color:var(--brand-gold-soft);font-family:inherit;font-size:.75rem;font-weight:800;letter-spacing:.12em;text-transform:uppercase}.footer-links>div:nth-child(1) h2{color:var(--brand-red-soft)}.footer-links>div:nth-child(2) h2{color:var(--brand-green-soft)}.footer-links>div:nth-child(3) h2{color:var(--brand-blue-soft)}
  .footer-links ul{margin:1.1rem 0 0;padding:0;list-style:none}.footer-links li+li{margin-top:.65rem}.footer-links a{color:rgba(255,255,255,.76);font-size:.88rem}.footer-links a:hover{color:#fff}
  .footer-workshop{display:grid;gap:1.5rem;margin-top:3.5rem;border-top:1px solid rgba(255,255,255,.12);padding-top:2rem}
  .footer-workshop span{display:block;margin-bottom:.6rem;color:rgba(255,255,255,.6);font-size:.75rem;font-weight:800;letter-spacing:.11em;text-transform:uppercase}.footer-workshop p{font-size:.88rem;line-height:1.7}
  .footer-workshop a{display:inline-flex;min-height:1.5rem;align-items:center}
  .footer-bottom{display:flex;justify-content:space-between;gap:1rem;margin-top:3rem;border-top:1px solid rgba(255,255,255,.12);padding-top:1.4rem;color:rgba(255,255,255,.62);font-size:.75rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase}
  .footer-release{color:var(--brand-gold-soft);font-family:'Clash Display',sans-serif;font-weight:600}
  @media(min-width:900px){.footer-top{grid-template-columns:1fr 1.35fr}.footer-workshop{grid-template-columns:1.5fr .8fr .8fr}}
  @media(max-width:640px){.footer-links{grid-template-columns:repeat(2,minmax(0,1fr))}.footer-bottom{flex-direction:column;gap:.5rem}.footer-release{margin-top:.5rem}}
</style>
