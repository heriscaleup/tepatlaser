---
import { SITE_CONFIG, SERVICES, MATERIALS } from '../utils/constants.js';
const whatsapp = `https://api.whatsapp.com/send?phone=${SITE_CONFIG.whatsapp}&text=${encodeURIComponent('Halo Tepat Laser, saya ingin konsultasi project.')}`;
---
<footer class="relative overflow-hidden border-t border-[var(--line)] bg-[var(--ink-soft)]">
  <div class="pointer-events-none absolute -right-24 -top-24 h-72 w-72 rounded-full bg-[var(--acid)] opacity-[.06] blur-3xl"></div>
  <div class="container-custom section-padding !pb-12">
    <div class="grid gap-12 lg:grid-cols-[1.4fr_.8fr_.8fr_1.2fr]">
      <div><a href="/" class="group inline-flex items-center gap-3"><img src="/images/logo.webp" alt="Logo Tepat Laser" class="h-11 w-11 object-contain transition-transform duration-300 group-hover:scale-105" width="48" height="48" /><span><strong class="block font-heading text-lg tracking-[-.04em]">Tepat Laser</strong><small class="font-mono text-[.6rem] uppercase tracking-[.16em] text-[var(--muted)]">Precision fabrication</small></span></a><p class="mt-6 max-w-sm text-sm leading-7">Kami membantu ide arsitektur, interior, signage, dan manufaktur berubah menjadi komponen nyata yang presisi, rapi, dan siap dipasang.</p><a href={whatsapp} target="_blank" rel="noopener noreferrer" class="mt-7 inline-flex items-center gap-3 font-mono text-xs font-bold uppercase tracking-[.15em] text-[var(--acid)]" data-wa-label="Footer consultation">Mulai dari file Anda <span class="text-lg">↗</span></a></div>
      <div><h2 class="font-mono text-xs font-bold uppercase tracking-[.16em] text-[var(--acid)]">Layanan</h2><ul class="mt-5 space-y-3 text-sm text-[var(--muted)]">{SERVICES.slice(0,4).map((service) => <li><a class="transition-colors hover:text-[var(--acid)]" href={`/${service.slug}/`}>{service.name}</a></li>)}</ul></div>
      <div><h2 class="font-mono text-xs font-bold uppercase tracking-[.16em] text-[var(--acid)]">Material</h2><ul class="mt-5 space-y-3 text-sm text-[var(--muted)]">{MATERIALS.slice(0,5).map((material) => <li><a class="transition-colors hover:text-[var(--acid)]" href={`/${material.slug}/`}>{material.name}</a></li>)}</ul></div>
      <div><h2 class="font-mono text-xs font-bold uppercase tracking-[.16em] text-[var(--acid)]">Workshop</h2><div class="mt-5 space-y-4 text-sm leading-6 text-[var(--muted)]"><p>{SITE_CONFIG.address}</p><a class="block transition-colors hover:text-[var(--acid)]" href={`tel:${SITE_CONFIG.phone}`}>{SITE_CONFIG.phone}</a><p class="font-mono text-xs uppercase tracking-[.1em]">{SITE_CONFIG.businessHours}</p></div></div>
    </div>
    <div class="mt-16 flex flex-col gap-3 border-t border-[var(--line)] pt-6 font-mono text-[.65rem] uppercase tracking-[.12em] text-[var(--muted)] sm:flex-row sm:items-center sm:justify-between"><span>© {new Date().getFullYear()} Tepat Laser</span><span>Made for real-world projects · Tangerang Selatan</span></div>
  </div>
  <button id="back-to-top" class="fixed bottom-5 left-5 z-40 grid h-10 w-10 translate-y-20 place-items-center border border-[var(--line)] bg-[var(--panel)] text-[var(--acid)] opacity-0 transition-all" aria-label="Kembali ke atas">↑</button>
  <a href={whatsapp} target="_blank" rel="noopener noreferrer" class="fixed bottom-5 right-5 z-40 grid h-14 w-14 place-items-center rounded-full bg-[#25D366] text-white shadow-[0_0_2rem_rgba(37,211,102,.28)] transition-transform hover:scale-110" aria-label="Chat WhatsApp" data-wa-label="Floating WhatsApp"><svg class="h-8 w-8" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><circle cx="12" cy="12" r="11" fill="none" stroke="currentColor" stroke-width="1.2"/><path d="M16.5 13.7c-.2-.1-1.1-.5-1.3-.6-.2-.1-.3-.1-.5.1l-.6.8c-.1.2-.2.2-.4.1-.2-.1-.8-.3-1.5-.9-.6-.5-.9-1.1-1-1.3-.1-.2 0-.3.1-.4l.3-.3.2-.3c.1-.1 0-.3 0-.4l-.6-1.4c-.1-.4-.3-.3-.5-.3h-.4c-.1 0-.4.1-.5.3-.2.2-.7.7-.7 1.7s.7 1.9.8 2c.1.1 1.4 2.1 3.4 2.9.5.2.9.4 1.2.4.5.2.9.1 1.2.1.4-.1 1.1-.5 1.3-1 .2-.5.2-.9.1-1-.1-.1-.2-.2-.4-.3Z"/></svg></a>
</footer>
<script is:inline>document.addEventListener('DOMContentLoaded', () => { const button = document.querySelector('#back-to-top'); window.addEventListener('scroll', () => { const visible = window.scrollY > 500; button?.classList.toggle('translate-y-20', !visible); button?.classList.toggle('opacity-0', !visible); button?.classList.toggle('translate-y-0', visible); button?.classList.toggle('opacity-100', visible); }, { passive: true }); button?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' })); });</script>
