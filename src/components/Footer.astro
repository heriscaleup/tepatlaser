---
import { SITE_CONFIG, SERVICES, MATERIALS } from '../utils/constants.js';
const wa = `https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent('Halo Tepat Laser, saya ingin konsultasi project.')}`;
---
<footer class="border-t border-[var(--line)] bg-white"><div class="container-custom section-padding !pb-8"><div class="grid gap-10 lg:grid-cols-[1.4fr_.8fr_.8fr_1fr]"><div><a href="/" class="brand-lockup"><span class="brand-mark">TL</span><span><span class="brand-name">TEPAT LASER</span><span class="brand-meta">Precision beyond expectation</span></span></a><p class="mt-6 max-w-sm text-sm leading-7">Partner produksi untuk komponen, signage, interior, arsitektur, dan kebutuhan custom yang perlu dibuat dengan presisi.</p><a href={wa} target="_blank" rel="noopener noreferrer" class="mt-6 inline-flex font-mono text-xs font-bold uppercase tracking-[.14em] text-[var(--laser-deep)]" data-wa-label="Footer WhatsApp">Kirim file Anda ↗</a></div><div><h2 class="eyebrow">Capabilities</h2><ul class="mt-5 space-y-3 text-sm font-semibold text-[var(--muted)]">{SERVICES.map((item)=><li><a href={`/${item.slug}/`} class="hover:text-[var(--ink)]">{item.name}</a></li>)}</ul></div><div><h2 class="eyebrow">Materials</h2><ul class="mt-5 space-y-3 text-sm font-semibold text-[var(--muted)]">{MATERIALS.slice(0,5).map((item)=><li><a href={`/${item.slug}/`} class="hover:text-[var(--ink)]">{item.name}</a></li>)}</ul></div><div><h2 class="eyebrow">Workshop</h2><p class="mt-5 text-sm leading-7">{SITE_CONFIG.address}</p><a href={`tel:${SITE_CONFIG.phone}`} class="mt-4 block text-sm font-bold text-[var(--ink)]">{SITE_CONFIG.phone}</a><p class="mt-2 font-mono text-[.62rem] uppercase tracking-[.1em]">{SITE_CONFIG.businessHours}</p></div></div><div class="mt-14 flex flex-col gap-3 border-t border-[var(--line)] pt-6 font-mono text-[.6rem] font-bold uppercase tracking-[.12em] text-[var(--muted)] sm:flex-row sm:justify-between"><span>© {new Date().getFullYear()} Tepat Laser</span><span>Tangerang Selatan · Indonesia</span></div></div><a href={wa} target="_blank" rel="noopener noreferrer" class="fixed bottom-5 right-5 z-40 grid h-14 w-14 place-items-center rounded-full bg-[#25D366] text-white shadow-[0_.6rem_1.8rem_rgba(37,211,102,.28)] transition-transform hover:scale-105" aria-label="Chat Tepat Laser via WhatsApp" data-wa-label="Floating WhatsApp"><svg class="h-7 w-7" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.04 2a9.9 9.9 0 0 0-8.3 15.3L2.5 22l4.82-1.25A9.94 9.94 0 1 0 12.04 2Zm0 18.1a8.13 8.13 0 0 1-4.15-1.14l-.3-.18-2.86.75.76-2.78-.2-.29a8.1 8.1 0 1 1 6.75 3.64Zm4.46-6.05c-.24-.12-1.42-.7-1.64-.77-.22-.08-.38-.12-.54.12-.16.24-.62.77-.76.93-.14.16-.28.18-.52.06-.24-.12-1.01-.37-1.92-1.18-.71-.63-1.18-1.4-1.32-1.64-.14-.24-.01-.37.1-.49.1-.1.23-.25.34-.38.11-.13.14-.23.22-.38.07-.16.04-.29-.02-.41-.06-.12-.54-1.3-.74-1.78-.2-.47-.4-.4-.54-.41h-.46c-.16 0-.41.06-.63.29-.22.24-.83.81-.83 1.97s.85 2.28.96 2.44c.12.16 1.67 2.54 4.04 3.56.56.24 1 .38 1.34.49.56.18 1.08.15 1.48.09.45-.07 1.42-.58 1.62-1.14.2-.55.2-1.02.14-1.12-.06-.1-.21-.16-.44-.28Z"/></svg></a></footer>
