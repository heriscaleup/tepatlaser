---
interface Pillar { title: string; description: string; evidence: string; }
interface Props {
  eyebrow: string;
  title: string;
  intro: string;
  pillars: Pillar[];
  checklistTitle: string;
  checklistIntro: string;
  checklist: string[];
}
const { eyebrow, title, intro, pillars, checklistTitle, checklistIntro, checklist } = Astro.props;
---

<section class="editorial-depth section-padding bg-white">
  <div class="container-custom">
    <div class="editorial-depth-intro">
      <div>
        <span class="eyebrow text-amber-800">{eyebrow}</span>
        <h2 class="heading-md mt-5 text-slate-950">{title}</h2>
      </div>
      <p>{intro}</p>
    </div>
    <div class="editorial-depth-grid">
      {pillars.map((pillar, index) => (
        <article>
          <span>0{index + 1}</span>
          <h3>{pillar.title}</h3>
          <p>{pillar.description}</p>
          <small>{pillar.evidence}</small>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="editorial-check section-padding bg-slate-950 text-white">
  <div class="container-custom editorial-check-grid">
    <div>
      <span class="eyebrow text-amber-400">Yang bisa Anda verifikasi</span>
      <h2 class="heading-md mt-5 text-white">{checklistTitle}</h2>
      <p class="mt-5">{checklistIntro}</p>
    </div>
    <ol>
      {checklist.map((item, index) => (
        <li><span>{String(index + 1).padStart(2, '0')}</span><p>{item}</p></li>
      ))}
    </ol>
  </div>
</section>

<style>
  .editorial-depth-intro{display:grid;gap:2rem;align-items:end}
  .editorial-depth-intro>p{max-width:44rem;color:#475569;font-size:1rem;line-height:1.85}
  .editorial-depth-grid{display:grid;gap:1rem;margin-top:3rem}
  .editorial-depth-grid article{border:1px solid #cbd5e1;background:#f8fafc;padding:1.5rem}
  .editorial-depth-grid article>span{color:#76520e;font-size:.75rem;font-weight:850;letter-spacing:.12em}
  .editorial-depth-grid h3{margin-top:2rem;color:#0f172a;font-size:1.35rem}
  .editorial-depth-grid p{margin-top:.8rem;color:#475569;font-size:.94rem;line-height:1.75}
  .editorial-depth-grid small{display:block;margin-top:1.25rem;border-top:1px solid #cbd5e1;padding-top:1rem;color:#334155;font-size:.75rem;font-weight:800;line-height:1.55;text-transform:uppercase}
  .editorial-check-grid{display:grid;gap:3rem}
  .editorial-check-grid>div>p{max-width:38rem;color:#cbd5e1;line-height:1.8}
  .editorial-check-grid ol{display:grid;margin:0;padding:0;border-top:1px solid #334155;list-style:none}
  .editorial-check-grid li{display:grid;grid-template-columns:3rem 1fr;gap:1rem;border-bottom:1px solid #334155;padding:1.2rem 0}
  .editorial-check-grid li span{color:#edcf79;font-size:.75rem;font-weight:850}
  .editorial-check-grid li p{color:#f8fafc;font-weight:700;line-height:1.65}
  @media(min-width:760px){.editorial-depth-intro{grid-template-columns:.85fr 1.15fr}.editorial-depth-grid{grid-template-columns:repeat(3,minmax(0,1fr))}.editorial-check-grid{grid-template-columns:.75fr 1.25fr}}
</style>
