---
import BaseLayout from '../components/BaseLayout.astro'; import Header from '../components/Header.astro'; import Footer from '../components/Footer.astro'; import PageIntro from '../components/PageIntro.astro'; import { SITE_CONFIG, WHATSAPP_MESSAGES } from '../utils/constants.js';
const waUrl = `https://api.whatsapp.com/send?phone=${SITE_CONFIG.whatsapp}&text=${encodeURIComponent(WHATSAPP_MESSAGES.default)}`;
---
<BaseLayout title="Hubungi Tepat Laser — Konsultasi Proyek" description="Kirim file dan konsultasikan kebutuhan laser cutting, CNC router, atau engraving Anda bersama tim Tepat Laser." keywords="kontak tepat laser, konsultasi laser cutting WhatsApp, hubungi laser cutting" url="/contact/"><Header slot="header" />
  <main class="overflow-hidden"><PageIntro eyebrow="Kontak" title="Kirim yang Anda punya. Kami bantu melengkapi yang belum jelas." description="Tidak perlu menunggu file sempurna. Ukuran, foto, material, jumlah, target waktu, atau sketsa awal sudah cukup untuk memulai percakapan yang tepat." actionText="Buka WhatsApp" actionHref={waUrl} />
    <section class="section-padding"><div class="container-custom contact-grid"><div class="contact-main"><span class="eyebrow">Agar lebih cepat ditinjau</span><h2 class="heading-md mt-6">Lima informasi yang membuat jawaban kami jauh lebih cepat.</h2><ol><li><span>01</span><p>Material atau fungsi yang diinginkan</p></li><li><span>02</span><p>Ukuran dan ketebalan</p></li><li><span>03</span><p>Jumlah kebutuhan</p></li><li><span>04</span><p>Target waktu selesai</p></li><li><span>05</span><p>File DXF, DWG, AI, CDR, SVG, PDF vektor, foto, atau sketsa</p></li></ol></div><aside><div><span>Workshop</span><p>{SITE_CONFIG.address}</p></div><div><span>Jam kerja</span><p>{SITE_CONFIG.businessHours}</p></div><div><span>Telepon</span><p><a href={`tel:${SITE_CONFIG.phone}`}>{SITE_CONFIG.phone}</a></p></div><div><span>Email</span><p><a href={`mailto:${SITE_CONFIG.email}`}>{SITE_CONFIG.email}</a></p></div></aside></div></section>
    <section class="dark-section section-padding"><div class="container-custom response-grid"><div><span class="eyebrow">Setelah brief dikirim</span><h2 class="heading-md mt-5">Percakapan diarahkan menuju keputusan, bukan berhenti di “berapa harganya?”.</h2><p class="mt-5">Harga baru bermakna jika material, ukuran, jumlah, file, finishing, dan target waktu merujuk pada kebutuhan yang sama.</p></div><ol><li><span>01</span><div><h3>Cek kelengkapan</h3><p>Tim menandai data yang sudah cukup dan yang masih perlu dipastikan.</p></div></li><li><span>02</span><div><h3>Review teknis</h3><p>File, geometri, material, proses, serta risiko dibaca sebelum estimasi.</p></div></li><li><span>03</span><div><h3>Penawaran</h3><p>Scope, harga, asumsi, waktu, dan metode serah terima dirangkum.</p></div></li><li><span>04</span><div><h3>Persetujuan</h3><p>Produksi bergerak setelah detail utama disepakati oleh kedua pihak.</p></div></li></ol></div></section>
    <section class="warm-section section-padding"><div class="container-custom message-template"><div><span class="eyebrow">Template pesan</span><h2 class="heading-md mt-5">Salin struktur ini agar review pertama langsung produktif.</h2><a href={waUrl} target="_blank" rel="noopener noreferrer" class="btn-primary mt-7">Kirim melalui WhatsApp <span>↗</span></a></div><div class="template-card"><p>Halo Tepat Laser, saya ingin konsultasi:</p><ul><li>Fungsi/produk:</li><li>Material & ketebalan:</li><li>Ukuran:</li><li>Jumlah:</li><li>Finishing:</li><li>Target diterima:</li><li>Pickup/kirim ke:</li></ul><p>File/foto saya lampirkan setelah pesan ini.</p></div></div></section>
  </main><Footer slot="footer" />
</BaseLayout>
<style>
  .contact-grid{display:grid;gap:2rem}.contact-main{border:1px solid var(--line);background:var(--surface);padding:clamp(1.5rem,4vw,3rem)}.contact-main ol{margin:2.5rem 0 0;padding:0;list-style:none}.contact-main li{display:grid;grid-template-columns:2rem 1fr;gap:1rem;border-top:1px solid var(--line);padding:1rem 0}.contact-main li span{color:var(--laser);font-size:.76rem;font-weight:800}.contact-main li p{color:var(--ink);font-size:.95rem;font-weight:700}.contact-grid aside{display:grid;gap:1px;border:1px solid var(--line);background:var(--line)}.contact-grid aside>div{background:var(--surface);padding:1.35rem}.contact-grid aside span{color:var(--laser-deep);font-size:.75rem;font-weight:800;letter-spacing:.11em;text-transform:uppercase}.contact-grid aside p{margin-top:.8rem;font-size:.9rem;line-height:1.7}
  .response-grid{display:grid;gap:3rem}.response-grid>div>p{max-width:38rem;font-size:1rem;line-height:1.8}.response-grid ol{display:grid;margin:0;padding:0;border:1px solid var(--line);list-style:none}.response-grid li{display:grid;grid-template-columns:2rem 1fr;gap:.75rem;padding:1.25rem}.response-grid li+li{border-top:1px solid var(--line)}.response-grid li>span{color:var(--laser);font-size:.75rem;font-weight:800}.response-grid h3{font-size:1.2rem}.response-grid li p{margin-top:.4rem;font-size:.9rem;line-height:1.65}
  .message-template{display:grid;gap:3rem}.template-card{border:1px solid var(--line);background:var(--surface);padding:clamp(1.4rem,4vw,2.25rem);box-shadow:var(--shadow-sm)}.template-card p{color:var(--ink);font-weight:700}.template-card ul{margin:1.25rem 0;padding-left:1.2rem;color:var(--muted)}.template-card li{margin:.5rem 0;font-size:.95rem}
  @media(min-width:900px){.contact-grid{grid-template-columns:1.2fr .8fr}.response-grid,.message-template{grid-template-columns:.8fr 1.2fr}.response-grid ol{grid-template-columns:repeat(2,minmax(0,1fr))}.response-grid li:nth-child(2n){border-left:1px solid var(--line)}.response-grid li:nth-child(2){border-top:0}.response-grid li:nth-child(n+3){border-top:1px solid var(--line)}}
</style>
