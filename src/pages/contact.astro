---
import BaseLayout from '../components/BaseLayout.astro'; import Header from '../components/Header.astro'; import Footer from '../components/Footer.astro'; import PageIntro from '../components/PageIntro.astro'; import { SITE_CONFIG, WHATSAPP_MESSAGES } from '../utils/constants.js';
const waUrl = `https://api.whatsapp.com/send?phone=${SITE_CONFIG.whatsapp}&text=${encodeURIComponent(WHATSAPP_MESSAGES.default)}`;
---
<BaseLayout title="Hubungi Tepat Laser — Konsultasi Proyek" description="Kirim file dan konsultasikan kebutuhan laser cutting, CNC router, atau engraving Anda bersama tim Tepat Laser." keywords="kontak tepat laser, konsultasi laser cutting WhatsApp, hubungi laser cutting" url="/contact/"><Header slot="header" />
  <main class="overflow-hidden"><PageIntro eyebrow="Kontak" title="Mulai dari brief yang sudah ada." description="Tidak perlu menunggu file sempurna. Kirim ukuran, material, jumlah, target waktu, atau referensi visual—tim kami bantu memetakan langkah pertama." actionText="Buka WhatsApp" actionHref={waUrl} />
    <section class="section-padding"><div class="container-custom contact-grid"><div class="contact-main"><span class="eyebrow">Agar lebih cepat ditinjau</span><h2 class="heading-md mt-6">Sertakan lima informasi dasar.</h2><ol><li><span>01</span><p>Material atau fungsi yang diinginkan</p></li><li><span>02</span><p>Ukuran dan ketebalan</p></li><li><span>03</span><p>Jumlah kebutuhan</p></li><li><span>04</span><p>Target waktu selesai</p></li><li><span>05</span><p>File DXF, DWG, AI, CDR, SVG, PDF vektor, foto, atau sketsa</p></li></ol></div><aside><div><span>Workshop</span><p>{SITE_CONFIG.address}</p></div><div><span>Jam kerja</span><p>{SITE_CONFIG.businessHours}</p></div><div><span>Telepon</span><p><a href={`tel:${SITE_CONFIG.phone}`}>{SITE_CONFIG.phone}</a></p></div><div><span>Email</span><p><a href={`mailto:${SITE_CONFIG.email}`}>{SITE_CONFIG.email}</a></p></div></aside></div></section>
  </main><Footer slot="footer" />
</BaseLayout>
<style>
  .contact-grid{display:grid;gap:2rem}.contact-main{border:1px solid var(--line);background:var(--surface);padding:clamp(1.5rem,4vw,3rem)}.contact-main ol{margin:2.5rem 0 0;padding:0;list-style:none}.contact-main li{display:grid;grid-template-columns:2rem 1fr;gap:1rem;border-top:1px solid var(--line);padding:1rem 0}.contact-main li span{color:var(--laser);font-size:.7rem;font-weight:800}.contact-main li p{color:var(--ink);font-size:.9rem;font-weight:700}.contact-grid aside{display:grid;gap:1px;border:1px solid var(--line);background:var(--line)}.contact-grid aside>div{background:var(--surface);padding:1.35rem}.contact-grid aside span{color:var(--laser-deep);font-size:.62rem;font-weight:800;letter-spacing:.12em;text-transform:uppercase}.contact-grid aside p{margin-top:.8rem;font-size:.8rem;line-height:1.7}
  @media(min-width:900px){.contact-grid{grid-template-columns:1.2fr .8fr}}
</style>
