---
import BaseLayout from '../components/BaseLayout.astro'; import Header from '../components/Header.astro'; import Footer from '../components/Footer.astro'; import { SITE_CONFIG, WHATSAPP_MESSAGES } from '../utils/constants.js';
const waUrl = `https://api.whatsapp.com/send?phone=${SITE_CONFIG.whatsapp}&text=${encodeURIComponent(WHATSAPP_MESSAGES.default)}`;
---
<BaseLayout title="Hubungi Tepat Laser — Konsultasi Project" description="Kirim file dan konsultasikan kebutuhan laser cutting, CNC router, atau engraving Anda bersama tim Tepat Laser." keywords="kontak tepat laser, konsultasi laser cutting WhatsApp, hubungi laser cutting" url="/contact/"><Header slot="header" />
  <main class="overflow-hidden"><section class="border-b border-[var(--line)] pt-40 pb-20"><div class="container-custom grid gap-10 lg:grid-cols-[1fr_.7fr] lg:items-end"><div><span class="eyebrow">Contact / Start here</span><h1 class="heading-xl mt-7">Send the<br /><span class="text-[var(--acid)]">brief.</span></h1></div><p class="max-w-xl text-lg leading-8">Tidak perlu menunggu file sempurna. Kirim ukuran, material, jumlah, deadline, atau sekadar referensi—tim kami bantu memetakan langkah pertama.</p></div></section><section class="section-padding"><div class="container-custom grid gap-5 lg:grid-cols-[1.1fr_.9fr]"><div class="border border-[var(--line)] bg-[var(--panel)] p-7 md:p-10"><span class="eyebrow">WhatsApp line</span><h2 class="heading-md mt-6">Project masuk,<br /><span class="text-[var(--acid)]">kami review.</span></h2><p class="mt-5 max-w-lg leading-8">Kirim file DXF, DWG, AI, CDR, SVG, PDF vector, atau foto/sketsa. Sertakan material, ketebalan, ukuran, jumlah, dan target selesai.</p><a href={waUrl} target="_blank" rel="noopener noreferrer" class="btn-primary mt-8" data-wa-label="Contact WhatsApp">Buka WhatsApp <span>↗</span></a></div><div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-1"><div class="line-panel p-6"><span class="eyebrow">Workshop</span><p class="mt-4 text-sm leading-7">{SITE_CONFIG.address}</p></div><div class="line-panel p-6"><span class="eyebrow">Hours</span><p class="mt-4 text-sm leading-7">{SITE_CONFIG.businessHours}</p><a href={`tel:${SITE_CONFIG.phone}`} class="mt-3 block text-sm text-[var(--paper)] hover:text-[var(--acid)]">{SITE_CONFIG.phone}</a></div><div class="line-panel p-6"><span class="eyebrow">Email</span><a href={`mailto:${SITE_CONFIG.email}`} class="mt-4 block text-sm text-[var(--paper)] hover:text-[var(--acid)]">{SITE_CONFIG.email}</a></div></div></div></section></main><Footer slot="footer" />
</BaseLayout>
