---
import BaseLayout from '../../components/BaseLayout.astro'; import Header from '../../components/Header.astro'; import Footer from '../../components/Footer.astro'; import CTA from '../../components/CTA.astro'; import { getCollection, render } from 'astro:content'; import { generateBlogPostSchema, generateBlogFaqSchema, generateBreadcrumbSchema } from '../../utils/seo.js';
export async function getStaticPaths(){ const posts = await getCollection('blog'); return posts.map((post) => ({params:{slug:post.id}, props:{post}})); }
const { post } = Astro.props; const { Content } = await render(post); const allPosts = await getCollection('blog'); const relatedPosts = allPosts.filter((item) => item.data.category === post.data.category && item.id !== post.id).slice(0,3); const crumbs = [{name:'Beranda',url:'/'},{name:'Blog',url:'/blog/'},{name:post.data.title,url:`/blog/${post.id}/`}]; const faqSchema = generateBlogFaqSchema(post.data.faq); const jsonLd = {'@context':'https://schema.org','@graph':[generateBlogPostSchema({...post.data,slug:post.id}),generateBreadcrumbSchema(crumbs),...(faqSchema?[faqSchema]:[])]};
---
<BaseLayout title={post.data.title} description={post.data.description} keywords={post.data.keywords} image={post.data.image} type="article" publishedTime={post.data.publishDate} modifiedTime={post.data.updatedDate} author={post.data.author} jsonLd={[jsonLd]}><Header slot="header" />
  <main class="overflow-hidden"><article class="pt-36 pb-20"><div class="container-custom max-w-5xl"><a href="/blog/" class="font-mono text-xs uppercase tracking-[.13em] text-[var(--acid)]">← Back to field notes</a><div class="mt-10 grid gap-10 lg:grid-cols-[1fr_.35fr] lg:items-end"><div><span class="eyebrow">{post.data.category} · {post.data.readTime}</span><h1 class="heading-lg mt-6">{post.data.title}</h1><p class="mt-6 max-w-3xl text-lg leading-8">{post.data.excerpt}</p></div><div class="border-l border-[var(--line)] pl-5 font-mono text-[.62rem] uppercase tracking-[.12em] text-[var(--muted)]"><p>Published</p><time class="mt-2 block text-[var(--paper)]" datetime={post.data.publishDate}>{new Date(post.data.publishDate).toLocaleDateString('id-ID',{year:'numeric',month:'long',day:'numeric'})}</time><p class="mt-6">By {post.data.author}</p></div></div><img src={post.data.image} alt={post.data.imageAlt} width="1200" height="630" class="mt-14 aspect-[1.9] w-full object-cover" fetchpriority="high" decoding="async" />
      <div class="mx-auto mt-12 grid max-w-4xl gap-10 lg:grid-cols-[.28fr_1fr]"><aside class="h-fit border border-[var(--line)] bg-[var(--panel)] p-5 lg:sticky lg:top-28"><p class="eyebrow">Quick take</p><ul class="mt-5 space-y-3 text-sm leading-6">{post.data.keyTakeaways.map((item) => <li class="flex gap-3"><span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--acid)]"></span><span>{item}</span></li>)}</ul></aside><div class="article-prose"><Content /></div></div>
      <section class="mx-auto mt-16 max-w-4xl border-t border-[var(--line)] pt-10"><h2 class="heading-md">Layanan dan panduan terkait</h2><div class="mt-6 grid gap-3 sm:grid-cols-2">{post.data.relatedLinks.map((link) => <a href={link.url} class="line-panel p-4 text-sm font-semibold transition-colors hover:border-[var(--acid)] hover:text-[var(--acid)]">{link.title} ↗</a>)}</div>{post.data.faq?.length > 0 && <div class="mt-16"><h2 class="heading-md">FAQ project</h2><div class="mt-6 space-y-3">{post.data.faq.map((item) => <details class="border border-[var(--line)] bg-[var(--panel)] p-5"><summary class="cursor-pointer font-semibold text-[var(--paper)]">{item.question}</summary><p class="mt-4 text-sm leading-7">{item.answer}</p></details>)}</div></div>}</section>
    </div></article><CTA title="Punya project yang ingin dibahas?" primaryText="Konsultasi via WhatsApp" secondaryText="Kembali ke blog" secondaryLink="/blog/" />
    {relatedPosts.length > 0 && <section class="border-t border-[var(--line)] bg-[var(--ink-soft)] py-20"><div class="container-custom"><span class="eyebrow">Keep reading</span><div class="mt-8 grid gap-5 md:grid-cols-3">{relatedPosts.map((related) => <a href={`/blog/${related.id}/`} class="group border border-[var(--line)] bg-[var(--panel)] p-5 transition-colors hover:border-[var(--acid)]"><span class="font-mono text-[.6rem] uppercase tracking-[.12em] text-[var(--acid)]">{related.data.category}</span><h3 class="mt-10 text-xl group-hover:text-[var(--acid)]">{related.data.title}</h3><p class="mt-3 text-sm">{related.data.excerpt}</p></a>)}</div></div></section>}
  </main><Footer slot="footer" />
</BaseLayout>
<style is:global>.article-prose{color:var(--muted);font-size:1.05rem;line-height:1.9}.article-prose h2,.article-prose h3{margin:2.6rem 0 1rem;color:var(--paper)}.article-prose h2{font-size:2rem}.article-prose h3{font-size:1.45rem}.article-prose p{margin:1.2rem 0}.article-prose a{color:var(--acid);text-decoration:underline;text-underline-offset:4px}.article-prose ul,.article-prose ol{margin:1.2rem 0;padding-left:1.3rem}.article-prose li{margin:.5rem 0}.article-prose strong{color:var(--paper)}.article-prose blockquote{margin:2rem 0;border-left:2px solid var(--acid);padding:1rem 1.25rem;background:var(--panel);color:var(--paper)}</style>
