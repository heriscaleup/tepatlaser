---
import BaseLayout from '../../components/BaseLayout.astro'; import Header from '../../components/Header.astro'; import Footer from '../../components/Footer.astro'; import CTA from '../../components/CTA.astro'; import { getCollection, render } from 'astro:content'; import { generateBlogPostSchema, generateBlogFaqSchema, generateBreadcrumbSchema } from '../../utils/seo.js';
export async function getStaticPaths(){ const posts = await getCollection('blog'); return posts.map((post) => ({params:{slug:post.id}, props:{post}})); }
const { post } = Astro.props; const { Content } = await render(post); const allPosts = await getCollection('blog'); const relatedPosts = allPosts.filter((item) => item.data.category === post.data.category && item.id !== post.id).slice(0,3); const crumbs = [{name:'Beranda',url:'/'},{name:'Wawasan',url:'/blog/'},{name:post.data.title,url:`/blog/${post.id}/`}]; const faqSchema = generateBlogFaqSchema(post.data.faq); const jsonLd = {'@context':'https://schema.org','@graph':[generateBlogPostSchema({...post.data,slug:post.id}),generateBreadcrumbSchema(crumbs),...(faqSchema?[faqSchema]:[])]};
---
<BaseLayout title={post.data.title} description={post.data.description} keywords={post.data.keywords} image={post.data.image} type="article" publishedTime={post.data.publishDate} modifiedTime={post.data.updatedDate} author={post.data.author} jsonLd={[jsonLd]}><Header slot="header" />
  <main class="overflow-hidden"><article class="article-page"><header class="article-header"><div class="container-custom"><a href="/blog/" class="article-back">← Kembali ke wawasan</a><div class="article-head-grid"><div><span class="eyebrow">{post.data.category} · {post.data.readTime}</span><h1 class="article-title">{post.data.title}</h1><p class="article-excerpt">{post.data.excerpt}</p></div><div class="article-byline"><span>Terbit</span><time datetime={post.data.publishDate}>{new Date(post.data.publishDate).toLocaleDateString('id-ID',{year:'numeric',month:'long',day:'numeric'})}</time><span>Penulis</span><strong>{post.data.author}</strong></div></div></div></header><div class="kinetic-line" aria-hidden="true"><div class="kinetic-track"><span>Material</span><span>Persiapan file</span><span>Proses mesin</span><span>Pemeriksaan mutu</span><span>Material</span><span>Persiapan file</span><span>Proses mesin</span><span>Pemeriksaan mutu</span></div></div>
    <div class="container-custom"><img src={post.data.image} alt={post.data.imageAlt} width="1200" height="630" class="article-cover" fetchpriority="high" decoding="async" /><div class="article-layout"><aside><p>Ringkasan</p><ul>{post.data.keyTakeaways.map((item) => <li><span></span>{item}</li>)}</ul></aside><div class="article-prose"><Content /></div></div>
      <section class="article-related-links"><h2 class="heading-md">Layanan dan panduan terkait</h2><div>{post.data.relatedLinks.map((link) => <a href={link.url}>{link.title} <span>↗</span></a>)}</div>{post.data.faq?.length > 0 && <div class="article-faq"><h2 class="heading-md">Pertanyaan terkait</h2>{post.data.faq.map((item) => <details><summary>{item.question}<span>＋</span></summary><p>{item.answer}</p></details>)}</div>}</section>
    </div></article><CTA title="Punya proyek yang ingin dibahas?" primaryText="Konsultasi via WhatsApp" secondaryText="Kembali ke wawasan" secondaryLink="/blog/" />
    {relatedPosts.length > 0 && <section class="warm-section py-16 md:py-20"><div class="container-custom"><span class="eyebrow">Bacaan berikutnya</span><div class="more-grid">{relatedPosts.map((related) => <a href={`/blog/${related.id}/`}><span>{related.data.category}</span><h3>{related.data.title}</h3><p>{related.data.excerpt}</p></a>)}</div></div></section>}
  </main><Footer slot="footer" />
</BaseLayout>
<style>
  .article-page{padding-top:4.8rem}
  .article-header{border-bottom:1px solid var(--line);background:var(--surface);padding-block:clamp(4rem,8vw,7rem)}
  .article-back{color:var(--laser-deep);font-size:.78rem;font-weight:800;letter-spacing:.08em;text-transform:uppercase}
  .article-head-grid{display:grid;align-items:end;gap:2.5rem;margin-top:2.5rem}
  .article-title{margin-top:1.2rem;max-width:20ch;font-size:clamp(2.6rem,5vw,4.8rem);line-height:1;letter-spacing:-.043em}
  .article-excerpt{max-width:46rem;margin-top:1.5rem;font-size:clamp(1rem,1.6vw,1.2rem);line-height:1.75}
  .article-byline{display:grid;grid-template-columns:auto 1fr;gap:.45rem 1rem;border-left:1px solid var(--line);padding-left:1.25rem;font-size:.78rem}
  .article-byline span{color:var(--muted);font-weight:800;letter-spacing:.09em;text-transform:uppercase}
  .article-byline time,.article-byline strong{color:var(--ink);font-weight:750}
  .article-cover{width:100%;aspect-ratio:1.9;margin-top:clamp(2rem,5vw,4rem);object-fit:cover}
  .article-layout{display:grid;gap:2.5rem;max-width:62rem;margin:3rem auto}
  .article-layout>aside{height:max-content;border-top:2px solid var(--laser);background:var(--surface);padding:1.2rem}
  .article-layout>aside>p{color:var(--laser-deep);font-size:.75rem;font-weight:800;letter-spacing:.11em;text-transform:uppercase}
  .article-layout aside ul{margin:1rem 0 0;padding:0;list-style:none}
  .article-layout aside li{display:flex;gap:.65rem;color:var(--muted);font-size:.85rem;line-height:1.6}
  .article-layout aside li+li{margin-top:.65rem}
  .article-layout aside li span{width:.35rem;height:.35rem;flex:none;margin-top:.45rem;border-radius:50%;background:var(--laser)}
  .article-related-links{max-width:48rem;margin:4rem auto 6rem;border-top:1px solid var(--line);padding-top:3rem}
  .article-related-links>div{display:grid;gap:.6rem;margin-top:1.5rem}
  .article-related-links>div>a{display:flex;justify-content:space-between;gap:1rem;border:1px solid var(--line);background:var(--surface);padding:1rem;font-size:.9rem;font-weight:750}
  .article-related-links>div>a:hover{border-color:var(--ink)}
  .article-faq{margin-top:4rem}
  .article-faq details{border-top:1px solid var(--line);padding:1rem 0}
  .article-faq details:last-child{border-bottom:1px solid var(--line)}
  .article-faq summary{display:flex;justify-content:space-between;gap:1rem;cursor:pointer;list-style:none;font-weight:750}
  .article-faq summary::-webkit-details-marker{display:none}
  .article-faq summary span{color:var(--laser)}
  .article-faq p{margin-top:.8rem;font-size:.92rem;line-height:1.75}
  .more-grid{display:grid;gap:1rem;margin-top:2rem}
  .more-grid>a{border:1px solid var(--line);background:var(--surface);padding:1.3rem}
  .more-grid>a>span{color:var(--laser-deep);font-size:.75rem;font-weight:800;letter-spacing:.09em;text-transform:uppercase}
  .more-grid h3{margin-top:2rem;font-size:1.3rem;line-height:1.12}
  .more-grid p{margin-top:.75rem;font-size:.88rem;line-height:1.65}
  @media(min-width:800px){.article-head-grid{grid-template-columns:1fr .3fr}.article-layout{grid-template-columns:.3fr 1fr}.article-layout>aside{position:sticky;top:6.5rem}.more-grid{grid-template-columns:repeat(3,minmax(0,1fr))}}
</style>
