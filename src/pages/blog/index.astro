---
import BaseLayout from '../../components/BaseLayout.astro'; import Header from '../../components/Header.astro'; import Footer from '../../components/Footer.astro'; import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).sort((a,b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());
const blogSchema = {'@context':'https://schema.org','@type':'Blog','name':'Blog Tepat Laser','description':'Panduan laser cutting, CNC router, material, file desain, dan quality control.','url':'https://tepatlaser.com/blog/','publisher':{'@type':'Organization','name':'Tepat Laser'}};
---
<BaseLayout title="Blog Tepat Laser — Panduan Produksi & Material" description="Panduan praktis memilih material, proses laser cutting, CNC router, biaya, file desain, dan quality control." keywords="blog laser cutting, panduan CNC router, material laser cutting" jsonLd={[blogSchema]}><Header slot="header" />
  <main class="overflow-hidden"><section class="border-b border-[var(--line)] pt-40 pb-20"><div class="container-custom grid gap-10 lg:grid-cols-[1fr_.7fr] lg:items-end"><div><span class="eyebrow">Field notes / Tepat Laser</span><h1 class="heading-xl mt-7">Read the<br /><span class="text-[var(--acid)]">process.</span></h1></div><p class="max-w-xl text-lg leading-8">Catatan teknis untuk membantu Anda membuat keputusan yang lebih baik sebelum file masuk ke lantai produksi.</p></div></section>
    <section class="section-padding"><div class="container-custom"><div class="mb-10 flex items-center justify-between border-b border-[var(--line)] pb-4"><span class="eyebrow">{posts.length} articles</span><span class="font-mono text-xs uppercase tracking-[.12em] text-[var(--muted)]">Latest first</span></div><div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">{posts.map((post, index) => <article class="group overflow-hidden border border-[var(--line)] bg-[var(--panel)]"><a href={`/blog/${post.id}/`} class="block overflow-hidden"><img src={post.data.image} alt={post.data.imageAlt} width="1200" height="800" class="aspect-[1.35] w-full object-cover opacity-75 transition duration-700 group-hover:scale-105 group-hover:opacity-100" loading={index < 3 ? 'eager' : 'lazy'} decoding="async" /></a><div class="p-6"><div class="flex items-center justify-between gap-3 font-mono text-[.6rem] uppercase tracking-[.12em] text-[var(--acid)]"><span>{post.data.category}</span><span class="text-[var(--muted)]">{post.data.readTime}</span></div><h2 class="mt-5 text-2xl leading-tight transition-colors group-hover:text-[var(--acid)]"><a href={`/blog/${post.id}/`}>{post.data.title}</a></h2><p class="mt-4 line-clamp-3 text-sm leading-7">{post.data.excerpt}</p><div class="mt-6 flex items-center justify-between border-t border-[var(--line)] pt-4"><time class="font-mono text-[.6rem] uppercase tracking-[.1em] text-[var(--muted)]" datetime={post.data.publishDate}>{new Date(post.data.publishDate).toLocaleDateString('id-ID',{year:'numeric',month:'short',day:'numeric'})}</time><a href={`/blog/${post.id}/`} class="font-mono text-xs uppercase tracking-[.1em] text-[var(--acid)]">Baca ↗</a></div></div></article>)}</div></div></section>
  </main><Footer slot="footer" />
</BaseLayout>
<style>.line-clamp-3{display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}</style>
