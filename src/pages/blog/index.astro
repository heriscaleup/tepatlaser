---
import BaseLayout from '../../components/BaseLayout.astro'; import Header from '../../components/Header.astro'; import Footer from '../../components/Footer.astro'; import PageIntro from '../../components/PageIntro.astro'; import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).sort((a,b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());
const [featured, ...remainingPosts] = posts;
const blogSchema = {'@context':'https://schema.org','@type':'Blog','name':'Wawasan Tepat Laser','description':'Panduan laser cutting, CNC router, material, file desain, dan pemeriksaan mutu.','url':'https://tepatlaser.com/blog/','publisher':{'@type':'Organization','name':'Tepat Laser'}};
---
<BaseLayout title="Wawasan Tepat Laser — Panduan Produksi & Material" description="Panduan praktis memilih material, proses laser cutting, CNC router, biaya, file desain, dan pemeriksaan mutu." keywords="blog laser cutting, panduan CNC router, material laser cutting" url="/blog/" jsonLd={[blogSchema]}><Header slot="header" />
  <main class="overflow-hidden"><PageIntro eyebrow="Wawasan teknis" title="Keputusan produksi yang baik dimulai dari informasi yang benar." description="Catatan praktis mengenai material, file, biaya, mesin, dan pemeriksaan mutu agar proyek masuk produksi dengan lebih siap." />
    <section class="kinetic-line" aria-label="Topik wawasan"><div class="kinetic-track"><span>Material</span><span>Proses mesin</span><span>Persiapan file</span><span>Estimasi biaya</span><span>Pemeriksaan mutu</span><span>Material</span><span>Proses mesin</span><span>Persiapan file</span><span>Estimasi biaya</span><span>Pemeriksaan mutu</span></div></section>
    <section class="section-padding blog-section"><div class="container-custom"><div class="blog-toolbar"><span>{posts.length} artikel</span><span>Terbaru lebih dulu</span></div>{featured && <article class="blog-featured"><a href={`/blog/${featured.id}/`} class="featured-media" aria-label={`Baca ${featured.data.title}`} data-parallax><img src={featured.data.image} alt={featured.data.imageAlt} width="1400" height="900" fetchpriority="high" decoding="async" /></a><div class="featured-copy"><div class="blog-meta"><span>Artikel pilihan · {featured.data.category}</span><span>{featured.data.readTime}</span></div><h2><a href={`/blog/${featured.id}/`}>{featured.data.title}</a></h2><p>{featured.data.excerpt}</p><div class="blog-bottom"><time datetime={featured.data.publishDate}>{new Date(featured.data.publishDate).toLocaleDateString('id-ID',{year:'numeric',month:'long',day:'numeric'})}</time><a href={`/blog/${featured.id}/`}>Baca artikel ↗</a></div></div></article>}<div class="blog-grid">{remainingPosts.map((post,index) => <article class="blog-card"><a href={`/blog/${post.id}/`} class="blog-media" aria-label={`Baca ${post.data.title}`}><img src={post.data.image} alt={post.data.imageAlt} width="1200" height="800" loading={index<5?'eager':'lazy'} decoding="async" /></a><div class="blog-copy"><div class="blog-meta"><span>{post.data.category}</span><span>{post.data.readTime}</span></div><h2><a href={`/blog/${post.id}/`}>{post.data.title}</a></h2><p>{post.data.excerpt}</p><div class="blog-bottom"><time datetime={post.data.publishDate}>{new Date(post.data.publishDate).toLocaleDateString('id-ID',{year:'numeric',month:'short',day:'numeric'})}</time><a href={`/blog/${post.id}/`}>Baca artikel ↗</a></div></div></article>)}</div></div></section>
  </main><Footer slot="footer" />
</BaseLayout>
<style>
  .blog-section{background:radial-gradient(circle at 12% 12%,rgba(54,114,172,.09),transparent 24rem)}.blog-toolbar{display:flex;justify-content:space-between;gap:1rem;border-bottom:1px solid var(--line);padding-bottom:1rem;color:var(--muted);font-size:.65rem;font-weight:800;letter-spacing:.11em;text-transform:uppercase}.blog-toolbar span:first-child{color:var(--laser-deep)}.blog-featured{display:grid;overflow:hidden;margin-top:2rem;border:1px solid var(--line);background:var(--surface)}.featured-media{position:relative;display:block;min-height:25rem;overflow:hidden;background:#050906}.featured-media::after{position:absolute;inset:0;content:'';background:linear-gradient(90deg,transparent,rgba(5,9,6,.16))}.featured-media img{position:absolute;inset:-4%;width:108%;height:108%;object-fit:cover}.featured-copy{display:flex;flex-direction:column;justify-content:center;padding:clamp(1.5rem,4vw,3.5rem)}.featured-copy h2{margin-top:1.3rem;font-size:clamp(2rem,4vw,4rem);line-height:.98}.featured-copy>p{margin-top:1.2rem;font-size:.92rem;line-height:1.75}.blog-grid{display:grid;gap:1rem;margin-top:1rem}.blog-card{overflow:hidden;border:1px solid var(--line);background:var(--surface);transition:transform .45s var(--ease),border-color .45s var(--ease)}.blog-card:hover{border-color:var(--laser);transform:translateY(-7px)}.blog-media{display:block;aspect-ratio:1.35;overflow:hidden;background:var(--surface-soft)}.blog-media img{width:100%;height:100%;object-fit:cover;filter:saturate(.74);transition:transform .75s var(--ease),filter .75s var(--ease)}.blog-card:hover img{transform:scale(1.055);filter:saturate(1)}.blog-copy{padding:1.35rem}.blog-meta{display:flex;justify-content:space-between;gap:.7rem;color:var(--laser-deep);font-size:.6rem;font-weight:800;letter-spacing:.08em;text-transform:uppercase}.blog-meta span:last-child{color:var(--muted)}.blog-copy h2{margin-top:1rem;font-size:1.35rem;line-height:1.08}.blog-copy>p{display:-webkit-box;overflow:hidden;margin-top:.8rem;font-size:.78rem;line-height:1.7;-webkit-box-orient:vertical;-webkit-line-clamp:3}.blog-bottom{display:flex;align-items:center;justify-content:space-between;gap:1rem;margin-top:1.2rem;border-top:1px solid var(--line);padding-top:1rem;font-size:.62rem;font-weight:750}.blog-bottom time{color:var(--muted)}.blog-bottom a{color:var(--laser-deep)}
  @media(min-width:700px){.blog-grid{grid-template-columns:repeat(2,minmax(0,1fr))}}
  @media(min-width:900px){.blog-featured{grid-template-columns:1.15fr .85fr}.featured-media{min-height:34rem}}@media(min-width:1050px){.blog-grid{grid-template-columns:repeat(3,minmax(0,1fr))}}
</style>
