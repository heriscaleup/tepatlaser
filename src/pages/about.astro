---
import BaseLayout from '../components/BaseLayout.astro'; import Header from '../components/Header.astro'; import Footer from '../components/Footer.astro'; import CTA from '../components/CTA.astro'; import { SITE_CONFIG, SERVICES } from '../utils/constants.js'; import { generateBreadcrumbSchema } from '../utils/seo.js';
---
<BaseLayout title="Tentang Tepat Laser — Workshop Fabrikasi Presisi" description="Kenali Tepat Laser, workshop laser cutting, CNC router, dan engraving di Tangerang Selatan untuk kebutuhan project nyata." keywords="tentang tepat laser, workshop laser cutting tangerang selatan, jasa fabrikasi presisi" url="/about/" jsonLd={[generateBreadcrumbSchema([{name:'Beranda',url:'/'},{name:'Tentang Kami',url:'/about/'}])]}><Header slot="header" />
  <main class="overflow-hidden"><section class="relative border-b border-[var(--line)] pt-40 pb-20"><div class="container-custom grid gap-10 lg:grid-cols-[1.1fr_.9fr] lg:items-end"><div><span class="eyebrow">About / Tepat Laser</span><h1 class="heading-xl mt-7">Precision is a<br /><span class="text-[var(--acid)]">way of thinking.</span></h1></div><p class="max-w-xl text-lg leading-8">Kami bukan sekadar tempat potong. Tepat Laser adalah partner produksi untuk ide yang harus diterjemahkan ke ukuran, material, dan detail yang benar.</p></div></section>
    <section class="section-padding"><div class="container-custom grid gap-12 lg:grid-cols-[1fr_1fr] lg:gap-24"><div><span class="eyebrow">The workshop</span><h2 class="heading-lg mt-6">Dibangun untuk<br /><span class="text-[var(--acid)]">membuatnya tepat.</span></h2></div><div class="space-y-6 text-lg leading-8"><p>Setiap project punya konteks berbeda: ada yang mengejar detail, ada yang mengejar jumlah, ada yang harus masuk ke site dengan deadline ketat. Kami mulai dari mendengar kebutuhan itu, bukan langsung menyalakan mesin.</p><p>Tim teknis kami membantu membaca file, memilih proses, mengoptimalkan nesting, dan menjaga konsistensi output. Hasil akhirnya bukan hanya potongan yang presisi, tetapi komponen yang benar-benar siap dipakai.</p><p>Berbasis di Parigi, Bintaro, kami melayani kebutuhan custom untuk interior, arsitektur, signage, manufaktur, furniture, hingga prototyping di Tangerang Selatan dan Jabodetabek.</p></div></div></section>
    <section class="border-y border-[var(--line)] bg-[var(--ink-soft)] py-16"><div class="container-custom grid gap-px border border-[var(--line)] bg-[var(--line)] md:grid-cols-3"><div class="bg-[var(--ink-soft)] p-7"><span class="eyebrow">01</span><h3 class="mt-10 text-2xl">Tanya dulu</h3><p class="mt-3 text-sm leading-7">Kami petakan fungsi, material, ukuran, dan batasan project.</p></div><div class="bg-[var(--ink-soft)] p-7"><span class="eyebrow">02</span><h3 class="mt-10 text-2xl">Pilih rute</h3><p class="mt-3 text-sm leading-7">Laser fiber, CO2, CNC router, atau engraving — sesuai kebutuhan.</p></div><div class="bg-[var(--ink-soft)] p-7"><span class="eyebrow">03</span><h3 class="mt-10 text-2xl">Jaga output</h3><p class="mt-3 text-sm leading-7">QC sebelum dikirim agar komponen datang dalam kondisi siap kerja.</p></div></div></section>
    <section class="section-padding"><div class="container-custom grid gap-8 lg:grid-cols-[.8fr_1.2fr]"><div><span class="eyebrow">Workshop coordinates</span><h2 class="heading-md mt-5">Temui kami<br /><span class="text-[var(--acid)]">di lapangan.</span></h2></div><div class="grid gap-4 sm:grid-cols-2"><div class="line-panel p-6"><span class="eyebrow">Location</span><p class="mt-4 text-sm leading-7">{SITE_CONFIG.address}</p></div><div class="line-panel p-6"><span class="eyebrow">Hours</span><p class="mt-4 text-sm leading-7">{SITE_CONFIG.businessHours}</p></div><div class="line-panel p-6"><span class="eyebrow">Contact</span><a href={`tel:${SITE_CONFIG.phone}`} class="mt-4 block text-sm text-[var(--paper)] hover:text-[var(--acid)]">{SITE_CONFIG.phone}</a><a href={`mailto:${SITE_CONFIG.email}`} class="mt-2 block text-sm text-[var(--muted)] hover:text-[var(--acid)]">{SITE_CONFIG.email}</a></div><div class="line-panel p-6"><span class="eyebrow">Focus</span><p class="mt-4 text-sm leading-7">{SERVICES.map((service) => service.name).join(' · ')}</p></div></div></div></section><CTA title="Kalau brief-nya sudah ada, mari kita pecahkan bersama." primaryText="Hubungi Tepat Laser" secondaryText="Lihat layanan" secondaryLink="/services/" />
  </main><Footer slot="footer" />
</BaseLayout>
