---
import BaseLayout from '../components/BaseLayout.astro'; import Header from '../components/Header.astro'; import Footer from '../components/Footer.astro'; import CTA from '../components/CTA.astro'; import PageIntro from '../components/PageIntro.astro'; import EditorialDepth from '../components/EditorialDepth.astro'; import { SITE_CONFIG, SERVICES } from '../utils/constants.js'; import { generateBreadcrumbSchema } from '../utils/seo.js';
const aboutDepth = {
  eyebrow:'Kepercayaan dibangun dari cara kerja',
  title:'Workshop yang baik tidak menyembunyikan keputusan penting di balik nama mesin.',
  intro:'Calon pelanggan perlu mengetahui siapa yang membaca brief, bagaimana risiko dikomunikasikan, dan kapan pekerjaan dianggap siap masuk produksi. Transparansi proses membuat hubungan kerja lebih kuat daripada klaim “paling presisi” yang tidak memiliki konteks.',
  pillars:[
    {title:'Brief dibaca sebagai fungsi',description:'Kami menanyakan bagaimana part digunakan, bagian mana yang kritis, dan proses apa yang terjadi setelah cutting. Konteks ini mencegah mesin menghasilkan bentuk yang benar tetapi tidak berguna.',evidence:'Fungsi · dimensi kritis · proses berikutnya'},
    {title:'Batasan dibicarakan sebelum produksi',description:'Material, detail terlalu kecil, potensi deformasi, bekas panas, radius tool, dan kondisi finishing dijelaskan ketika masih bisa diperbaiki pada file.',evidence:'Risiko · alternatif proses · persetujuan'},
    {title:'Hasil diperiksa terhadap brief',description:'Pemeriksaan mengikuti kebutuhan proyek: jumlah, kondisi visual, dimensi acuan, sisi kosmetik, serta kesiapan part untuk dirakit atau dipasang.',evidence:'File final · QC · serah terima'}
  ],
  checklistTitle:'Anda tidak harus percaya pada kata-kata kami saja.',
  checklistIntro:'Gunakan daftar ini untuk menilai Tepat Laser atau vendor fabrikasi mana pun secara lebih objektif.',
  checklist:['Minta penjelasan mengapa suatu mesin dan material dipilih.','Pastikan quotation menyebut scope, asumsi, material, jumlah, dan proses tambahan.','Tandai dimensi atau permukaan yang paling kritis pada drawing.','Sepakati bagaimana revisi file dan perubahan jumlah ditangani.','Konfirmasi metode pickup, packing, atau pengiriman sebelum produksi selesai.']
};
---
<BaseLayout title="Tentang Tepat Laser — Workshop Fabrikasi Presisi" description="Kenali Tepat Laser, workshop laser cutting, CNC router, dan engraving di Tangerang Selatan untuk kebutuhan proyek nyata." keywords="tentang tepat laser, workshop laser cutting tangerang selatan, jasa fabrikasi presisi" url="/about/" jsonLd={[generateBreadcrumbSchema([{name:'Beranda',url:'/'},{name:'Tentang Kami',url:'/about/'}])]}><Header slot="header" />
  <main class="overflow-hidden">
    <PageIntro
      eyebrow="Tentang Workshop Tepat Laser"
      title="Komitmen Pada Presisi, Kerapian Tepi, & Ketepatan Waktu."
      description="Presisi dimulai jauh sebelum mesin dinyalakan: saat fungsi dipahami, bahan dipilih, risiko dibaca, dan detail penting tidak dibiarkan menjadi asumsi semata."
      image="/images/v10/home-fiber-workshop-real.webp"
      imageAlt="Workshop Fabrikasi Tepat Laser Tangerang Selatan"
      imageTag="WORKSHOP & TIM ENGINEER TANGSEL"
    />
    <section class="section-padding"><div class="container-custom about-story"><div><span class="eyebrow">Cara kami bekerja</span><h2 class="heading-lg mt-6">Bukan tempat potong yang sekadar menunggu file.</h2></div><div class="space-y-6 text-lg leading-8"><p>Setiap proyek punya konteks berbeda—ada yang mengejar detail, jumlah, kekuatan, penampilan, atau jadwal pemasangan. Karena itu kami mulai dari fungsi, bukan dari mesin.</p><p>Tim teknis meninjau file, menyarankan proses, menunjukkan risiko material, dan memeriksa hasil sebelum serah terima. Tujuannya sederhana: lebih sedikit kejutan saat proyek berlanjut.</p><p>Workshop kami berada di Parigi, Bintaro, dan melayani kebutuhan interior, arsitektur, signage, manufaktur ringan, furnitur, serta prototyping di Jabodetabek.</p></div></div></section>
    <EditorialDepth {...aboutDepth} />
    <section class="about-image"><img src="/gambar/pagar-laser-cutting-landing/pintu-expanded-metal-laser-cutting.webp" alt="Detail aplikasi panel metal hasil fabrikasi" width="880" height="544" loading="lazy" decoding="async" /><div class="container-custom"><p>Ukuran yang tepat. Material yang sesuai. Hasil yang siap digunakan.</p></div></section>
    <section class="dark-section py-16 md:py-20"><div class="container-custom values-grid"><div><span class="number-tag">01</span><h3>Dengar kebutuhan</h3><p>Fungsi, ukuran, jumlah, lokasi penggunaan, dan target waktu dipetakan lebih dulu.</p></div><div><span class="number-tag">02</span><h3>Pilih jalur produksi</h3><p>Laser fiber, CO2, CNC router, atau engraving dipilih berdasarkan material dan hasil akhir.</p></div><div><span class="number-tag">03</span><h3>Jaga konsistensi</h3><p>File dan output diperiksa agar komponen datang dalam kondisi siap diteruskan.</p></div></div></section>
    <section class="section-padding"><div class="container-custom workshop-grid"><div><span class="eyebrow">Workshop</span><h2 class="heading-md mt-5">Datang, kirim file, atau mulai lewat WhatsApp.</h2></div><div class="workshop-cards"><div><span>Alamat</span><p>{SITE_CONFIG.address}</p></div><div><span>Jam kerja</span><p>{SITE_CONFIG.businessHours}</p></div><div><span>Kontak</span><p><a href={`tel:${SITE_CONFIG.phone}`}>{SITE_CONFIG.phone}</a><br /><a href={`mailto:${SITE_CONFIG.email}`}>{SITE_CONFIG.email}</a></p></div><div><span>Fokus</span><p>{SERVICES.map((service) => service.name).join(' · ')}</p></div></div></div></section>
    <CTA title="Punya brief yang perlu dibaca bersama?" primaryText="Hubungi Tepat Laser" secondaryText="Lihat layanan" secondaryLink="/services/" />
  </main><Footer slot="footer" />
</BaseLayout>
<style>
  .about-story{display:grid;gap:3rem}.about-image{position:relative;min-height:34rem;overflow:hidden;background:#050906}.about-image img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}.about-image::after{position:absolute;inset:0;content:'';background:linear-gradient(to top,rgba(5,9,6,.86),transparent 55%)}.about-image>div{position:absolute;z-index:1;right:0;bottom:2rem;left:0}.about-image p{max-width:38rem;color:#fff;font-family:'Clash Display',sans-serif;font-size:clamp(2rem,4vw,3.5rem);font-weight:600;line-height:1;letter-spacing:-.04em}
  .values-grid{display:grid;gap:2rem}.values-grid h3{margin-top:2.5rem;font-size:1.7rem}.values-grid p{margin-top:.8rem;font-size:.92rem;line-height:1.7}.workshop-grid{display:grid;gap:2.5rem}.workshop-cards{display:grid;gap:1px;border:1px solid var(--line);background:var(--line)}.workshop-cards>div{background:var(--surface);padding:1.4rem}.workshop-cards span{color:var(--laser-deep);font-size:.75rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase}.workshop-cards p{margin-top:1rem;font-size:.9rem;line-height:1.7}
  @media(min-width:800px){.about-story{grid-template-columns:.85fr 1.15fr}.values-grid{grid-template-columns:repeat(3,minmax(0,1fr))}.values-grid>div+div{border-left:1px solid rgba(255,255,255,.16);padding-left:2rem}.workshop-grid{grid-template-columns:.8fr 1.2fr}.workshop-cards{grid-template-columns:repeat(2,minmax(0,1fr))}}
</style>
