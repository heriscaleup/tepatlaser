---
import BaseLayout from '../components/BaseLayout.astro'; import Header from '../components/Header.astro'; import Footer from '../components/Footer.astro'; import CTA from '../components/CTA.astro'; import PageIntro from '../components/PageIntro.astro'; import { FAQ } from '../utils/constants.js'; import { generateFAQSchema, generateBreadcrumbSchema } from '../utils/seo.js';
const breadcrumb = generateBreadcrumbSchema([{name:'Beranda',url:'/'},{name:'FAQ',url:'/faq/'}]);
const extra = {question:'Format file apa yang paling cepat diproses?',answer:'DXF, DWG, AI, CDR, SVG, atau PDF vektor dengan skala 1:1. Jika belum punya file final, kirim sketsa atau referensi untuk peninjauan awal.'};
---
<BaseLayout title="FAQ Tepat Laser — Pertanyaan Teknis Laser Cutting" description="Jawaban praktis seputar material, file desain, kapasitas mesin, biaya, lead time, dan pengiriman Tepat Laser." keywords="FAQ laser cutting, ketentuan potong laser, format file DXF, harga laser cutting" url="/faq/" jsonLd={[breadcrumb,generateFAQSchema([...FAQ,extra])]}><Header slot="header" />
  <main class="overflow-hidden"><PageIntro eyebrow="Pertanyaan umum" title="Pastikan detail sebelum produksi." description="Jawaban ringkas mengenai file, material, biaya, kapasitas, dan waktu pengerjaan agar komunikasi awal lebih efisien." />
    <section class="section-padding"><div class="container-custom faq-list">{[...FAQ,extra].map((faq,index) => <details open={index===0}><summary><span class="number-tag">0{index+1}</span><strong>{faq.question}</strong><i>＋</i></summary><p>{faq.answer}</p></details>)}</div></section>
    <CTA title="Masih ada detail yang perlu dipastikan?" primaryText="Tanya tim teknis" secondaryText="Lihat proses produksi" secondaryLink="/proses-produksi-lead-time/" />
  </main><Footer slot="footer" />
</BaseLayout>
<style>
  .faq-list{max-width:58rem}.faq-list details{border-top:1px solid var(--line)}.faq-list details:last-child{border-bottom:1px solid var(--line)}.faq-list summary{display:grid;grid-template-columns:2.5rem 1fr auto;align-items:center;gap:1rem;cursor:pointer;list-style:none;padding:1.35rem 0}.faq-list summary::-webkit-details-marker{display:none}.faq-list summary strong{font-family:'Clash Display',sans-serif;font-size:clamp(1.1rem,2.2vw,1.5rem);font-weight:600;letter-spacing:-.02em}.faq-list summary i{color:var(--laser);font-size:1.4rem;font-style:normal;transition:transform .2s ease}.faq-list details[open] summary i{transform:rotate(45deg)}.faq-list details>p{max-width:47rem;padding:0 0 1.5rem 3.5rem;font-size:.9rem;line-height:1.8}
</style>
