---
import BaseLayout from '../components/BaseLayout.astro'; import Header from '../components/Header.astro'; import Footer from '../components/Footer.astro'; import CTA from '../components/CTA.astro'; import { FAQ } from '../utils/constants.js'; import { generateFAQSchema, generateBreadcrumbSchema } from '../utils/seo.js';
const breadcrumb = generateBreadcrumbSchema([{name:'Beranda',url:'/'},{name:'FAQ',url:'/faq/'}]);
---
<BaseLayout title="FAQ Tepat Laser — Pertanyaan Teknis Laser Cutting" description="Jawaban praktis seputar material, file desain, kapasitas mesin, biaya, lead time, dan pengiriman Tepat Laser." keywords="FAQ laser cutting, ketentuan potong laser, format file DXF, harga laser cutting" url="/faq/" jsonLd={[breadcrumb,generateFAQSchema(FAQ)]}><Header slot="header" />
  <main class="overflow-hidden"><section class="border-b border-[var(--line)] pt-40 pb-20"><div class="container-custom grid gap-10 lg:grid-cols-[1fr_.7fr] lg:items-end"><div><span class="eyebrow">FAQ / Technical notes</span><h1 class="heading-xl mt-7">Before we<br /><span class="text-[var(--acid)]">cut.</span></h1></div><p class="max-w-xl text-lg leading-8">Jawaban singkat untuk mengurangi bolak-balik sebelum file Anda masuk ke lantai produksi.</p></div></section><section class="section-padding"><div class="container-custom max-w-4xl space-y-3">{FAQ.map((faq,index) => <details class="group border border-[var(--line)] bg-[var(--panel)] p-6" open={index === 0}><summary class="flex cursor-pointer list-none items-center justify-between gap-6 text-lg font-bold text-[var(--paper)]"><span><span class="mr-4 font-mono text-xs text-[var(--acid)]">0{index+1}</span>{faq.question}</span><span class="text-2xl text-[var(--acid)] transition-transform group-open:rotate-45">＋</span></summary><p class="mt-5 max-w-3xl border-t border-[var(--line)] pt-5 text-sm leading-7">{faq.answer}</p></details>)}<details class="group border border-[var(--line)] bg-[var(--panel)] p-6"><summary class="flex cursor-pointer list-none items-center justify-between gap-6 text-lg font-bold text-[var(--paper)]"><span><span class="mr-4 font-mono text-xs text-[var(--acid)]">06</span>File apa yang paling cepat diproses?</span><span class="text-2xl text-[var(--acid)] transition-transform group-open:rotate-45">＋</span></summary><p class="mt-5 border-t border-[var(--line)] pt-5 text-sm leading-7">DXF, DWG, AI, CDR, SVG, atau PDF vector dengan skala 1:1. Jika belum punya file final, kirim sketsa atau referensinya untuk review awal.</p></details></div></section><CTA title="Masih ada yang perlu dipastikan?" primaryText="Tanya tim teknis" secondaryText="Lihat proses produksi" secondaryLink="/proses-produksi-lead-time/" /></main><Footer slot="footer" />
</BaseLayout>
