---
import BaseLayout from '../components/BaseLayout.astro'; import Header from '../components/Header.astro'; import Footer from '../components/Footer.astro'; import CTA from '../components/CTA.astro'; import PageIntro from '../components/PageIntro.astro'; import { generateBreadcrumbSchema } from '../utils/seo.js';
const schema = generateBreadcrumbSchema([{name:'Beranda',url:'/'},{name:'Portofolio',url:'/portfolio/'}]);
const projects = [
 {title:'Pagar panel geometris',category:'Eksterior',material:'Panel metal',process:'Laser cutting',image:'/gambar/pagar-laser-cutting-landing/hero-pagar-laser-cutting.webp',desc:'Pola laser cutting memberi privasi, ritme visual, dan identitas pada fasad rumah.'},
 {title:'Reling tangga berpola',category:'Interior',material:'Panel metal',process:'Cutting & finishing',image:'/gambar/railing-laser-cutting-landing/reling-tangga-daylight.webp',desc:'Panel dekoratif berfungsi sebagai pengaman sekaligus elemen pembentuk cahaya.'},
 {title:'Fasad panel custom',category:'Arsitektur',material:'Panel eksterior',process:'CNC / cutting',image:'/gambar/pagar-laser-cutting-landing/facade-laser-cutting.webp',desc:'Panel modular membentuk ritme fasad tanpa menghilangkan karakter bangunan.'},
 {title:'Pintu panel geometris',category:'Eksterior',material:'Panel metal',process:'Cutting & fabrikasi',image:'/gambar/pagar-laser-cutting-landing/galeri-pintu-gerbang-laser-cutting.webp',desc:'Pintu panel dengan pola terukur untuk privasi, ventilasi, dan tampilan yang tetap bersih.'},
 {title:'Panel ACP beralur',category:'Fasad & signage',material:'ACP',process:'CNC router',image:'/images/acppro (3).webp',desc:'Alur dan kontur panel direncanakan dari file agar sambungan serta arah lipatan lebih mudah dikendalikan.'},
 {title:'Display akrilik custom',category:'Retail',material:'Akrilik',process:'Laser CO₂',image:'/images/displyacrylic.webp',desc:'Komponen display dipotong dari file vektor untuk menjaga konsistensi ukuran pada unit yang berulang.'},
 {title:'Komponen stainless',category:'Metalwork',material:'Stainless steel',process:'Laser fiber',image:'/images/stainlesssteel (3).webp',desc:'Geometri komponen metal disiapkan untuk kebutuhan fabrikasi lanjutan, perakitan, atau pemasangan.'},
 {title:'Signage dan identitas ruang',category:'Komersial',material:'Multi-material',process:'Cutting & assembly',image:'/images/singagehote.webp',desc:'Elemen huruf dan bidang identitas disusun dengan mempertimbangkan skala baca, mounting, dan finishing.'}
];
---
<BaseLayout title="Portofolio Tepat Laser — Hasil Fabrikasi Presisi" description="Eksplorasi aplikasi laser cutting untuk pagar, railing, fasad, panel interior, dan kebutuhan arsitektural custom." keywords="portfolio laser cutting, pagar laser cutting, railing custom, panel arsitektur" url="/portfolio/" image={projects[0].image} jsonLd={[schema]}><Header slot="header" />
  <main class="overflow-hidden">
    <PageIntro
      eyebrow="Galeri aplikasi produksi"
      title="Referensi Bentuk, Material, & Cara Hasil Digunakan."
      description="Galeri ini membantu membaca kemungkinan aplikasi. Spesifikasi akhir tetap ditentukan dari ukuran, material, struktur, finishing, dan kondisi pemasangan proyek Anda."
      image="/gambar/pagar-laser-cutting-landing/fasad-gedung-laser-cutting.webp"
      imageAlt="Dokumentasi Hasil Proyek Tepat Laser"
      imageTag="REFERENSI APLIKASI TEPAT LASER"
    />
    <section class="portfolio-brief"><div class="container-custom"><div><span>01</span><strong>Lihat fungsi</strong><p>Apakah bidang berperan sebagai pagar, fasad, railing, display, signage, atau komponen.</p></div><div><span>02</span><strong>Catat material</strong><p>Material memengaruhi mesin, detail minimum, struktur, finishing, dan perawatan.</p></div><div><span>03</span><strong>Bawa konteks</strong><p>Foto lokasi, ukuran bidang, referensi pola, dan cara pemasangan mempercepat review.</p></div></div></section>
    <section class="section-padding"><div class="container-custom portfolio-grid">{projects.map((project,index) => <article class:list={["portfolio-card",index===0&&"portfolio-featured"]}><div class="portfolio-media"><img src={project.image} alt={project.title} width="1200" height="800" loading="lazy" decoding="async" /></div><div class="portfolio-copy"><span>{project.category}</span><h2>{project.title}</h2><p>{project.desc}</p><div><small>{project.material}</small><small>{project.process}</small></div></div></article>)}</div></section>
    <section class="dark-section section-padding"><div class="container-custom portfolio-note"><div><span class="eyebrow">Dari referensi ke file kerja</span><h2 class="heading-md mt-5">Gambar yang Anda sukai belum otomatis menjadi desain yang aman diproduksi.</h2></div><div><p>Tim meninjau skala pola, jarak antarlubang, tepi material, pembagian panel, titik sambungan, kebutuhan rangka, serta finishing. Hasil review tersebut menjadi dasar file produksi dan penawaran.</p><a href="/proses-produksi-lead-time/" class="btn-secondary">Pelajari alur produksi <span>→</span></a></div></div></section>
    <CTA title="Punya ide yang harus terlihat bagus sekaligus bekerja benar?" description="Kirim ukuran, referensi pola, material, dan konteks pemasangan. Kami bantu membaca risiko serta rute produksinya." primaryText="Mulai konsultasi" secondaryText="Lihat layanan" secondaryLink="/services/" />
  </main><Footer slot="footer" />
</BaseLayout>
<style>
  .portfolio-brief{border-block:1px solid var(--line);background:var(--surface);padding-block:2.25rem}.portfolio-brief>div{display:grid;gap:1.5rem}.portfolio-brief span{color:var(--laser);font-size:.75rem;font-weight:800}.portfolio-brief strong{display:block;margin-top:.45rem;color:#fff;font-family:'Clash Display',sans-serif;font-size:1.15rem}.portfolio-brief p{margin-top:.35rem;font-size:.88rem;line-height:1.65}
  .portfolio-grid{display:grid;gap:1rem}.portfolio-card{overflow:hidden;border:1px solid var(--line);background:var(--surface);transition:transform .45s var(--ease-smooth),border-color .45s var(--ease-smooth)}.portfolio-card:hover{border-color:var(--laser);transform:translateY(-6px)}.portfolio-media{aspect-ratio:1.2;overflow:hidden;background:#050906}.portfolio-media img{width:100%;height:100%;object-fit:cover;filter:saturate(.75);transition:transform .7s var(--ease-smooth),filter .7s var(--ease-smooth)}.portfolio-card:hover img{transform:scale(1.05);filter:saturate(1)}.portfolio-copy{padding:1.4rem}.portfolio-copy>span{color:var(--laser-deep);font-size:.75rem;font-weight:800;letter-spacing:.11em;text-transform:uppercase}.portfolio-copy h2{margin-top:.8rem;font-size:1.65rem}.portfolio-copy p{margin-top:.7rem;font-size:.9rem;line-height:1.7}.portfolio-copy>div{display:flex;flex-wrap:wrap;gap:.5rem 1rem;margin-top:1.2rem;border-top:1px solid var(--line);padding-top:1rem;color:var(--muted);font-size:.75rem;font-weight:700;text-transform:uppercase}
  .portfolio-note{display:grid;gap:2.5rem}.portfolio-note>div:last-child{align-self:end}.portfolio-note p{max-width:40rem;font-size:1rem;line-height:1.8}.portfolio-note .btn-secondary{margin-top:1.5rem}
  @media(min-width:760px){.portfolio-brief>div{grid-template-columns:repeat(3,minmax(0,1fr))}.portfolio-brief>div>div+div{border-left:1px solid var(--line);padding-left:1.5rem}.portfolio-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.portfolio-featured{grid-column:span 2}.portfolio-featured .portfolio-media{aspect-ratio:2.05}.portfolio-featured .portfolio-copy{display:grid;grid-template-columns:1fr 1fr;align-items:end;gap:1rem}.portfolio-featured .portfolio-copy>span{grid-column:1/-1}.portfolio-featured .portfolio-copy h2{font-size:2.2rem}.portfolio-featured .portfolio-copy p{margin-top:0}.portfolio-note{grid-template-columns:1fr 1fr}}
</style>
