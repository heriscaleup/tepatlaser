---
import BaseLayout from '../components/BaseLayout.astro'; import Header from '../components/Header.astro'; import Footer from '../components/Footer.astro'; import CTA from '../components/CTA.astro'; import PageIntro from '../components/PageIntro.astro'; import { generateBreadcrumbSchema } from '../utils/seo.js';
const schema = generateBreadcrumbSchema([{name:'Beranda',url:'/'},{name:'Portofolio',url:'/portfolio/'}]);
const projects = [
 {title:'Pagar panel geometris',category:'Eksterior',material:'Panel metal',process:'Laser cutting',image:'/gambar/pagar-laser-cutting-landing/hero-pagar-laser-cutting.webp',desc:'Pola laser cutting memberi privasi, ritme visual, dan identitas pada fasad rumah.'},
 {title:'Reling tangga berpola',category:'Interior',material:'Panel metal',process:'Cutting & finishing',image:'/gambar/railing-laser-cutting-landing/reling-tangga-daylight.webp',desc:'Panel dekoratif berfungsi sebagai pengaman sekaligus elemen pembentuk cahaya.'},
 {title:'Layar dekoratif tangga',category:'Interior',material:'Metal',process:'Laser cutting',image:'/gambar/railing-laser-cutting-landing/reling-tangga-moody-lattice.webp',desc:'Motif rapat menciptakan bayangan dan privasi tanpa menutup ruang sepenuhnya.'},
 {title:'Fasad panel custom',category:'Arsitektur',material:'Panel eksterior',process:'CNC / cutting',image:'/gambar/pagar-laser-cutting-landing/fasad-gedung-laser-cutting.webp',desc:'Panel disusun modular agar pola tetap terbaca pada skala bangunan.'},
 {title:'Pintu expanded metal',category:'Eksterior',material:'Expanded metal',process:'Cutting & fabrikasi',image:'/gambar/pagar-laser-cutting-landing/pintu-expanded-metal-laser-cutting.webp',desc:'Solusi pintu dengan karakter industrial, ventilasi, dan struktur yang tegas.'},
 {title:'Panel railing custom',category:'Arsitektur',material:'Plat metal',process:'Laser cutting',image:'/gambar/pagar-laser-cutting-landing/reling-tangga-laser-cutting.webp',desc:'Pola disesuaikan dengan ukuran bidang, jarak struktur, dan konteks pemasangan.'}
];
---
<BaseLayout title="Portofolio Tepat Laser — Hasil Fabrikasi Presisi" description="Eksplorasi aplikasi laser cutting untuk pagar, railing, fasad, panel interior, dan kebutuhan arsitektural custom." keywords="portfolio laser cutting, pagar laser cutting, railing custom, panel arsitektur" url="/portfolio/" image={projects[0].image} jsonLd={[schema]}><Header slot="header" />
  <main class="overflow-hidden"><PageIntro eyebrow="Pilihan aplikasi" title="Dibuat agar menyatu dengan ruang." description="Contoh aplikasi panel dan komponen custom yang menunjukkan bagaimana pola, material, ukuran, dan finishing bekerja bersama." />
    <section class="section-padding"><div class="container-custom portfolio-grid">{projects.map((project,index) => <article class:list={["portfolio-card",index===0&&"portfolio-featured"]}><div class="portfolio-media"><img src={project.image} alt={project.title} width="1200" height="800" loading={index<2?'eager':'lazy'} decoding="async" /></div><div class="portfolio-copy"><span>{project.category}</span><h2>{project.title}</h2><p>{project.desc}</p><div><small>{project.material}</small><small>{project.process}</small></div></div></article>)}</div></section>
    <CTA title="Punya bidang atau komponen yang ingin dibuat?" description="Kirim ukuran, referensi pola, material, dan konteks pemasangan. Kami bantu membaca rute produksinya." primaryText="Mulai konsultasi" secondaryText="Lihat layanan" secondaryLink="/services/" />
  </main><Footer slot="footer" />
</BaseLayout>
<style>
  .portfolio-grid{display:grid;gap:1rem}.portfolio-card{overflow:hidden;border:1px solid var(--line);background:var(--surface);transition:transform .45s var(--ease),border-color .45s var(--ease)}.portfolio-card:hover{border-color:var(--laser);transform:translateY(-6px)}.portfolio-media{aspect-ratio:1.2;overflow:hidden;background:#050906}.portfolio-media img{width:100%;height:100%;object-fit:cover;filter:saturate(.75);transition:transform .7s var(--ease),filter .7s var(--ease)}.portfolio-card:hover img{transform:scale(1.05);filter:saturate(1)}.portfolio-copy{padding:1.4rem}.portfolio-copy>span{color:var(--laser-deep);font-size:.64rem;font-weight:800;letter-spacing:.12em;text-transform:uppercase}.portfolio-copy h2{margin-top:.8rem;font-size:1.65rem}.portfolio-copy p{margin-top:.7rem;font-size:.8rem;line-height:1.7}.portfolio-copy>div{display:flex;flex-wrap:wrap;gap:.5rem 1rem;margin-top:1.2rem;border-top:1px solid var(--line);padding-top:1rem;color:var(--muted);font-size:.62rem;font-weight:700;text-transform:uppercase}
  @media(min-width:760px){.portfolio-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.portfolio-featured{grid-column:span 2}.portfolio-featured .portfolio-media{aspect-ratio:2.05}.portfolio-featured .portfolio-copy{display:grid;grid-template-columns:1fr 1fr;align-items:end;gap:1rem}.portfolio-featured .portfolio-copy>span{grid-column:1/-1}.portfolio-featured .portfolio-copy h2{font-size:2.2rem}.portfolio-featured .portfolio-copy p{margin-top:0}}
</style>
