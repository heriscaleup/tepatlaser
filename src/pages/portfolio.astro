---
import BaseLayout from '../components/BaseLayout.astro'; import Header from '../components/Header.astro'; import Footer from '../components/Footer.astro'; import CTA from '../components/CTA.astro'; import PageIntro from '../components/PageIntro.astro'; import EditorialDepth from '../components/EditorialDepth.astro'; import { generateBreadcrumbSchema } from '../utils/seo.js';
import { PORTFOLIO_PROJECTS_V10 as projects } from '../data/portfolioProjects.js';
const schema = generateBreadcrumbSchema([{name:'Beranda',url:'/'},{name:'Portofolio',url:'/portfolio/'}]);
const portfolioDepth = {
 eyebrow:'Cara membaca referensi',
 title:'Portofolio yang berguna membantu mengambil keputusan, bukan hanya mengumpulkan foto bagus.',
 intro:'Satu tampilan dapat dicapai melalui kombinasi material, ketebalan, struktur, finishing, dan pemasangan yang berbeda. Gunakan galeri sebagai titik diskusi visual, lalu ukur keputusan teknisnya terhadap kondisi proyek Anda.',
 pillars:[
  {title:'Pisahkan tampilan dan konstruksi',description:'Motif yang sama dapat dipasang sebagai panel tunggal, modul berangka, railing, secondary skin, atau lapisan dekoratif. Struktur di belakang foto sama pentingnya dengan pola di depan.',evidence:'Pola · rangka · fixing'},
  {title:'Baca skala dan jarak pandang',description:'Detail yang terlihat proporsional pada foto dekat bisa hilang pada fasad atau terlalu padat pada bidang kecil. Ukuran nyata menentukan kepadatan desain.',evidence:'Ukuran bidang · jarak baca'},
  {title:'Tanyakan proses setelah cutting',description:'Deburring, bending, welding, coating, lampu, assembly, packing, dan pemasangan sering menentukan sebagian besar kualitas akhir.',evidence:'Finishing · assembly · instalasi'}
 ],
 checklistTitle:'Data yang mengubah inspirasi menjadi brief produksi.',
 checklistIntro:'Semakin jelas konteksnya, semakin kecil kemungkinan referensi visual diterjemahkan secara keliru.',
 checklist:['Foto bidang dari depan dan sudut yang menunjukkan kondisi sekeliling.','Ukuran total, pembagian panel, serta posisi pintu atau bukaan.','Referensi motif dengan penjelasan bagian yang disukai.','Kebutuhan privasi, ventilasi, cahaya, keamanan, dan perawatan.','Target material, warna, anggaran, lokasi, serta waktu pemasangan.']
};
---
<BaseLayout title="Portofolio Tepat Laser — Hasil Fabrikasi Presisi" description="Eksplorasi aplikasi laser cutting untuk pagar, railing, fasad, panel interior, dan kebutuhan arsitektural custom." keywords="portfolio laser cutting, pagar laser cutting, railing custom, panel arsitektur" url="/portfolio/" image={projects[0].image} jsonLd={[schema]}><Header slot="header" />
  <main class="overflow-hidden">
    <PageIntro
      eyebrow="Galeri aplikasi produksi"
      title="Referensi Bentuk, Material, & Cara Hasil Digunakan."
      description="Galeri ini membantu membaca kemungkinan aplikasi. Spesifikasi akhir tetap ditentukan dari ukuran, material, struktur, finishing, dan kondisi pemasangan proyek Anda."
      image="/gambar/pagar-laser-cutting-landing/fasad-gedung-laser-cutting.webp"
      imageAlt="Dokumentasi Hasil Proyek Tepat Laser"
      imageTag="REFERENSI APLIKASI TEPAT LASER"
    />
    <section class="portfolio-brief"><div class="container-custom"><div><span>01</span><strong>Lihat fungsi</strong><p>Apakah bidang berperan sebagai pagar, fasad, railing, display, signage, atau komponen.</p></div><div><span>02</span><strong>Catat material</strong><p>Material memengaruhi mesin, detail minimum, struktur, finishing, dan perawatan.</p></div><div><span>03</span><strong>Bawa konteks</strong><p>Foto lokasi, ukuran bidang, referensi pola, dan cara pemasangan mempercepat review.</p></div></div></section>
    <section class="section-padding"><div class="container-custom portfolio-grid">{projects.map((project,index) => <a href={`/portfolio/${project.slug}/`} class:list={["portfolio-card",index===0&&"portfolio-featured"]} aria-label={`Buka detail portofolio ${project.title}`}><div class="portfolio-media"><img src={project.image} alt={project.title} width="1200" height="800" loading="lazy" decoding="async" /></div><div class="portfolio-copy"><span>{project.category}</span><h2>{project.title}</h2><p>{project.desc}</p><div><small>{project.material}</small><small>{project.process}</small><strong>Lihat studi aplikasi ↗</strong></div></div></a>)}</div></section>
    <EditorialDepth {...portfolioDepth} />
    <section class="dark-section section-padding"><div class="container-custom portfolio-note"><div><span class="eyebrow">Dari referensi ke file kerja</span><h2 class="heading-md mt-5">Gambar yang Anda sukai belum otomatis menjadi desain yang aman diproduksi.</h2></div><div><p>Tim meninjau skala pola, jarak antarlubang, tepi material, pembagian panel, titik sambungan, kebutuhan rangka, serta finishing. Hasil review tersebut menjadi dasar file produksi dan penawaran.</p><a href="/proses-produksi-lead-time/" class="btn-secondary">Pelajari alur produksi <span>→</span></a></div></div></section>
    <CTA title="Punya ide yang harus terlihat bagus sekaligus bekerja benar?" description="Kirim ukuran, referensi pola, material, dan konteks pemasangan. Kami bantu membaca risiko serta rute produksinya." primaryText="Mulai konsultasi" secondaryText="Lihat layanan" secondaryLink="/services/" />
  </main><Footer slot="footer" />
</BaseLayout>
<style>
  .portfolio-brief{border-block:1px solid var(--line);background:var(--surface);padding-block:2.25rem}.portfolio-brief>div{display:grid;gap:1.5rem}.portfolio-brief span{color:var(--laser);font-size:.75rem;font-weight:800}.portfolio-brief strong{display:block;margin-top:.45rem;color:#fff;font-family:'Clash Display',sans-serif;font-size:1.15rem}.portfolio-brief p{margin-top:.35rem;font-size:.88rem;line-height:1.65}
  .portfolio-grid{display:grid;gap:1rem}.portfolio-card{display:block;overflow:hidden;border:1px solid var(--line);background:var(--surface);transition:transform .45s var(--ease-smooth),border-color .45s var(--ease-smooth),box-shadow .45s var(--ease-smooth)}.portfolio-card:hover,.portfolio-card:focus-visible{border-color:var(--laser);transform:translateY(-6px);box-shadow:0 1.25rem 3rem rgba(0,0,0,.24)}.portfolio-media{aspect-ratio:1.2;overflow:hidden;background:#050906}.portfolio-media img{width:100%;height:100%;object-fit:cover;filter:saturate(.75);transition:transform .7s var(--ease-smooth),filter .7s var(--ease-smooth)}.portfolio-card:hover img,.portfolio-card:focus-visible img{transform:scale(1.05);filter:saturate(1)}.portfolio-copy{padding:1.4rem}.portfolio-copy>span{color:var(--laser-deep);font-size:.75rem;font-weight:800;letter-spacing:.11em;text-transform:uppercase}.portfolio-copy h2{margin-top:.8rem;font-size:1.65rem}.portfolio-copy p{margin-top:.7rem;font-size:.9rem;line-height:1.7}.portfolio-copy>div{display:flex;flex-wrap:wrap;align-items:center;gap:.5rem 1rem;margin-top:1.2rem;border-top:1px solid var(--line);padding-top:1rem;color:var(--muted);font-size:.75rem;font-weight:700;text-transform:uppercase}.portfolio-copy strong{margin-left:auto;color:var(--brand-gold-soft);font-size:.75rem}
  .portfolio-note{display:grid;gap:2.5rem}.portfolio-note>div:last-child{align-self:end}.portfolio-note p{max-width:40rem;font-size:1rem;line-height:1.8}.portfolio-note .btn-secondary{margin-top:1.5rem}
  @media(min-width:760px){.portfolio-brief>div{grid-template-columns:repeat(3,minmax(0,1fr))}.portfolio-brief>div>div+div{border-left:1px solid var(--line);padding-left:1.5rem}.portfolio-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.portfolio-featured{grid-column:span 2}.portfolio-featured .portfolio-media{aspect-ratio:2.05}.portfolio-featured .portfolio-copy{display:grid;grid-template-columns:1fr 1fr;align-items:end;gap:1rem}.portfolio-featured .portfolio-copy>span{grid-column:1/-1}.portfolio-featured .portfolio-copy h2{font-size:2.2rem}.portfolio-featured .portfolio-copy p{margin-top:0}.portfolio-note{grid-template-columns:1fr 1fr}}
</style>
