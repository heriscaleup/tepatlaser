---
import BaseLayout from '../components/BaseLayout.astro'; import Header from '../components/Header.astro'; import Footer from '../components/Footer.astro'; import CTA from '../components/CTA.astro'; import { PORTFOLIO_PROJECTS } from '../utils/constants.js'; import { generateBreadcrumbSchema } from '../utils/seo.js';
const schema = generateBreadcrumbSchema([{name:'Beranda',url:'/'},{name:'Portfolio',url:'/portfolio/'}]);
---
<BaseLayout title="Portfolio Tepat Laser — Hasil Fabrikasi Presisi" description="Eksplorasi hasil laser cutting metal, engraving, akrilik, dan CNC router Tepat Laser." keywords="portfolio laser cutting, hasil kerja tepat laser, contoh fabrikasi presisi" url="/portfolio/" jsonLd={[schema]}><Header slot="header" />
  <main class="overflow-hidden"><section class="border-b border-[var(--line)] pt-40 pb-20"><div class="container-custom grid gap-10 lg:grid-cols-[1fr_.7fr] lg:items-end"><div><span class="eyebrow">Selected output / 2026</span><h1 class="heading-xl mt-7">Made to<br /><span class="text-[var(--acid)]">fit.</span></h1></div><p class="max-w-xl text-lg leading-8">Potongan, marking, dan komponen yang dibuat untuk benar-benar masuk ke project: terukur, rapi, dan siap dilanjutkan ke tahap berikutnya.</p></div></section>
    <section class="section-padding"><div class="container-custom grid gap-5 md:grid-cols-12">{PORTFOLIO_PROJECTS.map((project,index) => <article class:list={["group relative overflow-hidden border border-[var(--line)] bg-[var(--panel)]", index === 0 ? "md:col-span-7 md:row-span-2" : "md:col-span-5"]}><div class="overflow-hidden"><img src={project.image} alt={project.title} width="1200" height="800" class="h-full min-h-72 w-full object-cover opacity-85 transition duration-700 group-hover:scale-105" loading="lazy" decoding="async" /></div><div class="border-t border-[var(--line)] p-6"><span class="eyebrow">{project.category}</span><h2 class="mt-4 text-2xl">{project.title}</h2><p class="mt-3 text-sm leading-7">{project.description}</p><div class="mt-6 grid gap-2 border-t border-[var(--line)] pt-4 font-mono text-[.6rem] uppercase tracking-[.1em] text-[var(--muted)] sm:grid-cols-3"><span>{project.material}</span><span>{project.technique}</span><span>{project.client}</span></div></div></article>)}</div></section><CTA title="Punya output yang ingin dibuat?" description="Kirim sketsa atau file kerja Anda, lalu kita susun jalur produksi yang masuk akal." primaryText="Mulai konsultasi" secondaryText="Lihat layanan" secondaryLink="/services/" />
  </main><Footer slot="footer" />
</BaseLayout>
