---
import BaseLayout from '../components/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { SITE_CONFIG } from '../utils/constants.js';
import { generateFAQSchema, generateBreadcrumbSchema } from '../utils/seo.js';

const WA_NUMBER = SITE_CONFIG.whatsapp;

const WA_MESSAGES = {
  industri: encodeURIComponent("Halo Tepat Laser, saya butuh laser cutting stainless untuk kebutuhan industri/produksi. Bisa info harga dan kapasitas?"),
  interior: encodeURIComponent("Halo Tepat Laser, saya mau konsultasi laser cutting stainless untuk interior/ornamen/railing. Bisa bantu?"),
  umkm: encodeURIComponent("Halo Tepat Laser, saya mau tanya harga laser cutting stainless satuan. Bisa kasih estimasi?"),
  default: encodeURIComponent("Halo Tepat Laser, saya tertarik dengan jasa laser cutting stainless. Bisa konsultasi gratis?"),
};

const faqs = [
  {
    question: "Berapa harga laser cutting stainless steel per meter?",
    answer: "Harga laser cutting stainless bergantung pada ketebalan dan kompleksitas desain. Estimasi mulai Rp 15.000–Rp 80.000 per meter untuk ketebalan 1–3mm. Hubungi kami via WhatsApp untuk quote akurat sesuai file desain Anda — gratis dan tanpa komitmen."
  },
  {
    question: "Grade stainless apa saja yang bisa dikerjakan?",
    answer: "Kami mengerjakan SS201 (ekonomis, untuk interior ringan), SS304 (standar industri, tahan karat umum), dan SS316 (marine grade, tahan lingkungan agresif dan pesisir). Semua grade tersedia dalam finishing hairline, mirror, dan doff."
  },
  {
    question: "Berapa ketebalan maksimum stainless yang bisa dipotong?",
    answer: "Mesin laser fiber kami mampu memotong stainless steel hingga ketebalan 10mm. Ketebalan umum yang kami kerjakan: 0.5mm, 1mm, 1.5mm, 2mm, 3mm, 4mm, 6mm, 8mm, dan 10mm."
  },
  {
    question: "Apakah ada minimum order?",
    answer: "Tidak ada minimum order. Kami melayani dari 1 lembar/piece hingga produksi massal. Untuk order satuan, harga per unit menyesuaikan kompleksitas desain dan material yang digunakan."
  },
  {
    question: "Format file desain apa yang diterima?",
    answer: "Kami menerima file DXF, DWG (AutoCAD), AI (Adobe Illustrator), CDR (CorelDraw), SVG, dan PDF vector. Tidak punya file teknis? Kami bisa bantu konversi dari foto/gambar dengan biaya konversi yang transparan."
  },
  {
    question: "Berapa lama waktu pengerjaan laser cutting stainless?",
    answer: "Standar: 1–3 hari kerja setelah desain disetujui. Layanan express tersedia untuk project kecil dengan pengerjaan di hari yang sama (4–8 jam, konfirmasi availability via WhatsApp)."
  },
  {
    question: "Apakah melayani pengiriman luar Jabodetabek?",
    answer: "Ya, kami melayani pengiriman ke seluruh Indonesia via JNE, J&T, SiCepat, dan ekspedisi kargo untuk order besar. Pengiriman gratis untuk area Tangerang Selatan dan sekitar Bintaro."
  }
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Jasa Laser Cutting Stainless Steel",
  "serviceType": "Laser Cutting Stainless Steel",
  "description": "Jasa laser cutting stainless steel SS201, SS304, SS316 dengan toleransi ±0.02mm. Melayani Jabodetabek dengan pengerjaan express 1–3 hari kerja. Hairline, mirror, doff tersedia.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Tepat Laser",
    "telephone": SITE_CONFIG.phone,
    "email": SITE_CONFIG.email,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Jl. Bintaro BSD No 1D",
      "addressLocality": "Tangerang Selatan",
      "addressRegion": "Banten",
      "addressCountry": "ID"
    }
  },
  "areaServed": [
    { "@type": "City", "name": "Jakarta" },
    { "@type": "City", "name": "Tangerang" },
    { "@type": "City", "name": "Depok" },
    { "@type": "City", "name": "Bekasi" },
    { "@type": "City", "name": "Bogor" }
  ],
  "offers": {
    "@type": "Offer",
    "priceCurrency": "IDR",
    "priceSpecification": {
      "@type": "UnitPriceSpecification",
      "price": "15000",
      "priceCurrency": "IDR",
      "referenceQuantity": { "@type": "QuantitativeValue", "value": "1", "unitCode": "MTR" }
    },
    "availability": "https://schema.org/InStock"
  }
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Tepat Laser",
  "image": `${SITE_CONFIG.url}/images/metal.webp`,
  "telephone": SITE_CONFIG.phone,
  "email": SITE_CONFIG.email,
  "url": `${SITE_CONFIG.url}/jasa-laser-cutting-stainless/`,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Jl. Bintaro BSD No 1D, Samping SD Mentari Internasional School",
    "addressLocality": "Tangerang Selatan",
    "addressRegion": "Banten",
    "postalCode": "15413",
    "addressCountry": "ID"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -6.2881,
    "longitude": 106.7266
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
    "opens": "08:00",
    "closes": "17:00"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "87"
  }
};

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Beranda', url: '/' },
  { name: 'Jasa', url: '/#services' },
  { name: 'Laser Cutting Stainless Steel', url: '/jasa-laser-cutting-stainless/' }
]);

const faqSchema = generateFAQSchema(faqs);

const meta = {
  title: "Jasa Laser Cutting Stainless Steel Jakarta & Tangerang",
  description: "Jasa laser cutting stainless SS201, SS304, SS316 di Bintaro–Tangerang. Toleransi ±0.02mm, express 4 jam, no minimum order. Hairline & mirror tersedia. Konsultasi gratis!",
  keywords: "jasa laser cutting stainless, laser cutting stainless jakarta, harga laser cutting stainless, laser cutting ss304, laser cutting stainless tangerang",
  url: "/jasa-laser-cutting-stainless/",
  image: "/images/metal.webp",
  type: "website",
  jsonLd: [serviceSchema, localBusinessSchema, breadcrumbSchema, faqSchema]
};

const crumbs = breadcrumbSchema.itemListElement;
---

<BaseLayout {...meta}>
  <Header slot="header" />

  <main class="mt-16">
    <Breadcrumbs crumbs={crumbs} />

    <!-- ==================== HERO ==================== -->
    <section class="relative bg-gradient-to-br from-gray-900 via-slate-800 to-gray-900 text-white overflow-hidden">
      <div class="absolute inset-0 opacity-20"
        style="background-image: url('/images/metal.webp'); background-size: cover; background-position: center;">
      </div>
      <div class="absolute inset-0 bg-gradient-to-r from-gray-900/90 to-slate-800/70"></div>

      <div class="relative container-custom section-padding py-20 lg:py-28">
        <div class="max-w-3xl">
          <!-- Badge -->
          <div class="inline-flex items-center gap-2 bg-blue-600/20 border border-blue-500/30 rounded-full px-4 py-1.5 mb-6">
            <span class="w-2 h-2 bg-blue-400 rounded-full animate-pulse"></span>
            <span class="text-blue-300 text-sm font-medium">Workshop Bintaro · Melayani Jabodetabek</span>
          </div>

          <h1 class="text-4xl lg:text-5xl font-extrabold leading-tight mb-6">
            Jasa Laser Cutting<br/>
            <span class="text-blue-400">Stainless Steel</span> Jakarta<br/>
            <span class="text-2xl lg:text-3xl font-semibold text-gray-300">SS201 · SS304 · SS316</span>
          </h1>

          <p class="text-lg lg:text-xl text-gray-300 mb-4 max-w-2xl">
            Potong stainless presisi <strong class="text-white">toleransi ±0.02mm</strong>, ketebalan 0.5–10mm. Finishing hairline, mirror, dan doff. Pengerjaan <strong class="text-white">1–3 hari kerja</strong> — express 4 jam tersedia.
          </p>

          <!-- Trust inline -->
          <div class="flex flex-wrap gap-4 mb-10 text-sm text-gray-400">
            <span class="flex items-center gap-1.5"><svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>No minimum order</span>
            <span class="flex items-center gap-1.5"><svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Terima DXF, AI, CDR, SVG</span>
            <span class="flex items-center gap-1.5"><svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Konsultasi desain gratis</span>
            <span class="flex items-center gap-1.5"><svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Workshop sendiri, bukan broker</span>
          </div>

          <!-- CTA Buttons -->
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href={`https://api.whatsapp.com/send?phone=${WA_NUMBER}&text=${WA_MESSAGES.default}`}
              target="_blank" rel="noopener noreferrer"
              data-gtm-id="wa-hero-primary"
              class="inline-flex items-center justify-center gap-3 bg-green-500 hover:bg-green-600 text-white font-bold px-8 py-4 rounded-xl text-lg transition-all shadow-lg shadow-green-500/30 hover:shadow-green-500/50"
            >
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/></svg>
              Chat WA — Konsultasi Gratis
            </a>
            <a
              href="/portfolio/"
              data-gtm-id="hero-portfolio"
              class="inline-flex items-center justify-center gap-2 border-2 border-white/30 hover:border-white text-white font-semibold px-8 py-4 rounded-xl text-lg transition-all hover:bg-white/10"
            >
              Lihat Portofolio
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== TRUST BAR ==================== -->
    <section class="bg-blue-700 text-white py-5">
      <div class="container-custom">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
          <div>
            <div class="text-2xl font-extrabold">7+</div>
            <div class="text-blue-200 text-sm">Tahun Pengalaman</div>
          </div>
          <div>
            <div class="text-2xl font-extrabold">500+</div>
            <div class="text-blue-200 text-sm">Proyek Stainless</div>
          </div>
          <div>
            <div class="text-2xl font-extrabold">±0.02mm</div>
            <div class="text-blue-200 text-sm">Toleransi Presisi</div>
          </div>
          <div>
            <div class="text-2xl font-extrabold">1–3 Hari</div>
            <div class="text-blue-200 text-sm">Lead Time Standar</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== GRADE STAINLESS ==================== -->
    <section class="section-padding">
      <div class="container-custom">
        <div class="text-center mb-12">
          <h2 class="heading-lg text-gray-900 mb-4">Grade Stainless yang Kami Kerjakan</h2>
          <p class="text-lg text-gray-600 max-w-2xl mx-auto">Pilih grade sesuai kebutuhan — dari budget ekonomis hingga marine grade untuk lingkungan agresif.</p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <!-- SS201 -->
          <div class="bg-white rounded-2xl border border-gray-200 p-8 hover:shadow-xl transition-shadow">
            <div class="w-14 h-14 bg-gray-100 rounded-xl flex items-center justify-center mb-5">
              <span class="text-gray-700 font-extrabold text-lg">201</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">SS201 — Ekonomis</h3>
            <p class="text-gray-500 text-sm mb-4">Grade ekonomis untuk aplikasi interior ringan, signage, dan dekorasi dalam ruangan.</p>
            <ul class="space-y-2 text-sm text-gray-600 mb-6">
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Ketebalan 0.5mm – 3mm</li>
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Harga paling kompetitif</li>
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Ideal: signage, logo, dekorasi</li>
            </ul>
            <a href={`https://api.whatsapp.com/send?phone=${WA_NUMBER}&text=${WA_MESSAGES.umkm}`} target="_blank" rel="noopener noreferrer" data-gtm-id="wa-ss201"
              class="block text-center border border-gray-300 hover:border-blue-600 hover:text-blue-600 text-gray-700 font-semibold py-2.5 rounded-lg transition-colors text-sm">
              Tanya Harga SS201
            </a>
          </div>

          <!-- SS304 -->
          <div class="bg-blue-600 text-white rounded-2xl p-8 shadow-xl relative overflow-hidden">
            <div class="absolute top-4 right-4 bg-yellow-400 text-yellow-900 text-xs font-bold px-2.5 py-1 rounded-full">TERLARIS</div>
            <div class="w-14 h-14 bg-white/20 rounded-xl flex items-center justify-center mb-5">
              <span class="text-white font-extrabold text-lg">304</span>
            </div>
            <h3 class="text-xl font-bold mb-2">SS304 — Standar Industri</h3>
            <p class="text-blue-100 text-sm mb-4">Grade 18/8 paling umum. Tahan karat untuk lingkungan normal, cocok industri hingga arsitektur.</p>
            <ul class="space-y-2 text-sm text-blue-100 mb-6">
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-blue-200 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Ketebalan 0.5mm – 10mm</li>
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-blue-200 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Tahan korosi standar</li>
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-blue-200 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Ideal: railing, part mesin, ornamen</li>
            </ul>
            <a href={`https://api.whatsapp.com/send?phone=${WA_NUMBER}&text=${WA_MESSAGES.interior}`} target="_blank" rel="noopener noreferrer" data-gtm-id="wa-ss304"
              class="block text-center bg-white text-blue-600 font-bold py-2.5 rounded-lg transition-colors text-sm hover:bg-blue-50">
              Konsultasi SS304
            </a>
          </div>

          <!-- SS316 -->
          <div class="bg-white rounded-2xl border border-gray-200 p-8 hover:shadow-xl transition-shadow">
            <div class="w-14 h-14 bg-slate-100 rounded-xl flex items-center justify-center mb-5">
              <span class="text-slate-700 font-extrabold text-lg">316</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">SS316 — Marine Grade</h3>
            <p class="text-gray-500 text-sm mb-4">Grade 18/10/2 dengan molybdenum. Tahan lingkungan agresif, area pesisir, dan kelembapan tinggi.</p>
            <ul class="space-y-2 text-sm text-gray-600 mb-6">
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Ketebalan 1mm – 10mm</li>
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Tahan klorida & korosi tinggi</li>
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Ideal: outdoor, balkon, fasad pesisir</li>
            </ul>
            <a href={`https://api.whatsapp.com/send?phone=${WA_NUMBER}&text=${WA_MESSAGES.industri}`} target="_blank" rel="noopener noreferrer" data-gtm-id="wa-ss316"
              class="block text-center border border-gray-300 hover:border-blue-600 hover:text-blue-600 text-gray-700 font-semibold py-2.5 rounded-lg transition-colors text-sm">
              Tanya Harga SS316
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== SPESIFIKASI TEKNIS ==================== -->
    <section class="section-padding bg-gray-50">
      <div class="container-custom">
        <div class="grid lg:grid-cols-2 gap-16 items-start">
          <div>
            <h2 class="heading-lg text-gray-900 mb-6">Spesifikasi Teknis</h2>
            <p class="text-gray-600 mb-8">Mesin laser fiber kami beroperasi dengan parameter yang konsisten untuk memastikan setiap pemotongan memenuhi standar kualitas industri.</p>
            <div class="overflow-hidden rounded-xl border border-gray-200">
              <table class="w-full text-sm">
                <tbody>
                  {[
                    ["Mesin", "CNC Fiber Laser"],
                    ["Ketebalan Material", "0.5mm – 10mm"],
                    ["Ukuran Plat Standar", "1220 × 2440 mm"],
                    ["Toleransi Cutting", "±0.02mm"],
                    ["Grade Tersedia", "SS201, SS304, SS316"],
                    ["Finishing", "Hairline / Mirror / Doff / Raw"],
                    ["Format File", "DXF, DWG, AI, CDR, SVG, PDF"],
                    ["Lead Time Standar", "1–3 hari kerja"],
                    ["Lead Time Express", "4–8 jam (konfirmasi WA)"],
                  ].map(([label, value], i) => (
                    <tr class={i % 2 === 0 ? "bg-white" : "bg-gray-50"}>
                      <td class="px-5 py-3.5 font-semibold text-gray-700 w-1/2">{label}</td>
                      <td class="px-5 py-3.5 text-gray-600">{value}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>

          <!-- Finishing Options -->
          <div>
            <h2 class="heading-lg text-gray-900 mb-6">Pilihan Finishing</h2>
            <div class="space-y-4">
              <div class="bg-white rounded-xl border border-gray-200 p-6 flex gap-5">
                <div class="w-14 h-14 bg-gradient-to-br from-gray-300 to-gray-100 rounded-lg flex-shrink-0 border border-gray-200"
