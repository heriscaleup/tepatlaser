---
import BaseLayout from '../../components/BaseLayout.astro'; import Header from '../../components/Header.astro'; import Footer from '../../components/Footer.astro'; import CTA from '../../components/CTA.astro'; import PageIntro from '../../components/PageIntro.astro'; import { SERVICES } from '../../utils/constants.js';
export async function getStaticPaths() { return [{slug:'jakarta',name:'Jakarta'},{slug:'depok',name:'Depok'},{slug:'bekasi',name:'Bekasi'}].map((location) => ({params:{location:location.slug},props:{location}})); }
const { location } = Astro.props;
const title = `Tepat Laser untuk Proyek di ${location.name}`;
const description = `Konsultasi laser cutting, CNC router, dan engraving untuk proyek di ${location.name}. Kirim file dan kebutuhan Anda ke tim Tepat Laser.`;
---
<BaseLayout title={title} description={description} keywords={`laser cutting ${location.name}, Tepat Laser, CNC router ${location.name}`} url={`/lokasi/${location.slug}/`}><Header slot="header" />
  <main class="overflow-hidden"><PageIntro eyebrow={`Area layanan · ${location.name}`} title={`Jarak boleh berbeda. Standar produksi tetap sama untuk ${location.name}.`} description="Workshop berada di Tangerang Selatan. Review file, konfirmasi teknis, dan komunikasi dapat dilakukan secara daring sebelum hasil diambil atau dikirim." />
    <section class="section-padding"><div class="container-custom"><span class="eyebrow">Kapabilitas tersedia</span><div class="location-grid">{SERVICES.map((service,index) => <a href={`/${service.slug}/`}><span class="number-tag">0{index+1}</span><h2>{service.name}</h2><p>{service.description}</p><strong>Lihat layanan ↗</strong></a>)}</div></div></section>
    <CTA title={`Mulai dari brief proyek di ${location.name}.`} description="Kirim ukuran, material, jumlah, target waktu, dan file bila sudah ada. Kami akan meninjau rute produksinya lebih dulu." primaryText="Kirim brief via WhatsApp" secondaryText="Lihat proses kerja" secondaryLink="/proses-produksi-lead-time/" />
  </main><Footer slot="footer" />
</BaseLayout>
<style>
  .location-grid{display:grid;gap:1px;margin-top:2rem;border:1px solid var(--line);background:var(--line)}.location-grid>a{background:var(--surface);padding:1.4rem;transition:background .35s var(--ease),transform .35s var(--ease)}.location-grid>a:hover{background:rgba(54,114,172,.09);transform:translateY(-4px)}.location-grid h2{margin-top:2.5rem;font-size:1.55rem}.location-grid p{margin-top:.8rem;font-size:.8rem;line-height:1.7}.location-grid strong{display:block;margin-top:1.3rem;color:var(--laser-deep);font-size:.7rem}
  @media(min-width:800px){.location-grid{grid-template-columns:repeat(4,minmax(0,1fr))}}
</style>
