---
import BaseLayout from '../../components/BaseLayout.astro'; import Header from '../../components/Header.astro'; import Footer from '../../components/Footer.astro'; import CTA from '../../components/CTA.astro'; import PageIntro from '../../components/PageIntro.astro'; import { SERVICES, SITE_CONFIG } from '../../utils/constants.js'; import { generateBreadcrumbSchema, generateFAQSchema } from '../../utils/seo.js';
export async function getStaticPaths() {
  return [
    {slug:'jakarta',name:'Jakarta',focus:'signage, interior komersial, komponen metal, panel arsitektur, dan kebutuhan event',handover:'Pengambilan di workshop atau pengiriman kurir/logistik setelah ukuran paket dan jadwal disepakati.',note:'Untuk proyek gedung atau area dengan jam bongkar terbatas, cantumkan jadwal penerimaan serta PIC lokasi sejak tahap estimasi.'},
    {slug:'depok',name:'Depok',focus:'interior, furnitur custom, kebutuhan pendidikan, signage, panel dekoratif, dan prototyping',handover:'Brief dapat direview daring; hasil diambil di workshop atau dikirim sesuai dimensi serta kebutuhan proteksi.',note:'Foto lokasi dan ukuran aktual sangat membantu untuk pekerjaan yang akan dirakit atau dipasang oleh tim lain.'},
    {slug:'bekasi',name:'Bekasi',focus:'komponen manufaktur ringan, jig, panel mesin, nameplate, signage kawasan, dan kebutuhan gudang',handover:'Komponen dapat dikelompokkan per part atau batch; metode packing dan pengiriman dikonfirmasi sebelum produksi.',note:'Sertakan kode part, jumlah per kode, revisi file, serta kebutuhan marking agar komponen mudah diverifikasi saat diterima.'}
  ].map((location) => ({params:{location:location.slug},props:{location}}));
}
const { location } = Astro.props;
const title = `Tepat Laser untuk Proyek di ${location.name}`;
const description = `Konsultasi laser cutting, CNC router, dan engraving untuk proyek di ${location.name}. Kirim file dan kebutuhan Anda ke tim Tepat Laser.`;
const faqs = [
  {question:`Apakah Tepat Laser memiliki workshop di ${location.name}?`,answer:`Workshop Tepat Laser berada di Tangerang Selatan. Konsultasi dan review file untuk proyek ${location.name} dapat dilakukan secara daring sebelum pickup atau pengiriman.`},
  {question:`Bagaimana pengiriman hasil ke ${location.name}?`,answer:location.handover},
  {question:'Data apa yang perlu dikirim untuk estimasi?',answer:'Jenis material, ketebalan, ukuran, jumlah, file atau sketsa, finishing, target waktu, dan alamat serah terima bila membutuhkan pengiriman.'}
];
const breadcrumb = generateBreadcrumbSchema([{name:'Beranda',url:'/'},{name:`Area ${location.name}`,url:`/lokasi/${location.slug}/`}]);
---
<BaseLayout title={title} description={description} keywords={`laser cutting ${location.name}, Tepat Laser, CNC router ${location.name}`} url={`/lokasi/${location.slug}/`} jsonLd={[breadcrumb,generateFAQSchema(faqs)]}><Header slot="header" />
  <main class="overflow-hidden"><PageIntro eyebrow={`Area layanan · ${location.name}`} title={`Jarak boleh berbeda. Standar produksi tetap sama untuk ${location.name}.`} description={`Workshop berada di Tangerang Selatan. Kami melayani review untuk ${location.focus}. Konfirmasi teknis dilakukan sebelum hasil diambil atau dikirim.`} />
    <section class="location-intro"><div class="container-custom"><div><span>Workshop</span><strong>Tangerang Selatan</strong><p>{SITE_CONFIG.address}</p></div><div><span>Serah terima</span><strong>Pickup atau kirim</strong><p>{location.handover}</p></div><div><span>Catatan proyek</span><strong>Konfirmasi sebelum produksi</strong><p>{location.note}</p></div></div></section>
    <section class="section-padding"><div class="container-custom"><span class="eyebrow">Kapabilitas tersedia</span><div class="location-grid">{SERVICES.map((service,index) => <a href={`/${service.slug}/`}><span class="number-tag">0{index+1}</span><h2>{service.name}</h2><p>{service.description}</p><strong>Lihat layanan ↗</strong></a>)}</div></div></section>
    <section class="dark-section section-padding"><div class="container-custom location-process"><div><span class="eyebrow">Kolaborasi jarak jauh</span><h2 class="heading-md mt-5">File dan keputusan bergerak lebih dulu. Barang bergerak setelah semuanya jelas.</h2></div><ol><li><span>01</span><div><h3>Kirim brief</h3><p>Material, ukuran, jumlah, file, finishing, target waktu, serta alamat serah terima.</p></div></li><li><span>02</span><div><h3>Review teknis</h3><p>Tim memeriksa geometri, skala, rute mesin, risiko, dan data yang masih kurang.</p></div></li><li><span>03</span><div><h3>Konfirmasi</h3><p>Scope, harga, jadwal, metode packing, dan serah terima disetujui sebelum produksi.</p></div></li><li><span>04</span><div><h3>Produksi & QC</h3><p>Output diproses, diperiksa, dikelompokkan bila perlu, lalu disiapkan untuk perjalanan.</p></div></li></ol></div></section>
    <section class="section-padding"><div class="container-custom location-faq"><div><span class="eyebrow">Pertanyaan area layanan</span><h2 class="heading-md mt-5">Yang perlu jelas sebelum menghitung ongkos dan jadwal serah terima.</h2></div><div>{faqs.map((faq,index) => <details open={index===0}><summary>{faq.question}<span>＋</span></summary><p>{faq.answer}</p></details>)}</div></div></section>
    <CTA title={`Mulai dari brief proyek di ${location.name}.`} description="Kirim ukuran, material, jumlah, target waktu, dan file bila sudah ada. Kami akan meninjau rute produksinya lebih dulu." primaryText="Kirim brief via WhatsApp" secondaryText="Lihat proses kerja" secondaryLink="/proses-produksi-lead-time/" />
  </main><Footer slot="footer" />
</BaseLayout>
<style>
  .location-intro{border-block:1px solid var(--line);background:var(--surface);padding-block:2rem}.location-intro>div{display:grid;gap:1.5rem}.location-intro span{color:var(--laser);font-size:.75rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase}.location-intro strong{display:block;margin-top:.45rem;color:#fff;font-family:'Clash Display',sans-serif;font-size:1.15rem}.location-intro p{margin-top:.35rem;font-size:.88rem;line-height:1.65}
  .location-grid{display:grid;gap:1px;margin-top:2rem;border:1px solid var(--line);background:var(--line)}.location-grid>a{background:var(--surface);padding:1.4rem;transition:background .35s var(--ease-smooth),transform .35s var(--ease-smooth)}.location-grid>a:hover{background:rgba(54,114,172,.09);transform:translateY(-4px)}.location-grid h2{margin-top:2.5rem;font-size:1.55rem}.location-grid p{margin-top:.8rem;font-size:.9rem;line-height:1.7}.location-grid strong{display:block;margin-top:1.3rem;color:var(--laser-deep);font-size:.78rem}
  .location-process{display:grid;gap:3rem}.location-process ol{display:grid;margin:0;padding:0;border:1px solid var(--line);list-style:none}.location-process li{display:grid;grid-template-columns:2.25rem 1fr;gap:.75rem;padding:1.25rem}.location-process li+li{border-top:1px solid var(--line)}.location-process li>span{color:var(--laser);font-size:.75rem;font-weight:800}.location-process h3{font-size:1.2rem}.location-process p{margin-top:.4rem;font-size:.9rem;line-height:1.65}
  .location-faq{display:grid;gap:3rem}.location-faq details{border-top:1px solid var(--line);padding:1.2rem 0}.location-faq details:last-child{border-bottom:1px solid var(--line)}.location-faq summary{display:flex;justify-content:space-between;gap:1rem;cursor:pointer;list-style:none;color:var(--ink);font-weight:750}.location-faq summary::-webkit-details-marker{display:none}.location-faq summary span{color:var(--laser)}.location-faq details p{margin-top:.75rem;font-size:.92rem;line-height:1.75}
  @media(min-width:800px){.location-intro>div{grid-template-columns:repeat(3,minmax(0,1fr))}.location-intro>div>div+div{border-left:1px solid var(--line);padding-left:1.5rem}.location-grid{grid-template-columns:repeat(4,minmax(0,1fr))}.location-process,.location-faq{grid-template-columns:.8fr 1.2fr}.location-process ol{grid-template-columns:repeat(2,minmax(0,1fr))}.location-process li:nth-child(2n){border-left:1px solid var(--line)}.location-process li:nth-child(2){border-top:0}.location-process li:nth-child(n+3){border-top:1px solid var(--line)}}
</style>
