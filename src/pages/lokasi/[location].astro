---
import BaseLayout from '../../components/BaseLayout.astro'; import Header from '../../components/Header.astro'; import Footer from '../../components/Footer.astro'; import CTA from '../../components/CTA.astro'; import { SERVICES } from '../../utils/constants.js';
export async function getStaticPaths() { return [{slug:'jakarta',name:'Jakarta'},{slug:'depok',name:'Depok'},{slug:'bekasi',name:'Bekasi'}].map((location) => ({params:{location:location.slug},props:{location}})); }
const { location } = Astro.props;
const title = `Tepat Laser untuk Project di ${location.name}`;
const description = `Konsultasi laser cutting, CNC router, dan engraving untuk project di ${location.name}. Kirim file dan kebutuhan Anda ke tim Tepat Laser.`;
---
<BaseLayout title={title} description={description} keywords={`laser cutting ${location.name}, Tepat Laser, CNC router ${location.name}`} url={`/lokasi/${location.slug}/`}><Header slot="header" />
  <main class="location-page overflow-hidden"><section class="border-b border-[var(--line)] pt-40 pb-20"><div class="container-custom grid gap-10 lg:grid-cols-[1fr_.7fr] lg:items-end"><div><span class="eyebrow">Service area / {location.name}</span><h1 class="heading-xl mt-7">Project di<br /><span class="text-[var(--laser-deep)]">{location.name}.</span></h1></div><p class="max-w-xl text-lg leading-8">Tepat Laser membantu project dari review file, rekomendasi jalur produksi, sampai output siap diteruskan ke proses berikutnya.</p></div></section><section class="section-padding"><div class="container-custom"><span class="eyebrow">Capabilities nearby</span><div class="mt-8 grid gap-4 md:grid-cols-4">{SERVICES.map((service,index) => <a href={`/${service.slug}/`} class="group border border-[var(--line)] bg-white p-6 transition hover:-translate-y-1 hover:border-[var(--ink)]"><span class="font-mono text-xs font-bold text-[var(--laser-deep)]">0{index+1}</span><h2 class="mt-12 text-2xl group-hover:text-[var(--laser-deep)]">{service.name}</h2><p class="mt-3 text-sm leading-7">{service.description}</p></a>)}</div></div></section><CTA title={`Mulai dari brief project di ${location.name}.`} description="Kirim ukuran, material, jumlah, deadline, dan file jika sudah ada. Kami cek rute produksinya terlebih dahulu." primaryText="Kirim brief via WhatsApp" secondaryText="Lihat proses kerja" secondaryLink="/proses-produksi-lead-time/" /></main><Footer slot="footer" />
</BaseLayout>
