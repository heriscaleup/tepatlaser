---
import BaseLayout from '../components/BaseLayout.astro'; import Header from '../components/Header.astro'; import Footer from '../components/Footer.astro'; import CTA from '../components/CTA.astro'; import { SITE_CONFIG } from '../utils/constants.js'; import { generateBreadcrumbSchema, generateFAQSchema } from '../utils/seo.js';
const steps = [['01','Kirim brief','Desain, ukuran, material, ketebalan, jumlah, dan deadline.'],['02','Review teknis','Kami cek skala, jalur potong, detail kecil, dan risiko material.'],['03','Susun estimasi','Harga, kebutuhan bahan, opsi proses, dan lead time dirangkum jelas.'],['04','Masuk produksi','File dinest, material dikonfirmasi, lalu mesin bekerja sesuai rute.'],['05','QC & serah terima','Jumlah, visual, dan kerapian dicek sebelum diambil atau dikirim.']];
const faqs = [{question:'Berapa lama estimasi standar?',answer:'Umumnya 1–3 hari kerja setelah desain, material, dan penawaran disetujui. Pekerjaan express mengikuti antrean mesin dan kompleksitas file.'},{question:'Apa yang memengaruhi lead time?',answer:'Jenis material, ketebalan, panjang jalur potong, jumlah detail, finishing tambahan, ketersediaan bahan, dan antrean produksi.'},{question:'Bisa konsultasi sebelum produksi?',answer:'Bisa. Tim kami membantu cek desain, rekomendasi bahan, estimasi biaya, dan jadwal sebelum order dijalankan.'}];
const breadcrumb = generateBreadcrumbSchema([{name:'Beranda',url:'/'},{name:'Proses Produksi',url:'/proses-produksi-lead-time/'}]); const wa = `https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent('Halo Tepat Laser, saya ingin tanya proses produksi dan lead time.')}`;
---
<BaseLayout title="Proses Produksi & Lead Time — Tepat Laser" description="Lihat alur kerja Tepat Laser dari review file, estimasi, produksi, quality control, hingga serah terima." keywords="proses produksi laser cutting, lead time laser cutting, estimasi pengerjaan" url="/proses-produksi-lead-time/" jsonLd={[breadcrumb,generateFAQSchema(faqs)]}><Header slot="header" />
  <main class="overflow-hidden"><section class="border-b border-[var(--line)] pt-40 pb-20"><div class="container-custom grid gap-10 lg:grid-cols-[1fr_.7fr] lg:items-end"><div><span class="eyebrow">Workflow / Production control</span><h1 class="heading-xl mt-7">From file<br /><span class="text-[var(--acid)]">to fit.</span></h1></div><div><p class="text-lg leading-8">Alur yang terlihat membuat keputusan produksi terasa lebih ringan—dari file pertama sampai barang siap dipasang.</p><a href={wa} target="_blank" rel="noopener noreferrer" class="btn-primary mt-7" data-wa-label="Process consultation">Tanya jadwal produksi <span>↗</span></a></div></div></section><section class="section-padding"><div class="container-custom"><div class="grid gap-px border border-[var(--line)] bg-[var(--line)] md:grid-cols-5">{steps.map(([number,title,desc]) => <div class="bg-[var(--ink)] p-6"><span class="font-mono text-xs text-[var(--acid)]">{number}</span><h2 class="mt-12 text-xl">{title}</h2><p class="mt-3 text-sm leading-7">{desc}</p></div>)}</div><div class="mt-16 grid gap-5 md:grid-cols-3"><div class="line-panel p-6"><strong class="font-heading text-4xl text-[var(--acid)]">1–3</strong><p class="mt-3 text-sm">Hari kerja standar setelah approval.</p></div><div class="line-panel p-6"><strong class="font-heading text-4xl text-[var(--acid)]">QC</strong><p class="mt-3 text-sm">Visual, jumlah, dan kerapian dicek.</p></div><div class="line-panel p-6"><strong class="font-heading text-4xl text-[var(--acid)]">1:1</strong><p class="mt-3 text-sm">File vector/CAD paling cepat diproses.</p></div></div></div></section><section class="border-y border-[var(--line)] bg-[var(--ink-soft)] py-20"><div class="container-custom max-w-4xl"><span class="eyebrow">FAQ / Lead time</span><h2 class="heading-lg mt-5">Yang sering ditanya<br /><span class="text-[var(--acid)]">sebelum produksi.</span></h2><div class="mt-10 space-y-3">{faqs.map((faq) => <details class="border border-[var(--line)] bg-[var(--panel)] p-5"><summary class="cursor-pointer font-semibold">{faq.question}</summary><p class="mt-3 text-sm leading-7">{faq.answer}</p></details>)}</div></div></section><CTA title="Sudah siap mulai?" primaryText="Kirim brief project" secondaryText="Lihat layanan" secondaryLink="/services/" /></main><Footer slot="footer" />
</BaseLayout>
