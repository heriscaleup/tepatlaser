---
import BaseLayout from '../components/BaseLayout.astro'; import Header from '../components/Header.astro'; import Footer from '../components/Footer.astro'; import CTA from '../components/CTA.astro'; import PageIntro from '../components/PageIntro.astro'; import { SITE_CONFIG } from '../utils/constants.js'; import { generateBreadcrumbSchema, generateFAQSchema } from '../utils/seo.js';
const steps = [['01','Kirim brief','File, ukuran, material, ketebalan, jumlah, dan target waktu.'],['02','Review teknis','Kami cek skala, jalur potong, detail kecil, serta risiko material.'],['03','Konfirmasi estimasi','Lingkup, kebutuhan bahan, proses, biaya, dan waktu dirangkum sebelum produksi.'],['04','Produksi','File disiapkan, material dikonfirmasi, lalu proses dijalankan sesuai kebutuhan.'],['05','QC & serah terima','Jumlah, visual, dan kerapian diperiksa sebelum diambil atau dikirim.']];
const faqs = [{question:'Berapa lama estimasi pengerjaan?',answer:'Tanggal selesai dikonfirmasi setelah desain, material, jumlah, finishing, dan antrean mesin ditinjau. Dengan begitu jadwal merujuk pada scope nyata, bukan angka generik.'},{question:'Apa yang memengaruhi waktu pengerjaan?',answer:'Jenis material, ketebalan, panjang jalur potong, jumlah detail, proses tambahan, ketersediaan bahan, dan antrean produksi.'},{question:'Bisa konsultasi sebelum produksi?',answer:'Bisa. Tim kami membantu meninjau desain, material, estimasi, dan jadwal sebelum pekerjaan dijalankan.'}];
const breadcrumb = generateBreadcrumbSchema([{name:'Beranda',url:'/'},{name:'Proses Produksi',url:'/proses-produksi-lead-time/'}]); const wa = `https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent('Halo Tepat Laser, saya ingin menanyakan proses produksi dan jadwal pengerjaan.')}`;
---
<BaseLayout title="Proses Produksi & Lead Time — Tepat Laser" description="Lihat alur kerja Tepat Laser dari review file, estimasi, produksi, pemeriksaan mutu, hingga serah terima." keywords="proses produksi laser cutting, lead time laser cutting, estimasi pengerjaan" url="/proses-produksi-lead-time/" jsonLd={[breadcrumb,generateFAQSchema(faqs)]}><Header slot="header" />
  <main class="overflow-hidden"><PageIntro eyebrow="Alur produksi" title="Setiap keputusan punya tahap. Setiap hasil punya pemeriksaan." description="Alur yang terlihat membuat biaya, waktu, material, dan ekspektasi lebih mudah dikunci sebelum pekerjaan bergerak ke tahap berikutnya." actionText="Tanyakan jadwal produksi" actionHref={wa} />
    <section class="section-padding"><div class="container-custom process-list">{steps.map(([number,title,desc]) => <div><span>{number}</span><h2>{title}</h2><p>{desc}</p></div>)}</div></section>
    <section class="dark-section py-16 md:py-20"><div class="container-custom metrics"><div><strong>Jadwal</strong><p>Dikunci setelah material, file, jumlah, finishing, dan antrean ditinjau.</p></div><div><strong>QC</strong><p>Jumlah, visual, dan kerapian diperiksa sebelum serah terima.</p></div><div><strong>1:1</strong><p>File vektor atau CAD berskala benar paling cepat ditinjau.</p></div></div></section>
    <section class="warm-section section-padding"><div class="container-custom process-faq"><div><span class="eyebrow">Waktu pengerjaan</span><h2 class="heading-lg mt-6">Hal yang sering ditanyakan sebelum produksi.</h2></div><div>{faqs.map((faq) => <details><summary>{faq.question}<span>＋</span></summary><p>{faq.answer}</p></details>)}</div></div></section>
    <CTA title="Brief belum lengkap tetap bisa dimulai." description="Kirim yang sudah tersedia. Kami bantu menunjukkan informasi apa yang perlu dikunci agar estimasi dan produksi tidak berjalan dengan asumsi." primaryText="Kirim kebutuhan proyek" secondaryText="Lihat layanan" secondaryLink="/services/" />
  </main><Footer slot="footer" />
</BaseLayout>
<style>
  .process-list{border-top:1px solid var(--line)}.process-list>div{display:grid;grid-template-columns:2.5rem 1fr;gap:1rem;border-bottom:1px solid var(--line);padding:1.5rem 0}.process-list span{grid-row:span 2;color:var(--laser);font-size:.76rem;font-weight:800}.process-list h2{font-size:clamp(1.55rem,3vw,2.3rem)}.process-list p{max-width:37rem;font-size:.95rem;line-height:1.7}
  .metrics{display:grid;gap:2rem}.metrics strong{color:#fff;font-family:'Clash Display',sans-serif;font-size:clamp(2.5rem,4.5vw,4rem);font-weight:600;letter-spacing:-.05em}.metrics p{margin-top:.8rem;max-width:20rem;font-size:.9rem;line-height:1.7}.process-faq{display:grid;gap:3rem}.process-faq details{border-top:1px solid var(--line);padding:1.1rem 0}.process-faq details:last-child{border-bottom:1px solid var(--line)}.process-faq summary{display:flex;justify-content:space-between;gap:1rem;cursor:pointer;list-style:none;color:var(--ink);font-weight:750}.process-faq summary::-webkit-details-marker{display:none}.process-faq summary span{color:var(--laser)}.process-faq details p{margin-top:.8rem;font-size:.92rem;line-height:1.75}
  @media(min-width:760px){.process-list>div{grid-template-columns:3rem .65fr 1fr;align-items:start}.process-list span{grid-row:auto}.metrics{grid-template-columns:repeat(3,minmax(0,1fr))}.metrics>div+div{border-left:1px solid rgba(255,255,255,.16);padding-left:2rem}.process-faq{grid-template-columns:1fr 1fr}}
</style>
