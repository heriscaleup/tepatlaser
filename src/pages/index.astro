---
import BaseLayout from '../components/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTA from '../components/CTA.astro';
import { SERVICES, MATERIALS, FAQ, SITE_CONFIG } from '../utils/constants.js';
import { generateFAQSchema } from '../utils/seo.js';

const wa = `https://api.whatsapp.com/send?phone=${SITE_CONFIG.whatsapp}&text=${encodeURIComponent('Halo Tepat Laser, saya ingin konsultasi proyek dan mengirimkan file desain.')}`;
const meta = {
  title: 'Tepat Laser — Laser Cutting & Fabrikasi Presisi Tangerang Selatan',
  description: 'Jasa laser cutting metal, stainless steel, akrilik, MDF, aluminium, CNC router ACP/GRC, dan galvo engraving di Tangerang Selatan dengan review file dan QC sebelum serah terima.',
  keywords: 'jasa laser cutting Tangerang Selatan, laser fiber metal, laser CO2, CNC router ACP, galvo engraving metal, laser cutting stainless steel',
  url: '/',
  image: '/images/generated/fiber-laser-v6.webp',
  jsonLd: [generateFAQSchema(FAQ)]
};

const showcases = [
  { title: 'Pagar & Fasad Laser Panel', label: 'Arsitektural Eksterior', image: '/gambar/pagar-laser-cutting-landing/hero-pagar-laser-cutting.webp' },
  { title: 'Reling Tangga & Partisi Pola', label: 'Interior Custom', image: '/gambar/railing-laser-cutting-landing/reling-tangga-daylight.webp' },
  { title: 'Fasad ACP Gedung & Signage', label: 'Panel Bangunan Commercial', image: '/gambar/pagar-laser-cutting-landing/fasad-gedung-laser-cutting.webp' }
];

const qcCheckpoints = [
  { step: '01', title: 'Review File & Geometri', desc: 'File AI, DXF, DWG, CDR, atau SVG ditinjau untuk membaca ukuran, radius, jarak antarpotongan, dan titik yang berisiko.' },
  { step: '02', title: 'Kunci Parameter Produksi', desc: 'Mesin, daya, kecepatan, fokus, dan parameter pendukung dipilih sesuai jenis material serta target hasil akhir.' },
  { step: '03', title: 'Pemeriksaan Tepi & Permukaan', desc: 'Tepi, bekas proses, dan kondisi permukaan diperiksa. Pembersihan atau deburring dilakukan bila termasuk dalam lingkup pekerjaan.' },
  { step: '04', title: 'Verifikasi Dimensi & Packing', desc: 'Dimensi acuan diperiksa secara sampling atau sesuai brief, lalu metode packing disesuaikan dengan bentuk dan cara serah terima.' }
];

const comparisons = [
  { feature: 'Konsistensi geometri', tepat: 'File digital dan parameter mesin dapat diulang untuk produksi batch', manual: 'Sangat bergantung pada jig, alat, dan keterampilan operator' },
  { feature: 'Detail pola', tepat: 'Mampu mengikuti kontur dan pola berulang yang sudah lolos review', manual: 'Lebih cocok untuk bentuk sederhana atau koreksi langsung di lapangan' },
  { feature: 'Penanganan file', tepat: 'File ditinjau sebelum masuk antrean produksi', manual: 'Umumnya dimulai dari marking atau pengukuran langsung' },
  { feature: 'Perencanaan waktu', tepat: 'Estimasi diberikan setelah material, file, jumlah, dan finishing dikonfirmasi', manual: 'Estimasi dipengaruhi jumlah tahapan serta pengerjaan tangan' },
  { feature: 'Kapan paling tepat dipakai', tepat: 'Detail berulang, produksi presisi, dan kebutuhan hasil yang konsisten', manual: 'Penyesuaian sederhana, pekerjaan lapangan, atau bentuk yang tidak perlu diprogram' }
];

const trustLogos = [
  'Kontraktor Arsitektur', 'Interior Designer', 'Manufaktur Ringan', 'Signage Agency', 'Property Developer', 'Furniture Custom'
];
---

<BaseLayout {...meta}>
  <Header slot="header" />
  <main class="home-page overflow-hidden bg-slate-50 text-slate-900">
    <!-- Hero Banner Section -->
    <section class="home-hero" data-no-reveal>
      <div class="container-custom">
        <div class="grid items-center gap-8 lg:grid-cols-12 lg:gap-12">
          <!-- Left Column: Copy & CTAs -->
          <div class="lg:col-span-7 py-4">
            <div class="inline-flex items-center gap-2.5 rounded-full border border-slate-300 bg-white px-4 py-1.5 text-xs font-bold text-slate-800 shadow-sm">
              <span class="flex h-2.5 w-2.5 rounded-full bg-emerald-500 animate-pulse"></span>
              Workshop Fabrikasi Presisi · Tangsel & Sejabodetabek
            </div>

            <div class="text-reveal">
              <h1 class="mt-6 text-3xl font-black tracking-tight text-slate-950 sm:text-4xl lg:text-5xl lg:leading-[1.15]">
                <span class="text-slate-950 block">Presisi Bukan Soal Angka.</span>
                <span class="mt-1 block bg-gradient-to-r from-amber-600 via-rose-600 to-indigo-600 bg-clip-text text-transparent font-black">
                  Hasilnya Harus Pas Saat Dipasang.
                </span>
              </h1>
            </div>

            <div class="text-reveal">
              <p class="mt-6 text-base sm:text-lg leading-relaxed text-slate-700 font-medium max-w-2xl">
                File, material, toleransi, parameter mesin, finishing, dan QC kami kunci sebelum produksi agar komponen pas saat dipasang.
              </p>
            </div>

            <div class="mt-8 flex flex-col gap-3.5 sm:flex-row sm:items-center">
              <a href={wa} target="_blank" rel="noopener noreferrer" class="btn-primary shadow-lg shadow-amber-500/15" data-wa-label="Home hero consultation" data-magnetic>
                Kirim Brief Proyek Anda <span>↗</span>
              </a>
              <a href="#kapabilitas" class="btn-secondary" data-magnetic>
                Jelajahi Kapabilitas <span>↓</span>
              </a>
            </div>

            <div class="mt-10 grid grid-cols-2 gap-4 border-t border-slate-300 pt-6 sm:grid-cols-4">
              <div>
                <div class="font-mono text-2xl font-black text-slate-950">4</div>
                <div class="text-xs font-bold text-slate-600 mt-0.5">Teknologi produksi</div>
              </div>
              <div>
                <div class="font-mono text-2xl font-black text-slate-950">7+</div>
                <div class="text-xs font-bold text-slate-600 mt-0.5">Karakter material</div>
              </div>
              <div>
                <div class="font-mono text-2xl font-black text-emerald-700">122×244</div>
                <div class="text-xs font-bold text-slate-600 mt-0.5">cm area kerja maks.</div>
              </div>
              <div>
                <div class="font-mono text-2xl font-black text-slate-950">Tangsel</div>
                <div class="text-xs font-bold text-slate-600 mt-0.5">Lokasi workshop</div>
              </div>
            </div>
          </div>

          <!-- Right Column: Hero Image -->
          <div class="lg:col-span-5">
            <div class="img-reveal relative overflow-hidden rounded-2xl border border-slate-300 bg-slate-900 shadow-2xl">
              <img
                src="/images/generated/fiber-laser-v6.webp"
                alt="Proses kerja mesin fiber laser memotong lembaran metal presisi di workshop Tepat Laser"
                width="1600"
                height="900"
                class="w-full h-[22rem] sm:h-[28rem] lg:h-[32rem] object-cover object-center"
                fetchpriority="high"
                decoding="sync"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-slate-950/90 via-slate-950/20 to-transparent"></div>
              <div class="absolute bottom-0 inset-x-0 p-5 flex items-center justify-between text-white text-xs font-bold tracking-wider">
                <span class="flex items-center gap-2">
                  <span class="h-2 w-2 rounded-full bg-amber-400"></span>
                  FIBER LASER METAL 1500 W
                </span>
                <span class="text-slate-300 font-medium">Workshop Tangsel</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Kinetic Ticker -->
    <section class="kinetic-line" aria-label="Kapabilitas utama" data-no-reveal>
      <div class="kinetic-track">
        <span>Laser Fiber Metal</span><span>Laser CO₂ Akrilik</span><span>CNC Router ACP/GRC</span><span>Galvo Engraving</span><span>Review Vector File</span><span>QC Deburring Tepi</span>
        <span>Laser Fiber Metal</span><span>Laser CO₂ Akrilik</span><span>CNC Router ACP/GRC</span><span>Galvo Engraving</span><span>Review Vector File</span><span>QC Deburring Tepi</span>
      </div>
    </section>

    <!-- Social Proof / Trust Bar -->
    <section class="section-padding bg-white border-b border-slate-200">
      <div class="container-custom">
        <p class="text-center text-sm font-bold uppercase tracking-[.16em] text-slate-500 mb-8">Jalur produksi untuk kebutuhan profesional lintas industri</p>
        <div class="trust-grid">
          {trustLogos.map((logo) => (
            <div class="trust-item">
              <span class="trust-dot"></span>
              <span class="trust-label">{logo}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Kapabilitas Mesin Utama Section -->
    <section id="kapabilitas" class="dark-section section-padding">
      <div class="container-custom">
        <div class="section-head">
          <div>
            <span class="eyebrow text-amber-400">Teknologi & Armada Mesin</span>
            <h2 class="heading-lg mt-5">Mesin Bukan Jawaban Pertama. Kebutuhan Proyek Anda Yang Menentukan Prosesnya.</h2>
          </div>
          <p class="text-slate-300">
            Kami tidak memaksakan semua bahan melewati jenis mesin yang sama. Karakteristik material, ketebalan, detail radius, fungsi ruang, dan kerapian tepi dianalisis lebih dulu oleh teknisi kami.
          </p>
        </div>
        <div class="service-list accent-cycle">
          {SERVICES.map((service, index) => (
            <a href={`/${service.slug}/`} data-magnetic>
              <span class="number-tag">0{index + 1}</span>
              <div>
                <h3>{service.name}</h3>
                <p>{service.description}</p>
                <small class="mt-2 block font-semibold text-slate-400">Aplikasi: {service.applications.slice(0, 3).join(' · ')}</small>
              </div>
              <span class="service-arrow">↗</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Material Section -->
    <section class="section-padding warm-section">
      <div class="container-custom">
        <div class="section-head">
          <div>
            <span class="eyebrow">Pilihan Material Sedia & Custom</span>
            <h2 class="heading-lg mt-5">Material Yang Tepat Mencegah Koreksi & Biaya Membengkak Di Akhir.</h2>
          </div>
          <p>
            Bahan yang terlihat serupa di lembar katalog dapat bereaksi sangat berbeda saat terkena panas fokus laser. Kami membantu Anda memilih jenis dan ketebalan material yang ideal.
          </p>
        </div>
        <div class="material-grid accent-cycle">
          {MATERIALS.map((material, index) => (
            <a href={`/${material.slug}/`} class="material-card" data-material={material.id} data-magnetic>
              <div class="material-specimen" aria-hidden="true"><span></span><span></span><span></span></div>
              <div class="material-shade"></div>
              <div class="material-copy">
                <span class="number-tag">0{index + 1}</span>
                <h3>{material.name}</h3>
                <p>{material.thickness}</p>
                <span>Lihat Spesifikasi ↗</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- QC & Standard Kontrol Presisi -->
    <section class="section-padding bg-slate-900 text-white">
      <div class="container-custom">
        <div class="max-w-2xl">
          <span class="eyebrow text-amber-400">Standar Mutu Tepat Laser</span>
          <h2 class="heading-lg mt-4 text-white">4 Tahap Kontrol Kualitas Demi Hasil Siap Rakit & Bebas Retur.</h2>
          <p class="mt-4 text-slate-300">
            Setiap pesanan yang diproses di workshop Tepat Laser wajib melewati 4 pos pemeriksaan teknis sebelum dikirimkan ke alamat Anda.
          </p>
        </div>
        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {qcCheckpoints.map((qc) => (
            <div class="qc-card rounded-xl border border-slate-800 bg-slate-950/60 p-6 shadow-md backdrop-blur-sm">
              <span class="inline-block rounded-md bg-amber-500/10 px-3 py-1 font-mono text-sm font-bold text-amber-400 border border-amber-500/20">{qc.step}</span>
              <h3 class="mt-4 text-lg font-bold text-white">{qc.title}</h3>
              <p class="mt-3 text-xs leading-relaxed text-slate-400">{qc.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Perbandingan Tepat Laser vs Potongan Manual -->
    <section class="section-padding bg-white">
      <div class="container-custom">
        <div class="text-center max-w-2xl mx-auto">
          <span class="eyebrow text-amber-800">Perbandingan Kualitas</span>
          <h2 class="heading-lg mt-4 text-slate-950">Mengapa Kontraktor & Desainer Memilih Tepat Laser?</h2>
          <p class="mt-4 text-slate-700 font-medium">Setiap metode punya tempatnya. Tabel ini membantu menentukan kapan produksi berbasis file digital memberi nilai paling besar.</p>
        </div>
        <div class="mt-12 overflow-x-auto rounded-2xl border border-slate-300 shadow-md bg-white">
          <table class="w-full text-left text-sm border-collapse">
            <thead class="bg-slate-950 text-white font-extrabold border-b border-slate-300">
              <tr>
                <th class="p-4 md:p-5 text-slate-100 text-base">Parameter Kualitas</th>
                <th class="p-4 md:p-5 text-slate-950 bg-amber-400 text-base">Produksi digital Tepat Laser</th>
                <th class="p-4 md:p-5 text-slate-300 text-base">Pemotongan manual</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200 font-bold text-slate-950">
              {comparisons.map((row) => (
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="p-4 md:p-5 font-bold text-slate-950">{row.feature}</td>
                  <td class="p-4 md:p-5 font-black text-slate-950 bg-amber-50 border-x border-amber-200">
                    {row.tepat}
                  </td>
                  <td class="p-4 md:p-5 font-medium text-slate-600">
                    {row.manual}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Application Showcase Section -->
    <section class="section-padding bg-slate-50">
      <div class="container-custom">
        <div class="flex flex-col gap-7 md:flex-row md:items-end md:justify-between">
          <div>
            <span class="eyebrow text-amber-800">Pilihan Aplikasi & Portofolio</span>
            <h2 class="heading-lg mt-5 text-slate-950">Bukan Hanya Rapi Di Foto. Harus Bekerja Di Ruang Sebenarnya.</h2>
          </div>
          <a href="/portfolio/" class="btn-secondary md:w-auto" data-magnetic>Lihat Portofolio Lengkap <span>↗</span></a>
        </div>
        <div class="showcase-grid">
          {showcases.map((item, index) => (
            <article class:list={["showcase-card", index === 0 && "showcase-wide"]}>
              <img src={item.image} alt={item.title} width="1200" height="800" loading="lazy" decoding="async" />
              <div>
                <span>{item.label}</span>
                <h3>{item.title}</h3>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Process Flow Strip -->
    <section class="process-strip">
      <div class="container-custom">
        <div>
          <span>01</span>
          <h3>Ceritakan Kebutuhannya</h3>
          <p>Kirimkan berkas CAD/Vector, sketsa tangan, jenis material, ketebalan, dan jumlah pcs yang dibutuhkan.</p>
        </div>
        <div>
          <span>02</span>
          <h3>Kunci Keputusan Teknis</h3>
          <p>Tim engineer kami memeriksa risiko geometri, rekomendasi jenis mesin, toleransi potong, dan memberikan estimasi penawaran.</p>
        </div>
        <div>
          <span>03</span>
          <h3>Produksi & Delivery</h3>
          <p>Proses pemotongan cepat presisi, lolos QC deburring, dibungkus aman, dan dikirimkan sampai ke lokasi Anda.</p>
        </div>
      </div>
    </section>

    <CTA
      title="Bawa Idenya. Kami Bantu Membuatnya Layak Diproduksi."
      description="File belum final bukan penghalang. Kirim sketsa, foto referensi, atau sampel brief; tim teknis kami siap membantu optimalisasi file tanpa biaya konsultasi tambahan."
      primaryText="Mulai Konsultasi WhatsApp"
      secondaryText="Baca Panduan File Desain"
      secondaryLink="/blog/panduan-file-desain-laser-cutting-akurat/"
    />
  </main>
  <Footer slot="footer" />
</BaseLayout>

<style>
  .home-hero {
    background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    padding-top: 6.5rem;
    padding-bottom: 4.5rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }
  .home-hero .btn-secondary {
    border-color: #94a3b8;
    color: #0f172a;
  }
  .home-hero .btn-secondary:hover {
    border-color: #b7791f;
    background: #fffbeb;
    color: #0f172a;
  }
  .section-head {
    display: grid;
    gap: 2rem;
  }
  .section-head > p {
    max-width: 34rem;
    font-size: 1rem;
    line-height: 1.8;
  }

  /* Trust bar */
  .trust-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: .75rem;
    padding: .875rem 1.25rem;
    border: 1px solid #e2e8f0;
    border-radius: .5rem;
    background: #fff;
    transition: all .25s var(--ease-smooth);
  }
  .trust-item:hover {
    border-color: var(--brand-gold-soft);
    transform: translateY(-2px);
    box-shadow: 0 .5rem 1.5rem rgba(0,0,0,.06);
  }
  .trust-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--brand-gold-soft);
    flex-shrink: 0;
  }
  .trust-label {
    font-size: .9rem;
    font-weight: 700;
    color: #334155;
    letter-spacing: -.01em;
  }

  .service-list {
    margin-top: 3.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.16);
  }
  .service-list > a {
    display: grid;
    grid-template-columns: 2.5rem 1fr auto;
    align-items: center;
    gap: 1.2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.16);
    padding: 1.6rem 0;
    transition: padding 0.35s var(--ease-smooth), background 0.35s var(--ease-smooth), transform 0.35s var(--ease-smooth);
  }
  .service-list > a:hover {
    padding-inline: 0.8rem;
    background: rgba(54, 114, 172, 0.09);
    transform: translateX(4px);
  }
  .service-list h3 {
    font-size: clamp(1.6rem, 3vw, 2.6rem);
  }
  .service-list p {
    max-width: 42rem;
    margin-top: 0.45rem;
    font-size: 0.9rem;
    line-height: 1.6;
  }
  .service-arrow {
    color: var(--brand-blue-soft);
    font-size: 1.4rem;
    transition: transform 0.3s var(--ease-smooth);
  }
  .service-list > a:hover .service-arrow {
    transform: translate(0.25rem, -0.25rem);
  }

  .material-grid {
    display: grid;
    gap: 1px;
    margin-top: 3.5rem;
    border: 1px solid var(--line);
    background: var(--line);
  }
  .material-card {
    position: relative;
    min-height: 18rem;
    overflow: hidden;
    background: #050906;
    isolation: isolate;
    transition: transform 0.5s var(--ease-smooth);
  }
  .material-card:hover {
    transform: translateY(-4px);
    z-index: 2;
  }
  .material-specimen {
    position: absolute;
    inset: 0;
    overflow: hidden;
    transition: transform 0.8s var(--ease-smooth), filter 0.8s var(--ease-smooth);
  }
  .material-card:hover .material-specimen {
    transform: scale(1.06);
    filter: saturate(1.16);
  }
  .material-card[data-material='acrylic'] .material-specimen {
    background: radial-gradient(circle at 78% 18%, rgba(228, 255, 112, 0.72), transparent 20%), linear-gradient(140deg, #061713 0%, #143a34 48%, #07110f 100%);
  }
  .material-card[data-material='mdf'] .material-specimen {
    background: repeating-linear-gradient(172deg, #40291a 0 3px, #563820 3px 7px, #2b1a13 7px 10px);
  }
  .material-card[data-material='ply-wood-multiplex'] .material-specimen {
    background: repeating-linear-gradient(0deg, #c78a4e 0 12px, #6c4022 12px 16px, #e3b56e 16px 25px);
  }
  .material-card[data-material='metal'] .material-specimen {
    background: linear-gradient(125deg, #171c20 0%, #78868d 26%, #222b31 41%, #a7b3b5 57%, #1a2126 76%, #505d62 100%);
  }
  .material-card[data-material='acp'] .material-specimen {
    background: linear-gradient(145deg, #981f30 0 29%, #efc5c8 29.5% 31%, #151b20 31.5% 59%, #ccd8dc 59.5% 61%, #295b81 61.5%);
  }
  .material-card[data-material='pvc'] .material-specimen {
    background: linear-gradient(132deg, #dce6e4 0 43%, #f7faf8 43.5% 63%, #c4d2cf 63.5%);
  }
  .material-card[data-material='grc'] .material-specimen {
    background: radial-gradient(circle at 14% 24%, rgba(255, 255, 255, 0.18) 0 2px, transparent 3px), linear-gradient(145deg, #777c78, #c4c5bb 45%, #666d6b);
  }
  .material-shade {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(5, 9, 6, 0.97), rgba(5, 9, 6, 0.12) 72%);
  }
  .material-copy {
    position: absolute;
    z-index: 1;
    right: 1.3rem;
    bottom: 1.3rem;
    left: 1.3rem;
  }
  .material-grid h3 {
    margin-top: 2.2rem;
    color: #fff;
    font-size: 1.25rem;
  }
  .material-grid p {
    margin-top: 0.45rem;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.82rem;
  }
  .material-copy > span:last-child {
    display: block;
    margin-top: 1.4rem;
    color: var(--laser);
    font-size: 0.75rem;
    font-weight: 800;
  }

  .qc-card {
    transition: transform 0.4s var(--ease-smooth), border-color 0.4s ease;
  }
  .qc-card:hover {
    transform: translateY(-6px);
    border-color: rgba(211, 177, 93, 0.3);
  }

  .showcase-grid {
    display: grid;
    gap: 1rem;
    margin-top: 3rem;
  }
  .showcase-card {
    position: relative;
    min-height: 29rem;
    overflow: hidden;
    background: #050906;
    border-radius: 0.75rem;
    transition: transform 0.5s var(--ease-smooth);
  }
  .showcase-card:hover {
    transform: translateY(-4px);
  }
  .showcase-card img {
    position: absolute;
    inset: 0;
    width: 100%;
