---
import BaseLayout from '../components/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTA from '../components/CTA.astro';
import { SERVICES, MATERIALS, PORTFOLIO_PROJECTS, FAQ, TESTIMONIALS, SITE_CONFIG } from '../utils/constants.js';
import { generateFAQSchema, generateReviewSchema } from '../utils/seo.js';

const wa = `https://api.whatsapp.com/send?phone=${SITE_CONFIG.whatsapp}&text=${encodeURIComponent('Halo Tepat Laser, saya ingin konsultasi project dan kirim file desain.')}`;
const meta = { title: 'Tepat Laser — Precision Fabrication untuk Project Nyata', description: 'Laser cutting metal dan non-metal, CNC router, serta engraving dengan proses teknis yang jelas dan hasil presisi untuk kebutuhan industri, arsitektur, interior, dan signage.', keywords: 'jasa laser cutting Tangerang Selatan, laser fiber, laser CO2, CNC router, galvo engraving', url: '/', image: '/images/metal.webp', jsonLd: [generateFAQSchema(FAQ), generateReviewSchema(TESTIMONIALS)] };
---
<BaseLayout {...meta}><Header slot="header" />
  <main class="home-page overflow-hidden">
    <section class="relative isolate flex min-h-[min(900px,100svh)] items-end overflow-hidden border-b border-[var(--line)] pt-28 pb-12 md:pb-20">
      <img src="/images/metal.webp" alt="Detail material metal hasil laser cutting Tepat Laser" class="absolute inset-0 -z-20 h-full w-full object-cover object-center" width="1920" height="1080" fetchpriority="high" />
      <div class="absolute inset-0 -z-10 bg-[linear-gradient(90deg,rgba(8,11,10,.98)_0%,rgba(8,11,10,.78)_48%,rgba(8,11,10,.28)_100%)]"></div><div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_75%_35%,rgba(184,255,61,.2),transparent_25rem)]"></div>
      <div class="container-custom grid items-end gap-10 lg:grid-cols-[minmax(0,1fr)_20rem]">
        <div><div class="eyebrow mb-7 flex items-center gap-3"><span class="h-2 w-2 animate-pulse rounded-full bg-[var(--acid)]"></span>Workshop laser cutting / Tangerang Selatan</div><h1 class="heading-xl max-w-5xl text-white">Make the cut<br /><span class="text-[var(--acid)]">count.</span></h1><p class="mt-8 max-w-2xl text-lg leading-8 text-[rgba(237,240,232,.76)] md:text-xl">Dari file mentah menjadi komponen yang siap dipasang. Tepat Laser menggabungkan mesin, material, dan keputusan teknis yang tepat untuk hasil yang terlihat rapi.</p><div class="mt-9 flex flex-col gap-3 sm:flex-row"><a href={wa} target="_blank" rel="noopener noreferrer" class="btn-primary" data-wa-label="Home hero consultation">Kirim brief project <span>↗</span></a><a href="#capabilities" class="btn-secondary border-white/30 bg-white/10 text-white">Explore capability <span>↓</span></a></div></div>
        <div class="hidden border border-white/15 bg-[rgba(8,11,10,.62)] p-5 backdrop-blur-md lg:block"><div class="flex items-center justify-between border-b border-white/10 pb-4 font-mono text-[.6rem] uppercase tracking-[.14em] text-white/55"><span>Production log / 01</span><span class="text-[var(--acid)]">Live</span></div><div class="pt-5"><p class="font-mono text-[.6rem] uppercase tracking-[.14em] text-white/55">Toleransi proses</p><strong class="mt-2 block font-heading text-5xl text-white">±0.1<span class="text-2xl text-[var(--acid)]"> mm</span></strong><p class="mt-5 border-t border-white/10 pt-4 font-mono text-[.62rem] uppercase tracking-[.12em] text-white/55">File → review → cut → QC</p></div></div>
      </div>
    </section>

    <section class="border-b border-[var(--line)] bg-[var(--ink-soft)] py-5"><div class="container-custom flex flex-wrap gap-x-8 gap-y-3 font-mono text-[.62rem] uppercase tracking-[.14em] text-[var(--muted)]"><span class="text-[var(--acid)]">01 / Metal & non-metal</span><span>02 / Cut • mark • route</span><span>03 / Jabodetabek delivery</span><span>04 / File review awal</span></div></section>

    <section id="capabilities" class="section-padding"><div class="container-custom"><div class="grid gap-10 lg:grid-cols-[.7fr_1.3fr] lg:gap-20"><div><span class="eyebrow">Capabilities</span><h2 class="heading-lg mt-6">Satu workshop.<br /><span class="text-[var(--acid)]">Banyak jalur produksi.</span></h2></div><div><p class="max-w-2xl text-lg leading-8">Tidak semua proyek perlu mesin yang sama. Kami mulai dari fungsi, material, ketebalan, detail, lalu memilih rute paling masuk akal untuk hasil dan budget Anda.</p><div class="mt-10 grid gap-px border border-[var(--line)] bg-[var(--line)] sm:grid-cols-2">{SERVICES.map((service, index) => <a href={`/${service.slug}/`} class="group bg-[var(--ink)] p-6 transition-colors hover:bg-[var(--panel)]"><span class="font-mono text-xs text-[var(--acid)]">0{index + 1}</span><h3 class="mt-10 text-2xl transition-colors group-hover:text-[var(--acid)]">{service.name}</h3><p class="mt-3 text-sm leading-7">{service.description}</p><span class="mt-6 block font-mono text-xs uppercase tracking-[.14em] text-[var(--muted)] group-hover:text-[var(--acid)]">Explore route ↗</span></a>)}</div></div></div></div></section>

    <section class="section-padding border-y border-[var(--line)] bg-[var(--ink-soft)]"><div class="container-custom"><div class="flex flex-col justify-between gap-8 md:flex-row md:items-end"><div><span class="eyebrow">Material library</span><h2 class="heading-lg mt-5 max-w-3xl">Pilih material berdasarkan <span class="text-[var(--acid)]">cara ia bekerja.</span></h2></div><a href="/services/" class="btn-secondary md:w-auto">Semua material <span>↗</span></a></div><div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">{MATERIALS.slice(0,8).map((material, index) => <a href={`/${material.slug}/`} class="group relative min-h-56 overflow-hidden border border-[var(--line)]"><img src={material.image} alt={material.name} class="absolute inset-0 h-full w-full object-cover opacity-45 transition duration-700 group-hover:scale-105 group-hover:opacity-70" loading="lazy" width="800" height="600" /><div class="absolute inset-0 bg-gradient-to-t from-[var(--ink)] via-[var(--ink)]/50 to-transparent"></div><div class="relative flex h-full min-h-56 flex-col justify-end p-5"><span class="font-mono text-xs text-[var(--acid)]">0{index + 1}</span><h3 class="mt-2 text-xl">{material.name}</h3><p class="mt-1 text-xs">{material.thickness}</p></div></a>)}</div></div></section>

    <section class="section-padding"><div class="container-custom"><div class="flex flex-col justify-between gap-8 md:flex-row md:items-end"><div><span class="eyebrow">Selected output</span><h2 class="heading-lg mt-5">Yang keluar dari<br /><span class="text-[var(--acid)]">mesin kami.</span></h2></div><a href="/portfolio/" class="btn-secondary md:w-auto">Lihat semua karya <span>↗</span></a></div><div class="mt-12 grid gap-5 md:grid-cols-12">{PORTFOLIO_PROJECTS.slice(0,4).map((project, index) => <article class:list={["group relative overflow-hidden border border-[var(--line)]", index === 0 ? "md:col-span-7 md:row-span-2" : "md:col-span-5"]}><img src={project.image} alt={project.title} class="h-full min-h-64 w-full object-cover opacity-70 transition duration-700 group-hover:scale-105 group-hover:opacity-100" loading="lazy" width="1200" height="800" /><div class="absolute inset-0 bg-gradient-to-t from-[var(--ink)] via-transparent to-transparent"></div><div class="absolute inset-x-0 bottom-0 p-6"><span class="eyebrow">{project.category}</span><h3 class="mt-2 text-2xl">{project.title}</h3><p class="mt-2 max-w-lg text-sm">{project.description}</p></div></article>)}</div></div></section>

    <section class="border-y border-[var(--line)] bg-[var(--panel)] py-16"><div class="container-custom grid gap-8 md:grid-cols-3"><div><strong class="font-heading text-5xl text-[var(--acid)]">01</strong><p class="mt-3 text-sm">Kirim file, ukuran, material, dan deadline.</p></div><div><strong class="font-heading text-5xl text-[var(--acid)]">02</strong><p class="mt-3 text-sm">Kami cek kelayakan teknis dan susun opsi produksi.</p></div><div><strong class="font-heading text-5xl text-[var(--acid)]">03</strong><p class="mt-3 text-sm">Produksi, QC, lalu kirim dalam kondisi siap kerja.</p></div></div></section>
    <CTA title="Proyek Anda dimulai dari satu file." description="Kirim gambar, sketsa, atau brief singkat. Tim Tepat Laser akan membantu mengubahnya menjadi rencana produksi yang jelas." primaryText="Mulai konsultasi" secondaryText="Baca panduan" secondaryLink="/blog/" />
  </main>
  <Footer slot="footer" />
</BaseLayout>
