---
import BaseLayout from '../components/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTA from '../components/CTA.astro';
import { SERVICES, MATERIALS, FAQ, SITE_CONFIG } from '../utils/constants.js';
import { generateFAQSchema } from '../utils/seo.js';

const wa = `https://api.whatsapp.com/send?phone=${SITE_CONFIG.whatsapp}&text=${encodeURIComponent('Halo Tepat Laser, saya ingin konsultasi proyek dan mengirim file desain.')}`;
const meta = { title: 'Tepat Laser — Laser Cutting & Fabrikasi Presisi Tangsel', description: 'Laser cutting metal dan non-metal, CNC router, serta engraving untuk kebutuhan arsitektur, interior, signage, dan komponen custom di Tangerang Selatan.', keywords: 'jasa laser cutting Tangerang Selatan, laser fiber, laser CO2, CNC router, galvo engraving', url: '/', image: '/gambar/pagar-laser-cutting-landing/hero-pagar-laser-cutting.webp', jsonLd: [generateFAQSchema(FAQ)] };
const showcases = [
  { title: 'Pagar panel custom', label: 'Eksterior', image: '/gambar/pagar-laser-cutting-landing/hero-pagar-laser-cutting.webp' },
  { title: 'Reling berpola', label: 'Interior', image: '/gambar/railing-laser-cutting-landing/reling-tangga-daylight.webp' },
  { title: 'Fasad arsitektural', label: 'Panel bangunan', image: '/gambar/pagar-laser-cutting-landing/fasad-gedung-laser-cutting.webp' }
];
---

<BaseLayout {...meta}><Header slot="header" />
  <main class="home-page overflow-hidden">
    <section class="home-hero">
      <div class="container-custom home-hero-grid">
        <div class="home-hero-copy"><span class="eyebrow">Workshop fabrikasi · Tangerang Selatan</span><h1 class="heading-xl mt-7">Potongan presisi.<br /><em>Proyek berjalan pasti.</em></h1><p class="mt-7 max-w-xl text-lg leading-8">Kami membantu menerjemahkan file, ukuran, dan material menjadi komponen yang rapi—dengan proses yang jelas dari peninjauan awal hingga pemeriksaan mutu.</p><div class="mt-8 flex flex-col gap-3 sm:flex-row"><a href={wa} target="_blank" rel="noopener noreferrer" class="btn-primary" data-wa-label="Home hero consultation">Kirim brief proyek <span>↗</span></a><a href="#kapabilitas" class="btn-secondary">Jelajahi kapabilitas <span>↓</span></a></div><div class="hero-facts"><span><strong>4</strong> proses utama</span><span><strong>7+</strong> jenis material</span><span><strong>1</strong> tim teknis</span></div></div>
        <figure class="home-hero-media"><div class="home-hero-pictures"><picture><img src="/images/generated/fiber-laser-v5.webp" alt="Mesin fiber laser memotong lembaran metal secara presisi" width="1586" height="1000" fetchpriority="high" decoding="sync" /></picture></div><figcaption><span>Fiber laser cutting</span><span>Presisi produksi · Tangsel</span></figcaption></figure>
      </div>
    </section>

    <section class="kinetic-line" aria-label="Kapabilitas utama"><div class="kinetic-track"><span>Laser fiber</span><span>Laser CO₂</span><span>CNC router</span><span>Galvo engraving</span><span>Review file</span><span>Quality control</span><span>Laser fiber</span><span>Laser CO₂</span><span>CNC router</span><span>Galvo engraving</span><span>Review file</span><span>Quality control</span></div></section>

    <section id="kapabilitas" class="dark-section section-padding"><div class="container-custom"><div class="section-head"><div><span class="eyebrow">Kapabilitas</span><h2 class="heading-lg mt-6">Proses dipilih berdasarkan fungsi, bukan kebiasaan.</h2></div><p>Tidak semua desain harus masuk ke mesin yang sama. Kami meninjau material, ketebalan, geometri, jumlah, dan hasil akhir sebelum menentukan jalur produksi.</p></div><div class="service-list">{SERVICES.map((service,index) => <a href={`/${service.slug}/`}><span class="number-tag">0{index+1}</span><div><h3>{service.name}</h3><p>{service.description}</p></div><span class="service-arrow">↗</span></a>)}</div></div></section>

    <section class="section-padding warm-section"><div class="container-custom"><div class="section-head"><div><span class="eyebrow">Material</span><h2 class="heading-lg mt-6">Mulai dari karakter bahan yang benar.</h2></div><p>Setiap material merespons panas, kecepatan, dan finishing secara berbeda. Pilih bahan berdasarkan fungsi, lokasi penggunaan, dan kualitas permukaan yang diharapkan.</p></div><div class="material-grid">{MATERIALS.map((material,index) => <a href={`/${material.slug}/`} class="material-card"><img src={material.image} alt={material.name} width="800" height="600" loading="lazy" decoding="async" /><div class="material-shade"></div><div class="material-copy"><span class="number-tag">0{index+1}</span><h3>{material.name}</h3><p>{material.thickness}</p><span>Detail material ↗</span></div></a>)}</div></div></section>

    <section class="section-padding"><div class="container-custom"><div class="flex flex-col gap-7 md:flex-row md:items-end md:justify-between"><div><span class="eyebrow">Pilihan aplikasi</span><h2 class="heading-lg mt-6">Dari lembaran menjadi bagian ruang.</h2></div><a href="/portfolio/" class="btn-secondary md:w-auto">Lihat portofolio <span>↗</span></a></div><div class="showcase-grid">{showcases.map((item,index) => <article class:list={["showcase-card",index===0&&"showcase-wide"]}><img src={item.image} alt={item.title} width="1200" height="800" loading={index===0?'eager':'lazy'} decoding="async" /><div><span>{item.label}</span><h3>{item.title}</h3></div></article>)}</div></div></section>

    <section class="process-strip"><div class="container-custom"><div><span>01</span><h3>Kirim kebutuhan</h3><p>File, ukuran, material, jumlah, dan target waktu.</p></div><div><span>02</span><h3>Peninjauan teknis</h3><p>Kami cek geometri, bahan, dan opsi proses.</p></div><div><span>03</span><h3>Produksi & pemeriksaan</h3><p>Hasil diperiksa sebelum dikirim atau diambil.</p></div></div></section>
    <CTA title="Satu file bisa menjadi awal proyek yang lebih jelas." description="Tidak harus sempurna. Kirim gambar, sketsa, atau brief singkat; tim Tepat Laser akan membantu memetakan langkah berikutnya." primaryText="Mulai konsultasi" secondaryText="Baca panduan teknis" secondaryLink="/blog/" />
  </main>
  <Footer slot="footer" />
</BaseLayout>

<style>
  .home-hero{background:var(--surface);padding-top:4.8rem}
  .home-hero-grid{display:grid;min-height:calc(100svh - 4.8rem);align-items:stretch}
  .home-hero-copy{display:flex;flex-direction:column;justify-content:center;padding-block:clamp(4.5rem,8vw,7rem)}
  .home-hero h1 em{color:var(--laser);font-style:normal}
  .home-hero-media{position:relative;min-height:34rem;overflow:hidden;background:#050906}.home-hero-pictures{position:absolute;inset:-4%}.home-hero-media picture{display:block;width:100%;height:100%;overflow:hidden}.home-hero-media img{width:100%;height:100%;object-fit:cover;object-position:58% center}.home-hero-media::after{position:absolute;inset:0;content:'';background:linear-gradient(to top,rgba(5,9,6,.82),transparent 55%)}.home-hero-media figcaption{position:absolute;z-index:1;right:1.25rem;bottom:1.25rem;left:1.25rem;display:flex;justify-content:space-between;color:#fff;font-size:.65rem;font-weight:750;letter-spacing:.09em;text-transform:uppercase}
  .hero-facts{display:flex;flex-wrap:wrap;gap:1.2rem 2.2rem;margin-top:3.5rem;border-top:1px solid var(--line);padding-top:1.3rem;color:var(--muted);font-size:.7rem;font-weight:700}.hero-facts strong{margin-right:.3rem;color:var(--ink);font-family:'Clash Display',sans-serif;font-size:1.4rem;font-weight:600}
  .section-head{display:grid;gap:2rem}.section-head>p{max-width:34rem;font-size:1rem;line-height:1.8}.service-list{margin-top:3.5rem;border-top:1px solid rgba(255,255,255,.16)}.service-list>a{display:grid;grid-template-columns:2.5rem 1fr auto;align-items:center;gap:1.2rem;border-bottom:1px solid rgba(255,255,255,.16);padding:1.6rem 0;transition:padding .35s var(--ease),background .35s var(--ease)}.service-list>a:hover{padding-inline:.8rem;background:rgba(184,255,61,.055)}.service-list h3{font-size:clamp(1.6rem,3vw,2.6rem)}.service-list p{max-width:42rem;margin-top:.45rem;font-size:.78rem;line-height:1.6}.service-arrow{color:var(--laser);font-size:1.4rem;transition:transform .3s var(--ease)}.service-list>a:hover .service-arrow{transform:translate(.25rem,-.25rem)}
  .material-grid{display:grid;gap:1px;margin-top:3.5rem;border:1px solid var(--line);background:var(--line)}.material-card{position:relative;min-height:18rem;overflow:hidden;background:#050906}.material-card>img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:saturate(.7);transition:transform .8s var(--ease),filter .8s var(--ease)}.material-card:hover>img{transform:scale(1.07);filter:saturate(1)}.material-shade{position:absolute;inset:0;background:linear-gradient(to top,rgba(5,9,6,.96),rgba(5,9,6,.18) 72%)}.material-copy{position:absolute;z-index:1;right:1.3rem;bottom:1.3rem;left:1.3rem}.material-grid h3{margin-top:2.2rem;color:#fff;font-size:1.25rem}.material-grid p{margin-top:.45rem;color:rgba(255,255,255,.7);font-size:.75rem}.material-copy>span:last-child{display:block;margin-top:1.4rem;color:var(--laser);font-size:.68rem;font-weight:800}
  .showcase-grid{display:grid;gap:1rem;margin-top:3rem}.showcase-card{position:relative;min-height:29rem;overflow:hidden;background:#050906}.showcase-card img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:transform .7s var(--ease)}.showcase-card:hover img{transform:scale(1.045)}.showcase-card::after{position:absolute;inset:0;content:'';background:linear-gradient(to top,rgba(5,9,6,.86),transparent 58%)}.showcase-card>div{position:absolute;z-index:1;right:1.5rem;bottom:1.5rem;left:1.5rem}.showcase-card span{color:var(--laser);font-size:.65rem;font-weight:800;letter-spacing:.12em;text-transform:uppercase}.showcase-card h3{margin-top:.45rem;color:#fff;font-size:1.8rem}
  .process-strip{border-block:1px solid var(--line);background:var(--surface);padding-block:2.5rem}.process-strip>.container-custom{display:grid;gap:2rem}.process-strip span{color:var(--laser-deep);font-size:.7rem;font-weight:800}.process-strip h3{margin-top:1rem;font-size:1.25rem}.process-strip p{margin-top:.5rem;font-size:.78rem;line-height:1.65}
  @media(min-width:760px){.material-grid{grid-template-columns:repeat(4,minmax(0,1fr))}.showcase-grid{grid-template-columns:1.25fr .75fr}.showcase-wide{grid-row:span 2}.process-strip>.container-custom{grid-template-columns:repeat(3,minmax(0,1fr))}.process-strip>.container-custom>div+div{border-left:1px solid var(--line);padding-left:2rem}}
  @media(min-width:1000px){.home-hero-grid{grid-template-columns:1fr .9fr;gap:3rem}.section-head{grid-template-columns:1.15fr .85fr;align-items:end}.home-hero-media{margin-block:2rem}.home-hero-copy{padding-right:2rem}}
  @media(max-width:640px){.home-hero-grid{min-height:auto}.home-hero-media{min-height:26rem}.home-hero-pictures{display:block}.home-hero-pictures picture:first-child{display:block;height:100%}.home-hero-media img{object-position:64% center}.hero-facts{margin-top:2.5rem}.showcase-card{min-height:23rem}}
</style>
