---
import BaseLayout from '../components/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { SITE_CONFIG, SERVICES, MATERIALS } from '../utils/constants.js';
import { generateBreadcrumbSchema } from '../utils/seo.js';

const WA_LINK = `https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent('Halo Tepat Laser, saya ingin konsultasi layanan laser cutting yang sesuai kebutuhan saya.')}`;
const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Beranda', url: '/' },
  { name: 'Services', url: '/services/' }
]);

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: SERVICES.map((service, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: service.name,
    url: `https://www.tepatlaser.com/${service.slug}/`
  }))
};

const meta = {
  title: 'Services Laser Cutting, CNC Router & Engraving | Tepat Laser',
  description: 'Daftar layanan Tepat Laser: laser fiber metal, laser CO2, CNC router, galvo engraving, laser cutting akrilik, MDF, plywood, ACP, PVC, GRC, stainless, dan plat besi.',
  keywords: 'services laser cutting, jasa laser cutting, laser fiber, laser co2, cnc router, galvo engraving, potong akrilik, potong stainless, potong plat besi',
  url: '/services/',
  image: '/images/metal.webp',
  type: 'website',
  jsonLd: [breadcrumbSchema, serviceSchema]
};

const crumbs = breadcrumbSchema.itemListElement;
---

<BaseLayout {...meta}>
  <Header slot="header" />
  <main class="mt-16 overflow-x-hidden">
    <Breadcrumbs crumbs={crumbs} />

    <section class="relative bg-slate-950 text-white py-24 md:py-32 overflow-hidden">
      <div class="absolute inset-0 opacity-20" style="background-image:url('/images/metal.webp'); background-size:cover; background-position:center;"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-slate-950 via-slate-950/90 to-slate-950/20"></div>
      <div class="container-custom relative z-10">
        <div class="max-w-3xl">
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight mb-6">Services Tepat Laser</h1>
          <p class="text-lg sm:text-xl text-slate-300 mb-8 leading-relaxed">Satu workshop untuk kebutuhan laser cutting, CNC router, dan engraving: metal, stainless steel, akrilik, MDF, plywood, ACP, PVC, GRC, hingga kebutuhan signage dan komponen custom.</p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href={WA_LINK} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center bg-emerald-500 hover:bg-emerald-600 text-white font-bold px-8 py-4 rounded-xl text-lg shadow-lg shadow-emerald-500/20 transition-all" data-gtm-id="whatsapp-click">Konsultasi Layanan</a>
            <a href="/proses-produksi-lead-time/" class="inline-flex items-center justify-center border-2 border-slate-700 hover:border-slate-500 text-white font-semibold px-8 py-4 rounded-xl text-lg hover:bg-slate-800 transition-all">Proses & Lead Time</a>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 bg-white text-slate-900">
      <div class="container-custom">
        <div class="text-center max-w-3xl mx-auto mb-14">
          <h2 class="text-3xl md:text-4xl font-extrabold mb-4">Layanan Utama</h2>
          <p class="text-slate-600 text-lg">Pilih layanan berdasarkan jenis material, ketebalan, detail desain, dan target hasil akhir.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {SERVICES.map(service => (
            <a href={`/${service.slug}/`} class="group block bg-white rounded-2xl border border-slate-200 overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all">
              <img src={service.image} alt={service.name} class="w-full h-44 object-cover" loading="lazy" />
              <div class="p-6">
                <h3 class="text-xl font-bold mb-2 group-hover:text-blue-600 transition-colors">{service.name}</h3>
                <p class="text-slate-600 text-sm leading-relaxed mb-4">{service.description}</p>
                <span class="font-bold text-blue-600 text-sm">Lihat detail →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20 bg-slate-50 border-t border-slate-200">
      <div class="container-custom">
        <div class="text-center max-w-3xl mx-auto mb-14">
          <h2 class="text-3xl md:text-4xl font-extrabold mb-4">Layanan Berdasarkan Material</h2>
          <p class="text-slate-600 text-lg">Setiap material punya parameter potong berbeda. Tim kami bantu memilih metode paling efisien.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {MATERIALS.map(material => (
            <a href={`/${material.slug}/`} class="group flex gap-5 bg-white p-5 rounded-2xl border border-slate-200 shadow-sm hover:shadow-lg transition-all">
              <img src={material.image} alt={material.name} class="w-24 h-24 object-cover rounded-xl flex-shrink-0" loading="lazy" />
              <div>
                <h3 class="font-bold text-lg mb-1 group-hover:text-blue-600 transition-colors">{material.name}</h3>
                <p class="text-xs font-semibold text-slate-500 mb-2">Ketebalan: {material.thickness}</p>
                <p class="text-slate-600 text-sm leading-relaxed">{material.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20 bg-white border-t border-slate-200">
      <div class="container-custom grid grid-cols-1 lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-7">
          <h2 class="text-3xl md:text-4xl font-extrabold mb-5">Bingung pilih layanan yang mana?</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-8">Kirim foto, sketsa, atau file desain. Kami bantu tentukan apakah lebih cocok diproses dengan laser fiber, laser CO2, CNC router, atau engraving.</p>
          <a href={WA_LINK} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center bg-blue-600 hover:bg-blue-700 text-white font-bold px-8 py-4 rounded-xl text-lg transition-all" data-gtm-id="whatsapp-click">Kirim File untuk Dicek</a>
        </div>
        <div class="lg:col-span-5 bg-slate-950 text-white rounded-3xl p-8 shadow-xl">
          <h3 class="text-2xl font-bold mb-6">Yang perlu dikirim</h3>
          <ul class="space-y-4 text-slate-300">
            <li>✓ Ukuran dan jumlah kebutuhan</li>
            <li>✓ Jenis material dan ketebalan</li>
            <li>✓ File DXF/DWG/AI/CDR/SVG/PDF vector bila ada</li>
            <li>✓ Target finishing dan deadline produksi</li>
          </ul>
        </div>
      </div>
    </section>
  </main>
  <Footer slot="footer" />
</BaseLayout>
