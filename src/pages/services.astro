---
import BaseLayout from '../components/BaseLayout.astro'; import Header from '../components/Header.astro'; import Footer from '../components/Footer.astro'; import CTA from '../components/CTA.astro'; import PageIntro from '../components/PageIntro.astro'; import { SERVICES, MATERIALS, SITE_CONFIG } from '../utils/constants.js'; import { generateBreadcrumbSchema } from '../utils/seo.js';
const crumbs = generateBreadcrumbSchema([{name:'Beranda',url:'/'},{name:'Layanan',url:'/services/'}]); const wa = `https://api.whatsapp.com/send?phone=${SITE_CONFIG.whatsapp}&text=${encodeURIComponent('Halo Tepat Laser, saya ingin konsultasi layanan untuk proyek saya.')}`;
---
<BaseLayout title="Layanan Tepat Laser — Laser Cutting, CNC Router & Engraving" description="Pilih jalur produksi Tepat Laser untuk metal, non-metal, signage, arsitektur, interior, prototyping, dan kebutuhan custom." keywords="jasa laser cutting, laser fiber, laser CO2, CNC router, galvo engraving" url="/services/" jsonLd={[crumbs]}><Header slot="header" />
  <main class="overflow-hidden"><PageIntro eyebrow="Layanan produksi" title="Satu kebutuhan. Empat teknologi. Tanpa salah pilih proses." description="Kami tidak mulai dari nama mesin. Kami mulai dari fungsi, material, detail, jumlah, dan kualitas hasil yang harus Anda capai." actionText="Diskusikan kebutuhan" actionHref={wa} />
    <section class="kinetic-line" aria-label="Sistem produksi"><div class="kinetic-track"><span>Mesin yang tepat</span><span>Material yang sesuai</span><span>File siap produksi</span><span>Output diperiksa</span><span>Mesin yang tepat</span><span>Material yang sesuai</span><span>File siap produksi</span><span>Output diperiksa</span></div></section>
    <section class="section-padding"><div class="container-custom"><div class="service-table accent-cycle">{SERVICES.map((service,index) => <a href={`/${service.slug}/`}><span class="number-tag">0{index+1}</span><div><h2>{service.name}</h2><p>{service.description}</p></div><div><small>Cocok untuk</small><p>{service.applications.join(' · ')}</p></div><strong>↗</strong></a>)}</div></div></section>
    <section class="warm-section section-padding"><div class="container-custom service-materials"><div><span class="eyebrow">Material</span><h2 class="heading-lg mt-6">Bahan menentukan proses dan kualitas tepi.</h2><p class="mt-6 max-w-lg leading-8">Ketebalan di bawah adalah rentang umum. Kelayakan final tetap mengikuti jenis bahan, geometri, dan target hasil.</p></div><div class="material-list">{MATERIALS.map((item,index) => <a href={`/${item.slug}/`}><span>0{index+1}</span><div><h3>{item.name}</h3><p>{item.thickness}</p></div><strong>→</strong></a>)}</div></div></section>
    <CTA title="Anda tidak perlu hafal nama mesin untuk memulai." description="Kirim file atau referensi. Kami bantu membaca material, geometri, volume, dan kualitas akhir untuk memilih proses yang paling masuk akal." primaryText="Kirim file via WhatsApp" secondaryText="Baca panduan teknis" secondaryLink="/blog/" />
  </main><Footer slot="footer" />
</BaseLayout>
<style>
  .service-table{border-top:1px solid var(--line)}.service-table>a{display:grid;grid-template-columns:2.5rem 1fr auto;align-items:center;gap:1rem;border-bottom:1px solid var(--line);padding:1.6rem 0;transition:padding .35s var(--ease),background .35s var(--ease)}.service-table>a:hover{padding-inline:.75rem;background:rgba(54,114,172,.09)}.service-table h2{font-size:clamp(1.7rem,3vw,2.55rem)}.service-table p{margin-top:.5rem;max-width:38rem;font-size:.8rem;line-height:1.65}.service-table>a>div:nth-child(3){display:none}.service-table>a>strong{color:var(--laser);font-size:1.4rem;transition:transform .3s var(--ease)}.service-table>a:hover>strong{transform:translate(.25rem,-.25rem)}
  .service-materials{display:grid;gap:3rem}.material-list{border-top:1px solid var(--line)}.material-list>a{display:grid;grid-template-columns:2rem 1fr auto;align-items:center;gap:1rem;border-bottom:1px solid var(--line);padding:1rem 0;transition:padding .3s var(--ease),background .3s var(--ease)}.material-list>a:hover{padding-inline:.6rem;background:rgba(54,114,172,.09)}.material-list>a>span{color:var(--laser-deep);font-size:.65rem;font-weight:800}.material-list h3{font-size:1.2rem}.material-list p{font-size:.72rem}.material-list strong{color:var(--laser-deep)}
  @media(min-width:800px){.service-table>a{grid-template-columns:3rem 1fr .65fr auto}.service-table>a>div:nth-child(3){display:block;border-left:1px solid var(--line);padding-left:1.5rem}.service-table small{color:var(--laser-deep);font-size:.62rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase}.service-table>a>div:nth-child(3) p{color:var(--ink)}.service-materials{grid-template-columns:.85fr 1.15fr}}
</style>
