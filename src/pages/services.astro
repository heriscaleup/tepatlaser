---
import BaseLayout from '../components/BaseLayout.astro'; import Header from '../components/Header.astro'; import Footer from '../components/Footer.astro'; import CTA from '../components/CTA.astro'; import { SERVICES, MATERIALS, SITE_CONFIG } from '../utils/constants.js'; import { generateBreadcrumbSchema } from '../utils/seo.js';
const crumbs = generateBreadcrumbSchema([{name:'Beranda',url:'/'},{name:'Layanan',url:'/services/'}]); const wa = `https://api.whatsapp.com/send?phone=${SITE_CONFIG.whatsapp}&text=${encodeURIComponent('Halo Tepat Laser, saya ingin konsultasi layanan untuk project saya.')}`;
---
<BaseLayout title="Layanan Tepat Laser — Laser Cutting, CNC Router & Engraving" description="Pilih jalur produksi Tepat Laser untuk metal, non-metal, signage, arsitektur, interior, prototyping, dan kebutuhan custom." keywords="jasa laser cutting, laser fiber, laser CO2, CNC router, galvo engraving" url="/services/" jsonLd={[crumbs]}><Header slot="header" />
  <main class="overflow-hidden"><section class="relative border-b border-[var(--line)] pt-40 pb-20"><div class="container-custom grid gap-10 lg:grid-cols-[1fr_.7fr] lg:items-end"><div><span class="eyebrow">Services / Production routes</span><h1 class="heading-xl mt-7">Choose the<br /><span class="text-[var(--acid)]">right route.</span></h1></div><div><p class="text-lg leading-8">Empat metode, satu standar: detail yang terkontrol, jalur komunikasi yang jelas, dan hasil yang siap masuk ke project Anda.</p><a href={wa} target="_blank" rel="noopener noreferrer" class="btn-primary mt-7" data-wa-label="Services consultation">Diskusikan project <span>↗</span></a></div></div></section>
    <section class="section-padding"><div class="container-custom space-y-4">{SERVICES.map((service, index) => <a href={`/${service.slug}/`} class="group grid gap-6 border-t border-[var(--line)] py-8 transition-colors hover:border-[var(--acid)] md:grid-cols-[4rem_1fr_1fr_auto] md:items-center"><span class="font-mono text-sm text-[var(--acid)]">0{index+1}</span><div><h2 class="text-3xl transition-colors group-hover:text-[var(--acid)]">{service.name}</h2><p class="mt-3 max-w-xl text-sm leading-7">{service.description}</p></div><div class="hidden border-l border-[var(--line)] pl-6 md:block"><p class="font-mono text-[.62rem] uppercase tracking-[.14em] text-[var(--muted)]">Ideal untuk</p><p class="mt-3 text-sm text-[var(--paper)]">{service.applications.join(' · ')}</p></div><span class="text-2xl text-[var(--acid)] transition-transform group-hover:translate-x-2">↗</span></a>)}</div></section>
    <section class="border-y border-[var(--line)] bg-[var(--ink-soft)] py-20"><div class="container-custom grid gap-10 lg:grid-cols-[.7fr_1.3fr]"><div><span class="eyebrow">Material pairing</span><h2 class="heading-lg mt-5">Material menentukan<br /><span class="text-[var(--acid)]">hasil akhir.</span></h2></div><div class="grid gap-3 sm:grid-cols-2">{MATERIALS.map((material) => <a href={`/${material.slug}/`} class="line-panel p-5 transition-colors hover:border-[var(--acid)]"><span class="font-mono text-[.62rem] uppercase tracking-[.12em] text-[var(--acid)]">{material.thickness}</span><h3 class="mt-3 text-xl">{material.name}</h3><p class="mt-2 text-sm leading-6">{material.description}</p></a>)}</div></div></section><CTA title="Belum yakin pilih metode?" description="Kirim kebutuhan dan file Anda. Kami bantu menentukan proses yang paling efisien sebelum produksi dimulai." primaryText="Kirim file via WhatsApp" secondaryText="Baca blog teknis" secondaryLink="/blog/" />
  </main><Footer slot="footer" />
</BaseLayout>
