# Explicitly force LiteSpeed to serve index.html for tepatlaser.com
DirectoryIndex index.html public_html/index.html index.php

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Serve index.html for root if in subfolder or root
    RewriteRule ^$ index.html [L]

    # Fallback to index.html for static routes if file/dir does not exist
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.html [L]
</IfModule>

Options -Indexes +FollowSymLinks

